{"type":"message","id":"525c0f66","parentId":"120f6c20","timestamp":"2026-02-25T20:15:06.679Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The user is running a cron job that executes `node outreach.js` in the `/root/.openclaw/workspace/evolver` directory. This appears to be a scheduled task related to \"evomap-outreach\".\n\nLet me first understand what this does by reading the outreach.js file and checking any relevant context.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_d4d2566d935c484db5c6ab75","name":"read","arguments":{"path":"/root/.openclaw/workspace/evolver/outreach.js"}},{"type":"toolCall","id":"call_6f046b6e66234363ad24e245","name":"memory_search","arguments":{"query":"evomap outreach evolver","maxResults":5}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":2657,"output":106,"cacheRead":7616,"cacheWrite":0,"totalTokens":10379,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772050501435}}
{"type":"message","id":"1f6a518f","parentId":"525c0f66","timestamp":"2026-02-25T20:15:06.687Z","message":{"role":"toolResult","toolCallId":"call_d4d2566d935c484db5c6ab75","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * EvoMap Outreach v3 - 与其他节点建立长期联系（改进版）\n * \n * 改进点：\n * 1. ✅ 移除每天只发一次的限制 → 每天最多发布 10 次\n * 2. ✅ 改用 Bounty 悬赏任务建立联系\n * 3. ✅ 检查其他节点对 Bounty 的回复\n * 4. ✅ v3 新增：建立长期联系机制\n *    - 评估回复质量\n *    - 根据关系等级采取不同策略\n *    - 维护长期关系\n */\n\nconst https = require('https');\nconst crypto = require('crypto');\nconst fs = require('fs');\nconst path = require('path');\n\nconst { NODE_ID } = require('./credentials');\nconst { RelationshipManager } = require('./relationships');\nconst { MessageGenerator } = require('./communication-templates');\n\nconst OUTREACH_LOG = '/root/.openclaw/workspace/logs/outreach.log';\nconst STATE_FILE = '/root/.openclaw/workspace/.outreach-state.json';\nconst RESPONSES_FILE = '/root/.openclaw/workspace/memory/evomap-bounty-responses.json';\n\n// 确保日志目录存在\nconst logDir = path.dirname(OUTREACH_LOG);\nif (!fs.existsSync(logDir)) fs.mkdirSync(logDir, { recursive: true });\n\n// 确保记忆文件存在\nconst memoryDir = path.dirname(RESPONSES_FILE);\nif (!fs.existsSync(memoryDir)) fs.mkdirSync(memoryDir, { recursive: true });\n\n// 初始化关系管理器\nconst relManager = new RelationshipManager();\n\nfunction log(msg) {\n  const line = `[${new Date().toISOString()}] ${msg}\\n`;\n  console.log(msg);\n  fs.appendFileSync(OUTREACH_LOG, line);\n}\n\nfunction loadState() {\n  if (fs.existsSync(STATE_FILE)) {\n    return JSON.parse(fs.readFileSync(STATE_FILE, 'utf8'));\n  }\n  return {\n    stats: {\n      totalBounties: 0,\n      totalResponses: 0,\n      todayPublishCount: 0,\n      lastResetDate: new Date().toLocaleDateString('sv-SE', { timeZone: 'Asia/Shanghai' }),\n      relationshipsEstablished: 0,\n      longTermConnections: 0\n    },\n    lastCheck: null,\n    recentBounties: []\n  };\n}\n\nfunction saveState(state) {\n  // 每天重置计数器\n  const today = new Date().toLocaleDateString('sv-SE', { timeZone: 'Asia/Shanghai' });\n  if (state.stats.lastResetDate !== today) {\n    state.stats.todayPublishCount = 0;\n    state.stats.lastResetDate = today;\n    log('📊 每日计数器已重置');\n  }\n  \n  fs.writeFileSync(STATE_FILE, JSON.stringify(state, null, 2));\n}\n\nfunction generateMessageId() {\n  return `msg_${Date.now()}_${crypto.randomBytes(4).toString('hex')}`;\n}\n\nfunction sendA2A(messageType, payload) {\n  return new Promise((resolve, reject) => {\n    const message = {\n      protocol: 'gep-a2a',\n      protocol_version: '1.0.0',\n      message_type: messageType,\n      message_id: generateMessageId(),\n      sender_id: NODE_ID,\n      timestamp: new Date().toISOString(),\n      payload: payload\n    };\n\n    const postData = JSON.stringify(message);\n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: `/a2a/${messageType}`,\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'Content-Length': Buffer.byteLength(postData)\n      }\n    };\n\n    const timeout = setTimeout(() => reject(new Error('Timeout')), 30000);\n    const req = https.request(options, (res) => {\n      clearTimeout(timeout);\n      let data = '';\n      res.on('data', chunk => data += chunk);\n      res.on('end', () => {\n        try { resolve({ status: res.statusCode, data: JSON.parse(data) }); }\n        catch (e) { resolve({ status: res.statusCode, raw: data }); }\n      });\n    });\n    req.on('error', (e) => { clearTimeout(timeout); reject(e); });\n    req.write(postData);\n    req.end();\n  });\n}\n\nfunction httpsGet(urlPath) {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error('Timeout')), 15000);\n    https.get(`https://evomap.ai${urlPath}`, (res) => {\n      clearTimeout(timeout);\n      let data = '';\n      res.on('data', chunk => data += chunk);\n      res.on('end', () => {\n        try { resolve(JSON.parse(data)); }\n        catch (e) { resolve({ error: 'parse_error' }); }\n      });\n    }).on('error', (e) => { clearTimeout(timeout); reject(e); });\n  });\n}\n\n// 深度排序用于 canonicalization\nconst deepSort = (obj) => {\n  if (typeof obj !== 'object' || obj === null) return obj;\n  if (Array.isArray(obj)) return obj.map(deepSort);\n  const sorted = {};\n  Object.keys(obj).sort().forEach(k => sorted[k] = deepSort(obj[k]));\n  return sorted;\n};\n\nconst computeAssetId = (asset) => {\n  const { asset_id, ...rest } = asset;\n  return 'sha256:' + crypto.createHash('sha256').update(JSON.stringify(deepSort(rest))).digest('hex');\n};\n\n/**\n * 🆕 v3: 发送消息到节点\n */\nasync function sendMessageToNode(nodeId, message) {\n  log(`  📨 发送消息到 ${nodeId.substring(0, 20)}...`);\n  \n  try {\n    const result = await sendA2A('message', {\n      to: nodeId,\n      subject: message.subject || '问候',\n      body: message.body || message,\n      type: message.type || 'collaboration'\n    });\n\n    if (result.status === 200 || result.status === 201) {\n      log(`    ✅ 发送成功`);\n      return { success: true };\n    } else {\n      log(`    ⚠️ 发送失败: ${result.status}`);\n      return { success: false, error: result.status };\n    }\n  } catch (error) {\n    log(`    ❌ 发送错误: ${error.message}`);\n    return { success: false, error: error.message };\n  }\n}\n\n/**\n * 🆕 v3: 建立长期联系\n */\nasync function establishLongTermConnection(nodeId, response, bounty, state) {\n  log(`🤝 尝试与 ${nodeId.substring(0, 20)}... 建立长期联系`);\n  \n  // 1. 评估回复质量\n  const quality = relManager.evaluateResponseQuality(response);\n  log(`  质量评分: ${quality.toFixed(2)}`);\n  \n  // 2. 获取或创建节点关系\n  const node = relManager.getOrCreateNode(nodeId);\n  \n  // 3. 记录交互\n  relManager.recordInteraction(nodeId, {\n    type: 'bounty_response',\n    task: bounty.title || bounty.summary,\n    quality: quality,\n    capability: inferCapability(response)\n  });\n  \n  // 4. 根据关系等级决定策略\n  const relationshipLevel = node.relationshipLevel;\n  const interactionCount = node.interactionCount;\n  \n  log(`  关系等级: ${relationshipLevel} (第 ${interactionCount} 次交互)`);\n  \n  // 5. 准备消息上下文\n  const context = {\n    taskTitle: bounty.title || bounty.summary || '任务',\n    interactionCount: interactionCount,\n    capabilities: node.capabilities.join(', ') || '你的专业领域',\n    networkSize: relManager.getHighValueNodes().length\n  };\n  \n  // 6. 生成并发送消息\n  const message = MessageGenerator.decideMessage(relationshipLevel, context);\n  \n  if (message && quality >= 0.6) {\n    const result = await sendMessageToNode(nodeId, message);\n    \n    if (result.success) {\n      // 更新节点最后联系时间\n      node.lastContact = new Date().toISOString();\n      relManager.save();\n      \n      state.stats.longTermConnections++;\n      \n      // 记录到协作历史\n      appendToCollaborationHistory(nodeId, relationshipLevel, interactionCount, message);\n    }\n    \n    // 延迟避免 API 限流\n    await new Promise(resolve => setTimeout(resolve, 2000));\n  } else if (quality < 0.6) {\n    log(`  ⏭️ 跳过发送（质量分 < 0.6）`);\n  }\n  \n  return node;\n}\n\n/**\n * 从回复推断能力标签\n */\nfunction inferCapability(response) {\n  const content = response.content || '';\n  \n  if (content.includes('代码') || content.includes('code')) return 'code_review';\n  if (content.includes('翻译') || content.includes('translate')) return 'translation';\n  if (content.includes('算法') || content.includes('algorithm')) return 'algorithm';\n  if (content.includes('创意') || content.includes('creative')) return 'creative';\n  if (content.includes('安全') || content.includes('security')) return 'security';\n  \n  return 'general';\n}\n\n/**\n * 追加到协作历史文件\n */\nfunction appendToCollaborationHistory(nodeId, relationshipLevel, interactionCount, message) {\n  const historyFile = '/root/.openclaw/workspace/memory/collaboration-history.md';\n  \n  const entry = `\n### ${new Date().toISOString().split('T')[0]} - 交互 #${interactionCount}\n\n**节点**: \\`${nodeId.substring(0, 30)}...\\`\n**等级**: ${relationshipLevel}\n**动作**: 发送 \"${message.subject}\"\n**内容预览**: ${message.body.substring(0, 100)}...\n\n---\n`;\n\n  fs.appendFileSync(historyFile, entry);\n}\n\n/**\n * 检查之前发布的 Bounty 回复并建立联系\n */\nasync function checkBountyResponses(state) {\n  log('📨 步骤 1: 检查 Bounty 回复并建立长期联系...');\n  \n  try {\n    // 通过 fetch 获取我的任务响应\n    const fetchResult = await sendA2A('fetch', {\n      asset_type: 'Bounty',\n      include_tasks: true,\n      my_bounties: true  // 获取我发布的 bounty\n    });\n    \n    if (fetchResult.status === 200 && fetchResult.data?.payload?.bounties) {\n      const myBounties = fetchResult.data.payload.bounties;\n      log(`发现 ${myBounties.length} 个我发布的 Bounty`);\n      \n      let newResponses = 0;\n      \n      for (const bounty of myBounties) {\n        if (bounty.responses && bounty.responses.length > 0) {\n          log(`  Bounty ${bounty.asset_id.substring(0, 20)}... 有 ${bounty.responses.length} 个回复`);\n          \n          // 保存回复到记忆文件\n          const responses = JSON.parse(fs.readFileSync(RESPONSES_FILE, 'utf8') || '[]');\n          \n          for (const response of bounty.responses) {\n            // 检查是否已记录\n            const exists = responses.find(r => \n              r.bounty_id === bounty.asset_id && \n              r.responder === response.node_id &&\n              r.timestamp === response.timestamp\n            );\n            \n            if (!exists) {\n              // 保存到记忆\n              responses.push({\n                date: new Date().toISOString(),\n                bounty_id: bounty.asset_id,\n                bounty_title: bounty.summary,\n                responder: response.node_id,\n                content: response.content,\n                quality_score: response.quality_score || 0.5\n              });\n              newResponses++;\n              \n              // 🆕 v3: 尝试建立长期联系\n              await establishLongTermConnection(\n                response.node_id, \n                response, \n                bounty, \n                state\n              );\n            }\n          }\n          \n          fs.writeFileSync(RESPONSES_FILE, JSON.stringify(responses, null, 2));\n        }\n      }\n      \n      if (newResponses > 0) {\n        state.stats.totalResponses += newResponses;\n        log(`✅ 记录了 ${newResponses} 个新回复`);\n      }\n    }\n    \n    // 同时检查通过 API 的 bounty 问题列表\n    const bountyQuestions = await httpsGet('/api/hub/bounty/questions');\n    if (bountyQuestions.questions) {\n      const myQuestions = bountyQuestions.questions.filter(q => \n        q.author_node_id === NODE_ID || q.publisher === NODE_ID\n      );\n      log(`通过 API 发现 ${myQuestions.length} 个我发布的 Bounty 问题`);\n    }\n    \n  } catch (error) {\n    log(`⚠️ 检查回复失败: ${error.message}`);\n  }\n}\n\n// 发布新的 Bounty 任务\n/**\n * 根据任务类型生成 strategy（修复 400 错误）\n */\nfunction getStrategyForTask(task) {\n  const strategies = {\n    'code_review': [\n      'Review code quality and identify potential bugs',\n      'Check for security vulnerabilities and best practices',\n      'Suggest improvements for maintainability',\n      'Provide actionable feedback with examples'\n    ],\n    'translation': [\n      'Translate technical documentation accurately',\n      'Maintain technical terminology consistency',\n      'Ensure natural flow in target language',\n      'Review and refine translation quality'\n    ],\n    'algorithm': [\n      'Analyze current implementation for bottlenecks',\n      'Propose optimization strategies with complexity analysis',\n      'Suggest alternative algorithms if applicable',\n      'Provide benchmarking recommendations'\n    ],\n    'creative': [\n      'Brainstorm innovative marketing strategies',\n      'Identify target audience and channels',\n      'Propose content formats and messaging',\n      'Suggest metrics for measuring success'\n    ]\n  };\n  \n  return strategies[task.type] || [\n    'Analyze the task requirements',\n    'Propose solution approach',\n    'Implement or document findings',\n    'Review and iterate on results'\n  ];\n}\n\nasync function publishBountyTask(state, targetNode) {\n  // 添加时间戳使每个 Bounty 唯一\n  const timestamp = Date.now();\n  const dateStr = new Date().toISOString().split('T')[0];\n  \n  const taskTemplates = [\n    {\n      type: 'code_review',\n      title: '代码审查任务',\n      description: `请求审查 OpenClaw Agent 代码质量 (${dateStr} #${timestamp})`,\n      signals: ['code-review', 'security', 'best-practices'],\n      reward: 5\n    },\n    {\n      type: 'translation',\n      title: '文档翻译任务',\n      description: `翻译技术文档中英互译 (${dateStr} #${timestamp})`,\n      signals: ['translation', 'documentation', 'i18n'],\n      reward: 3\n    },\n    {\n      type: 'algorithm',\n      title: '算法优化建议',\n      description: `自动化任务调度优化思路 (${dateStr} #${timestamp})`,\n      signals: ['algorithm', 'optimization', 'scheduling'],\n      reward: 8\n    },\n    {\n      type: 'creative',\n      title: '创意征集',\n      description: `小说推广创新营销策略 (${dateStr} #${timestamp})`,\n      signals: ['marketing', 'creative', 'content'],\n      reward: 10\n    }\n  ];\n  \n  const task = taskTemplates[Math.floor(Math.random() * taskTemplates.length)];\n  \n  log(`🎯 准备发布: ${task.title}`);\n  \n  // 创建 Gene（任务定义）- 添加 strategy 字段修复 400 错误\n  const geneBase = {\n    type: 'Gene',\n    schema_version: '1.5.0',\n    category: 'optimize',  // bounty 任务通常用 optimize\n    signals_match: task.signals,\n    summary: task.description,\n    strategy: getStrategyForTask(task),  // 🆕 必需字段\n    validation: ['node -e \"console.log(\\'Bounty validation\\')\"']  // 🆕 修复：使用 node 命令\n  };\n  const geneAssetId = computeAssetId(geneBase);\n  const gene = { ...geneBase, asset_id: geneAssetId };\n  \n  // 创建 Capsule（Bounty 实例）- 添加时间戳确保唯一性\n  const capsuleBase = {\n    type: 'Capsule',\n    schema_version: '1.5.0',\n    trigger: task.signals,\n    gene: geneAssetId,\n    summary: `[Bounty] ${task.title}: ${task.description}`,\n    strategy: getStrategyForTask(task),  // 🆕 必需字段（Capsule 也需要）\n    confidence: 0.85,\n    blast_radius: { files: 1, lines: 50 },\n    outcome: { status: 'pending', score: 0 },\n    env_fingerprint: { \n      platform: 'linux', \n      arch: 'x64', \n      node_version: process.version,\n      task_type: 'bounty',\n      reward_credits: task.reward,\n      timestamp: timestamp  // 添加时间戳确保唯一性\n    },\n    success_streak: 0,\n    // 添加目标节点（如果指定）\n    target_nodes: targetNode ? [targetNode.node_id] : undefined,\n    bounty: {\n      enabled: true,\n      reward: task.reward,\n      expires_in: 86400  // 24小时\n    }\n  };\n  const capsuleAssetId = computeAssetId(capsuleBase);\n  const capsule = { ...capsuleBase, asset_id: capsuleAssetId };\n  \n  try {\n    const result = await sendA2A('publish', {\n      assets: [gene, capsule]\n    });\n    \n    // 🆕 详细错误日志\n    if (result.status !== 200 && result.status !== 201) {\n      log(`⚠️ 发布失败: ${result.status}`);\n      log(`❌ 错误详情: ${JSON.stringify(result.data || result.raw || result)}`);\n      return { success: false, error: result.status };\n    }\n    \n    if (result.status === 200 || result.status === 201) {\n      log(`✅ Bounty 发布成功`);\n      \n      // 记录到状态\n      state.recentBounties.push({\n        asset_id: capsuleAssetId,\n        title: task.title,\n        reward: task.reward,\n        published_at: new Date().toISOString(),\n        target: targetNode?.node_id || 'broadcast'\n      });\n      \n      // 保持最近 20 个记录\n      if (state.recentBounties.length > 20) {\n        state.recentBounties = state.recentBounties.slice(-20);\n      }\n      \n      state.stats.totalBounties++;\n      state.stats.todayPublishCount++;\n      \n      return { success: true, asset_id: capsuleAssetId };\n    } else {\n      log(`⚠️ 发布失败: ${result.status}`);\n      return { success: false, error: result.status };\n    }\n  } catch (error) {\n    log(`❌ 发布错误: ${error.message}`);\n    return { success: false, error: error.message };\n  }\n}\n\nasync function main() {\n  log('===== EvoMap Outreach v3 - 长期联系版 =====');\n  \n  const state = loadState();\n  \n  try {\n    // 1. 检查之前发布的任务回复 + 建立长期联系\n    await checkBountyResponses(state);\n    \n    // 2. 检查今日发布限制\n    const MAX_PUBLISH_PER_DAY = 10;\n    if (state.stats.todayPublishCount >= MAX_PUBLISH_PER_DAY) {\n      log(`📊 今日发布次数已达上限（${MAX_PUBLISH_PER_DAY}次），跳过发布`);\n      log('Outreach 完成 ✓');\n      saveState(state);\n      return;\n    }\n    \n    // 3. 获取活跃节点（优先选择有关系基础的节点）\n    log('🔍 步骤 2: 获取目标节点...');\n    \n    // 3.1 先检查高价值节点（朋友/合作伙伴）\n    const highValueNodes = relManager.getHighValueNodes();\n    let activeNodes = [];\n    \n    if (highValueNodes.length > 0) {\n      log(`发现 ${highValueNodes.length} 个高价值节点（优先）`);\n      for (const node of highValueNodes.slice(0, 5)) {\n        log(`  - ${node.id.substring(0, 20)}... ${node.relationshipLevel} (${node.interactionCount}次)`);\n        activeNodes.push({ node_id: node.id, reputation_score: 80 }); // 模拟结构\n      }\n    }\n    \n    // 3.2 如果高价值节点不足，从网络获取\n    if (activeNodes.length < 5) {\n      const nodes = await httpsGet('/a2a/nodes?limit=50');\n      \n      if (nodes.nodes && nodes.nodes.length > 0) {\n        // 筛选高信誉节点（排除自己）\n        const networkNodes = nodes.nodes\n          .filter(n => n.node_id !== NODE_ID && n.reputation_score >= 50)\n          .slice(0, 10);\n        \n        log(`从网络获取 ${networkNodes.length} 个节点`);\n        \n        // 合并（去重）\n        const existingIds = new Set(activeNodes.map(n => n.node_id));\n        for (const node of networkNodes) {\n          if (!existingIds.has(node.node_id)) {\n            activeNodes.push(node);\n          }\n        }\n      }\n    }\n    \n    log(`总计 ${activeNodes.length} 个目标节点`);\n    \n    // 4. 发布新的 Bounty 任务（每次最多 3 个）\n    log('📤 步骤 3: 发布 Bounty 任务...');\n    const publishCount = Math.min(3, MAX_PUBLISH_PER_DAY - state.stats.todayPublishCount, activeNodes.length);\n    \n    if (publishCount > 0) {\n      for (let i = 0; i < publishCount; i++) {\n        const targetNode = activeNodes[i] || null;\n        const result = await publishBountyTask(state, targetNode);\n        \n        if (!result.success) {\n          log(`发布失败，跳过后续任务`);\n          break;\n        }\n        \n        // 延迟避免 API 限流\n        if (i < publishCount - 1) {\n          await new Promise(resolve => setTimeout(resolve, 2000));\n        }\n      }\n    } else {\n      log('本次不发布新任务（已达到上限或无目标节点）');\n    }\n    \n    // 5. 输出关系统计\n    const relSummary = relManager.getSummary();\n    log('\\n📊 关系统计:');\n    log(`  总节点: ${relSummary.total}`);\n    log(`  陌生人: ${relSummary.stats.strangers}`);\n    log(`  熟人: ${relSummary.stats.acquaintances}`);\n    log(`  朋友: ${relSummary.stats.friends}`);\n    log(`  合作伙伴: ${relSummary.stats.partners}`);\n    log(`  高价值: ${relSummary.highValue}`);\n    log(`  需维护: ${relSummary.needsMaintenance}`);\n    \n    // 6. 更新状态\n    state.lastCheck = new Date().toISOString();\n    saveState(state);\n    \n    log(`\\n📊 本次统计:`);\n    log(`  总 Bounty: ${state.stats.totalBounties}`);\n    log(`  今日发布: ${state.stats.todayPublishCount}/${MAX_PUBLISH_PER_DAY}`);\n    log(`  总回复数: ${state.stats.totalResponses}`);\n    log(`  长期联系: ${state.stats.longTermConnections}`);\n    log('Outreach 完成 ✓');\n    \n  } catch (error) {\n    log(`❌ 错误: ${error.message}`);\n    log(error.stack);\n    saveState(state);\n    process.exit(1);\n  }\n}\n\nmain();\n"}],"isError":false,"timestamp":1772050506684}}
