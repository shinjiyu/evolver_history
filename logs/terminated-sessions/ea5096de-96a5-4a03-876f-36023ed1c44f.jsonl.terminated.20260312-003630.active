 \n  // 构建 Gene（不含 asset_id）\n  const geneBase = {\n    type: 'Gene',\n    category: topic.category,\n    signals_match: topic.signals,\n    summary: topic.summary,\n    intent: topic.domain === 'optimization' ? 'optimize' : (topic.domain === 'automation' ? 'repair' : 'evolve'),\n    created_at: timestamp\n  };\n  const gene = { ...geneBase, asset_id: computeAssetId(geneBase) };","newText":"// 生成 Gene 和 Capsule bundle\nfunction generateAssetBundle() {\n  // category 只能是: repair, optimize, innovate, regulatory\n  const topics = [\n    {\n      category: 'optimize',\n      title: '性能优化策略',\n      summary: '全栈性能优化方案，包含数据库查询优化、缓存策略和代码级优化',\n      signals: ['performance', 'optimization', 'caching', 'database'],\n      strategy: [\n        '分析慢查询日志，识别性能瓶颈',\n        '实施 Redis 缓存层，减少数据库负载',\n        '优化关键 SQL 语句和索引结构'\n      ],\n      confidence: 0.80,\n      files: 3,\n      lines: 180\n    },\n    {\n      category: 'repair',\n      title: '智能监控告警系统',\n      summary: '基于异常检测的智能监控系统，支持自动故障诊断和自愈',\n      signals: ['monitoring', 'alerting', 'anomaly-detection', 'self-healing'],\n      strategy: [\n        '部署 Prometheus + Grafana 监控栈',\n        '配置基于阈值的智能告警规则',\n        '实现自动故障检测和恢复流程'\n      ],\n      confidence: 0.88,\n      files: 4,\n      lines: 200\n    },\n    {\n      category: 'innovate',\n      title: '微服务架构升级',\n      summary: '基于事件驱动的微服务架构设计，支持自动扩缩容和故障隔离',\n      signals: ['microservice', 'event-driven', 'scalability', 'isolation'],\n      strategy: [\n        '设计事件驱动的服务通信模式',\n        '实施 Kubernetes 自动扩缩容策略',\n        '建立服务熔断和降级机制'\n      ],\n      confidence: 0.85,\n      files: 3,\n      lines: 150\n    },\n    {\n      category: 'optimize',\n      title: 'CI/CD 流程优化',\n      summary: 'GitOps 风格的持续集成和持续部署流程，包含自动测试和灰度发布',\n      signals: ['ci/cd', 'gitops', 'deployment', 'automation'],\n      strategy: [\n        '配置 GitHub Actions 自动化流水线',\n        '实施蓝绿部署和金丝雀发布策略',\n        '集成自动化测试和代码质量检查'\n      ],\n      confidence: 0.82,\n      files: 2,\n      lines: 12