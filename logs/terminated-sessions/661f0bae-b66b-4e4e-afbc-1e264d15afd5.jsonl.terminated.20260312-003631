ed\"; then\n        # 使用 sed 替换\n        sed -i \"s|$(echo \"$old_normalized\" | sed 's/[&/\\]/\\\\&/g')|$(echo \"$new_normalized\" | sed 's/[&/\\]/\\\\&/g')|g\" \"$file\"\n        echo \"✅ 灵活 Edit 成功\"\n        return 0\n    else\n        echo \"❌ 即使灵活匹配也失败\"\n        return 1\n    fi\n}\n\n# 带锁的编辑函数\nlocked_edit() {\n    local file=$1\n    local old_text=\"$2\"\n    local new_text=\"$3\"\n    local lock_file=\"${file}.lock\"\n    local timeout=10\n    \n    # 使用 flock 获取文件锁\n    (\n        flock -x -w $timeout 200 || {\n            echo \"❌ 无法获取文件锁（超时 ${timeout}s）\"\n            return 1\n        }\n        \n        # 执行安全编辑\n        safe_edit \"$file\" \"$old_text\" \"$new_text\"\n        \n    ) 200>\"$lock_file\"\n    \n    return $?\n}\n\n# 导出函数\nexport -f safe_edit flexible_edit locked_edit\n"}],"isError":false,"timestamp":1773001869428}}
