unctions-impact-report-$(date +%Y%m%d-%H%M).md\"\n\n# 创建日志目录\nmkdir -p \"$(dirname \"$LOG_FILE\")\"\n\n# 日志函数\nlog() {\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $1\" | tee -a \"$LOG_FILE\"\n}\n\necho \"========================================\" | tee -a \"$LOG_FILE\"\necho \"Safe Functions 效果监控\" | tee -a \"$LOG_FILE\"\necho \"========================================\" | tee -a \"$LOG_FILE\"\necho \"\" | tee -a \"$LOG_FILE\"\n\n# ========================================\n# 1. 统计当前错误数量\n# ========================================\nlog \"📊 Step 1: 统计当前错误数量\"\nlog \"----------------------------\"\n\n# 统计最近 12 小时（720 分钟）的错误\nSESSIONS_12H=$(find \"$SESSIONS_DIR\" -name \"*.jsonl\" -type f -mmin -720 | wc -l)\nENOENT_COUNT=$(grep -r \"ENOENT\" \"$SESSIONS_DIR\"/*.jsonl 2>/dev/null | wc -l || echo \"0\")\nEDIT_FAIL_COUNT=$(grep -r \"Could not find.*exact text\" \"$SESSIONS_DIR\"/*.jsonl 2>/dev/null | wc -l || echo \"0\")\nSAFE_USAGE_COUNT=$(grep -r \"safe_read\\|safe_edit\" \"$SESSIONS_DIR\"/*.jsonl 2>/dev/null | wc -l || echo \"0\")\n\nlog \"分析文件数: $SESSIONS_12H\"\nlog \"ENOENT 错误: $ENOENT_COUNT\"\nlog \"Edit 匹配失败: $EDIT_FAIL_COUNT\"\nlog \"Safe Functions 使用: $SAFE_USAGE_COUNT\"\nlog \"\"\n\n# ========================================\n# 2. 计算增长趋势\n# ========================================\nlog \"📈 Step 2: 计算增长趋势\"\nlog \"------------------------\"\n\n# 读取上次统计（如果存在）\nSTATE_FILE=\"$WORKSPACE/logs/safe-functions-state.json\"\nif [ -f \"$STATE_FILE\" ]; then\n    LAST_ENOENT=$(jq -r '.last_enoent // 0' \"$STATE_FILE\" 2>/dev/null || echo \"0\")\n    LAST_EDIT=$(jq -r '.last_edit // 0' \"$STATE_FILE\" 2>/dev/null || echo \"0\")\n    LAST_SAFE=$(jq -r '.last_safe // 0' \"$STATE_FILE\" 2>/dev/null || echo \"0\")\n    LAST_CHECK=$(jq -r '.last_check // \"1970-01-01T00:00:00Z\"' \"$STATE_FILE\" 2>/dev/null || echo \"1970-01-01T00:00:00Z\")\n    \n    # 计算变化\n    ENOENT_CHANGE=$((ENOENT_COUNT - LAST_ENOENT))\n    EDIT_CHANGE=$((EDIT_FAIL_COUNT - LAST_EDIT))\n    SAFE_CHANGE=$((SAFE_USAGE_COUNT - LAST_SAFE))\n    \n    # 计算变化率\n    if [ \"$LAST_ENOENT\" -gt 0 ]; then\n        ENOENT_RATE=$(awk \"BEGIN {printf \\\"%.1f\\\", ($ENOENT_CHANGE / $LAST_ENOENT) * 100}\")\n    else\n        ENOENT_RATE=\"N/A\"\n    fi\n    \n    if [ \"$LAST_EDIT\" -gt 0 ]; then\n        EDIT_RATE=$(awk \"BEGIN {printf \\\"%.1f\\\", ($EDIT_CHANGE / $LAST_EDIT) * 100}\")\n    else\n        EDIT_RATE=\"N/A\"\n    fi\n    \n    log \"上次检查: $LAST_CHECK\"\n    log \"ENOENT 变化: $ENOENT_CHANGE ($ENOENT_RATE%)\"\n    log \"Edit 变化: $EDIT_CHANGE ($EDIT_RATE%)\"\n    log \"Safe Functions 变化: +$SAFE_CHANGE\"\nelse\n    log \"首次运行，无历史数据\"\n    ENOENT_CHANGE=\"N/A\"\n    EDIT_CHANGE=\"N/A\"\n    SAFE_CHANGE=\"N/A\"\n    ENOENT_RATE=\"N/A\"\n    EDIT_RATE=\"N/A\"\nfi\nlog \"\"\n\n# ========================================\n# 3. 判断效果\n# ========================================\nlog \"🎯 Step 3: 判断效果\"\nlog \"--------------------\"\n\n# 判断 ENOENT 趋势\nif [ \"$ENOENT_RATE\" != \"N/A\" ]; then\n    ENOENT_RATE_NUM=$(echo \"$ENOENT_RATE\" | awk '{print int($1)}')\n    if [ \"$ENOENT_RATE_NUM\" -lt 1 ]; then\n        ENOENT_STATUS=\"✅ 优秀（增速 <1%）\"\n        ENOENT_EMOJI=\"🟢\"\n    elif [ \"$ENOENT_RATE_NUM\" -lt 5 ]; then\n        ENOENT_STATUS=\"✅ 良好（增速 1-5%）\"\n        ENOENT_EMOJI=\"🟢\"\n    elif [ \"$ENOENT_RATE_NUM\" -lt 10 ]; then\n        ENOENT_STATUS=\"🟡 一般（增速 5-10%）\"\n        ENOENT_EMOJI=\"🟡\"\n    else\n        ENOENT_STATUS=\"🔴 需关注（增速 >10%）\"\n        ENOENT_EMOJI=\"🔴\"\n    fi\nelse\n    ENOENT_STATUS=\"⏳ 首次运行\"\n    ENOENT_EMOJI=\"⏳\"\nfi\n\n# 判断 Edit 趋势\nif [ \"$EDIT_RATE\" != \"N/A\" ]; then\n    EDIT_RATE_NUM=$(echo \"$EDIT_RATE\" | awk '{print int($1)}')\n    if [ \"$EDIT_RATE_NUM\" -lt 1 ]; then\n        EDIT_STATUS=\"✅ 优秀（增速 <1%）\"\n        EDIT_EMOJI=\"🟢\"\n    elif [ \"$EDIT_RATE_NUM\" -lt 5 ]; then\n        EDIT_STATUS=\"✅ 良好（增速 1-5%）\"\n        EDIT_EMOJI=\"🟢\"\n    elif [ \"$EDIT_RATE_NUM\" -lt 10 ]; then\n        EDIT_STATUS=\"🟡 一般（增速 5-10%）\"\n        EDIT_EMOJ