ce-between;\n            align-items: center;\n        }\n        \n        .modal-header h3 {\n            margin: 0;\n        }\n        \n        .modal-body {\n            padding: 20px;\n        }\n        \n        .form-group {\n            margin-bottom: 15px;\n        }\n        \n        .form-group label {\n            display: block;\n            margin-bottom: 5px;\n            font-weight: bold;\n        }\n        \n        .form-group textarea {\n            width: 100%;\n            padding: 10px;\n            border: 1px solid #ddd;\n            border-radius: 4px;\n            font-size: 14px;\n            font-family: inherit;\n        }\n        \n        .form-actions {\n            display: flex;\n            justify-content: flex-end;\n            gap: 10px;\n            margin-top: 20px;\n        }\n        \n        .btn-primary {\n            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);\n            color: white;\n            border: none;\n            padding: 10px 20px;\n            border-radius: 4px;\n            cursor: pointer;\n        }\n        \n        .btn-secondary {\n            background: #f5f5f5;\n            color: #666;\n            border: 1px solid #ddd;\n            padding: 10px 20px;\n            border-radius: 4px;\n            cursor: pointer;\n        }\n        \n        .btn-close {\n            background: transparent;\n            border: none;\n            color: white;\n            font-size: 24px;\n            cursor: pointer;\n        }\n        \n        .empty-state {\n            text-align: center;\n            padding: 60px 20px;\n            color: #999;\n        }\n        \n        .hidden {\n            display: none !important;\n        }\n        \n        .login-screen {\n            max-width: 400px;\n            margin: 100px auto;\n            padding: 40px;\n            background: white;\n            border-radius: 8px;\n            box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n        }\n        \n        .login-screen h2 {\n            text-align: center;\n            margin-bottom: 30px;\n        }\n    </style>\n</head>\n<body>\n    <!-- 登录界面 -->\n    <div id=\"login-screen\" class=\"login-screen\">\n        <h2>🔐 管理员登录</h2>\n        <form id=\"login-form\">\n            <div class=\"form-group\">\n                <label for=\"admin-token\">管理员令牌</label>\n                <input type=\"password\" id=\"admin-token\" required\n                       placeholder=\"请输入管理员令牌\" style=\"width:100%; padding:10px; border:1px solid #ddd; border-radius:4px;\">\n            </div>\n            <button type=\"submit\" class=\"btn-primary\" style=\"width:100%;\">登录</button>\n        </form>\n    </div>\n    \n    <!-- 管理界面 -->\n    <div id=\"admin-screen\" class=\"admin-container hidden\">\n        <div class=\"admin-header\">\n            <h1>📋 审查员后台</h1>\n            <p>深渊代行者批注管理系统</p>\n        </div>\n        \n        <!-- 统计卡片 -->\n        <div class=\"stats-grid\">\n            <div class=\"stat-card\">\n                <h3>总批注数</h3>\n                <div class=\"number\" id=\"total-count\">0</div>\n            </div>\n            <div class=\"stat-card pending\">\n                <h3>待处理</h3>\n                <div class=\"number\" id=\"pending-count\">0</div>\n            </div>\n            <div class=\"stat-card accepted\">\n                <h3>已采纳</h3>\n                <div class=\"number\" id=\"accepted-count\">0</div>\n            </div>\n            <div class=\"stat-card rejected\">\n                <h3>已拒绝</h3>\n                <div class=\"number\" id=\"rejected-count\">0</div>\n            </div>\n        </div>\n        \n        <!-- 筛选器 -->\n        <div class=\"filters\">\n            <label>状态：</label>\n            <select id=\"status-filter\" onchange=\"loadAnnotations()\">\n                <option value=\"\">全部</option>\n                <option value=\"pending\" selected>待处理</option>\n                <option value=\"accepted\">已采纳</option>\n                <option value=\"rejected\">已拒绝</option>\n            </select>\n            \n            <label>章节：</label>\n            <select id=\"chapter-filter\" onchange=\"loadAnnotations()\">\n                <option value=\"\">全部章节</option>\n            </select>\n            \n            <button onclick=\"loadAnnotations()\" class=\"btn-primary\">刷新</button>\n        </div>\n        \n        <!-- 批注表格 -->\n        <div class=\"annotation-table-container\">\n            <table>\n                <thead>\n                    <tr>\n                        <th>章节</th>\n                        <th>原文</th>\n                        <th>批注内容</th>\n                        <th>类型</th>\n                        <th>作者</th>\n                        <th>状态</th>\n                        <th>时间</th>\n                        <th>操作</th>\n                    </tr>\n                </thead>\n                <tbody id=\"annotation-tbody\">\n                    <!-- 动态加载 -->\n                </tbody>\n            </table>\n        </div>\n    </div>\n    \n    <!-- 回复模态框 -->\n    <div id=\"reply-modal\" class=\"modal hidden\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <h3>回复批注</h3>\n                <button onclick=\"closeReplyModal()\" class=\"btn-close\">✕</button>\n            </div>\n            <div class=\"modal-body\">\n                <input type=\"hidden\" id=\"reply-annotation-id\">\n                <div class=\"form-group\">\n                    <label>批注内容：</label>\n                    <p id=\"reply-annotation-content\"></p>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"admin-reply\">管理员回复：</label>\n                    <textarea id=\"admin-reply\" rows=\"4\" placeholder=\"请输入回复内容...\"></textarea>\n                </div>\n                <div class=\"form-actions\">\n                    <button onclick=\"closeReplyModal()\" class=\"btn-secondary\">取消</button>\n                    <button onclick=\"submitReply()\" class=\"btn-primary\">提交回复</button>\n                </div>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        const API_BASE = '/abyss/api';\n        let adminToken = '';\n        \n        // 登录\n        document.getElementById('login-form').addEventListener('submit', async (e) => {\n            e.preventDefault();\n            adminToken = document.getElementById('admin-token').value;\n            \n            // 验证token\n            try {\n                const response = await fetch(`${API_BASE}/admin/stats`, {\n                    headers: { 'X-Admin-Token': adminToken }\n                });\n                \n                const result = await response.json();\n                \n                if (result.success) {\n                    document.getElementById('login-screen').classList.add('hidden');\n                    document.getElementById('admin-screen').classList.remove('hidden');\n                    loadChapterFilter();\n                    loadStats();\n                    loadAnnotations();\n                } else {\n                    alert('登录失败：' + result.error);\n                }\n            } catch (error) {\n                console.error('登录失败:', error);\n                alert('登录失败，请检查网络连接');\n            }\n        });\n        \n        // 加载章节筛选器\n        function loadChapterFilter() {\n            const select = document.getElementById('chapter-filter');\n            for (let i = 1; i <= 45; i++) {\n                const option = document.createElement('option');\n                option.value = i;\n                option.textContent = `第${i}章`;\n                select.appendChild(option);\n            }\n        }\n        \n        // 加载统计数据\n        async function loadStats() {\n            try {\n                const response = await fetch(`${API_BASE}/admin/stats`, {\n                    headers: { 'X-Admin-Token': adminToken }\n                });\n                \n                const result = await response.json();\n                \n                if (result.success) {\n                    document.getElementById('total-count').textContent = result.data.total;\n                    document.getElementById('pending-count').textContent = result.data.pending;\n                    document.getElementById('accepted-count').textContent = result.data.accepted;\n                    document.getElementById('rejected-count').textContent = result.data.rejected;\n                }\n            } catch (error) {\n                console.error('加载统计失败:', error);\n            }\n        }\n        \n        // 加载批注列表\n        async function loadAnnotations() {\n            const status = document.getElementById('status-filter').value;\n            const chapter = document.getElementById('chapter-filter').value;\n            \n            let url = `${API_BASE}/admin/annotations?`;\n            if (status) url += `status=${status}&`;\n            if (chapter) url += `chapter=${chapter}`;\n            \n            try {\n                const response = await fetch(url, {\n                    headers: { 'X-Admin-Token': adminToken }\n                });\n                \n                const result = await response.json();\n                \n                if (result.success) {\n                    displayAnnotations(result.data.annotations);\n                    loadStats(); // 更新统计\n                }\n            } catch (error) {\n                console.error('加载批注失败:', error);\n            }\n        }\n        \n        // 显示批注列表\n        function displayAnnotations(annotations) {\n            const tbody = document.getElementById('annotation-tbody');\n            \n            if (annotations.length === 0) {\n                tbody.innerHTML = `\n                    <tr>\n                        <td colspan=\"8\" class=\"empty-state\">\n                            暂无批注数据\n                        </td>\n                    </tr>\n                `;\n                return;\n            }\n            \n            tbody.innerHTML = annotations.map(ann => `\n                <tr>\n                    <td>第${ann.chapter}章</td>\n                    <td class=\"paragraph-preview\" title=\"${escapeHtml(ann.paragraph_text)}\">\n                        ${escapeHtml(ann.paragraph_text)}\n                    </td>\n                    <td class=\"annotation-content-preview\">\n                        ${escapeHtml(ann.content)}\n                    </td>\n                    <td>${getTypeName(ann.type)}</td>\n                    <td>${escapeHtml(ann.author)}</td>\n                    <td>\n                        <span class=\"status-badge ${ann.status}\">\n                            ${getStatusName(ann.status)}\n                        </span>\n                    </td>\n                    <td>${formatDate(ann.created_at)}</td>\n                    <td>\n                        <div class=\"action-buttons\">\n                            <button onclick=\"acceptAnnotation('${ann.id}')\" \n                                    class=\"btn-accept\" ${ann.status === 'accepted' ? 'disabled' : ''}>\n                                采纳\n                            </button>\n                            <button onclick=\"rejectAnnotation('${ann.id}')\"\n                                    class=\"btn-reject\" ${ann.status === 'rejected' ? 'disabled' : ''}>\n                                拒绝\n                            </button>\n                            <button onclick=\"openReplyModal('${ann.id}', '${escapeHtml(ann.content)}')\"\n                                    class=\"btn-reply\">\n                                回复\n                            </button>\n                            <button onclick=\"deleteAnnotation('${ann.id}')\"\n                                    class=\"btn-delete\">\n                                删除\n                            </button>\n                        </div>\n                    </td>\n                </tr>\n            `).join('');\n        }\n        \n        // 采纳批注\n        async function acceptAnnotation(id) {\n            if (!confirm('确定要采纳这条批注吗？')) return;\n            \n            try {\n                const response = await fetch(`${API_BASE}/admin/annotations/${id}`, {\n                    method: 'PATCH',\n                    headers: {\n                        'Content-Type': 'application/json',\n                        'X-Admin-Token': adminToken\n                    },\n                    body: JSON.stringify({ status: 'accepted' })\n                });\n                \n                const result = await response.json();\n                \n                if (result.success) {\n                    loadAnnotations();\n                } else {\n                    alert('操作失败：' + result.error);\n                }\n            } catch (error) {\n                console.error('采纳失败:', error);\n                alert('操作失败');\n            }\n        }\n        \n        // 拒绝批注\n        async function rejectAnnotation(id) {\n            if (!confirm('确定要拒绝这条批注吗？')) return;\n            \n            try {\n                const response = await fetch(`${API_BASE}/admin/annotations/${id}`, {\n                    method: 'PATCH',\n                    headers: {\n                        'Content-Type': 'application/json',\n                        'X-Admin-Token': adminToken\n                    },\n                    body: JSON.stringify({ status: 'rejected' })\n                });\n                \n                const result = await response.json();\n                \n                if (result.success) {\n                    loadAnnotations();\n                } else {\n                    alert('操作失败：' + result.error);\n                }\n            } catch (error) {\n                console.error('拒绝失败:', error);\n                alert('操作失败');\n            }\n        }\n        \n        // 打开回复模态框\n        function openReplyModal(id, content) {\n            document.getElementById('reply-annotation-id').value = id;\n            document.getElementById('reply-annotation-content').textContent = content;\n            document.getElementById('admin-reply').value = '';\n            document.getElementById('reply-modal').classList.remove('hidden');\n        }\n        \n        // 关闭回复模态框\n        function closeReplyModal() {\n            document.getElementById('reply-modal').classList.add('hidden');\n        }\n        \n        // 提交回复\n        async function submitReply() {\n            const id = document.getElementById('reply-annotation-id').value;\n            const reply = document.getElementById('admin-reply').value;\n            \n            if (!reply.trim()) {\n                alert('请输入回复内容');\n                return;\n            }\n            \n            try {\n                const response = await fetch(`${API_BASE}/admin/annotations/${id}`, {\n                    method: 'PATCH',\n                    headers: {\n                        'Content-Type': 'application/json',\n                        'X-Admin-Token': adminToken\n                    },\n                    body: JSON.stringify({\n                        admin_reply: reply,\n                        status: 'accepted',\n                        admin_id: 'admin'\n                    })\n                });\n                \n                const result = await response.json();\n                \n                if (result.success) {\n                    closeReplyModal();\n                    loadAnnotations();\n                } else {\n                    alert('回复失败：' + result.error);\n                }\n            } catch (error) {\n                console.error('回复失败:', error);\n                alert('回复失败');\n            }\n        }\n        \n        // 删除批注\n        async function deleteAnnotation(id) {\n            if (!confirm('确定要删除这条批注吗？此操作不可恢复！')) return;\n            \n            try {\n                const response = await fetch(`${API_BASE}/admin/annotations/${id}`, {\n                    method: 'DELETE',\n                    headers: { 'X-Admin-Token': adminToken }\n                });\n                \n                const result = await response.json();\n                \n                if (result.success) {\n                    loadAnnotations();\n                } else {\n                    alert('删除失败：' + result.error);\n                }\n            } catch (error) {\n                console.error('删除失败:', error);\n                alert('删除失败');\n            }\n        }\n        \n        // 辅助函数\n        function escapeHtml(text) {\n            const div = document.createElement('div');\n            div.textContent = text;\n            return div.innerHTML;\n        }\n        \n        function getTypeName(type) {\n            const names = { comment: '💬 评论', correction: '✏️ 纠错', suggestion: '💡 建议' };\n            return names[type] || type;\n        }\n        \n        function getStatusName(status) {\n            const names = { pending: '待处理', accepted: '已采纳', rejected: '已拒绝' };\n            return names[status] || status;\n        }\n        \n        function formatDate(dateStr) {\n            const date = new Date(dateStr);\n            return date.toLocaleDateString('zh-CN') + ' ' + date.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });\n        }\n    </script>\n</body>\n</html>\n"}],"isError":false,"timestamp":1772099481157}}
