{"type":"message","id":"7604c25b","parentId":"05c58c48","timestamp":"2026-02-26T09:51:40.771Z","message":{"role":"toolResult","toolCallId":"call_7eeb4359972a4c27870aa76e","toolName":"read","content":[{"type":"text","text":"/**\n * 深渊代行者 - 批注系统后端服务器 v2\n * 支持文本选择批注 (startOffset/endOffset)\n */\n\nconst express = require('express');\nconst cors = require('cors');\nconst bodyParser = require('body-parser');\nconst fs = require('fs').promises;\nconst path = require('path');\n\nconst app = express();\nconst PORT = process.env.PORT || 3002;\n\n// 中间件\napp.use(cors());\napp.use(bodyParser.json());\napp.use(bodyParser.urlencoded({ extended: true }));\n\n// 数据文件路径\nconst DATA_DIR = path.join(__dirname, 'data');\nconst ANNOTATIONS_FILE = path.join(DATA_DIR, 'annotations.json');\nconst CHAPTER_STATS_FILE = path.join(DATA_DIR, 'chapter_stats.json');\n\n// 管理员Token\nconst ADMIN_TOKEN = process.env.ADMIN_TOKEN || 'abyss_admin_2026';\n\n// 确保数据目录存在\nasync function ensureDataDir() {\n    try {\n        await fs.mkdir(DATA_DIR, { recursive: true });\n    } catch (error) {\n        // 目录已存在\n    }\n}\n\n/**\n * 读取批注数据\n */\nasync function readAnnotations() {\n    try {\n        const data = await fs.readFile(ANNOTATIONS_FILE, 'utf8');\n        return JSON.parse(data);\n    } catch (error) {\n        return {\n            annotations: [],\n            stats: { total: 0, pending: 0, accepted: 0, rejected: 0 }\n        };\n    }\n}\n\n/**\n * 写入批注数据\n */\nasync function writeAnnotations(data) {\n    await fs.writeFile(ANNOTATIONS_FILE, JSON.stringify(data, null, 2), 'utf8');\n}\n\n/**\n * 更新统计数据\n */\nasync function updateStats() {\n    const annotationData = await readAnnotations();\n    const annotations = annotationData.annotations;\n    \n    const stats = {\n        total: annotations.length,\n        pending: annotations.filter(a => a.status === 'pending').length,\n        accepted: annotations.filter(a => a.status === 'accepted').length,\n        rejected: annotations.filter(a => a.status === 'rejected').length\n    };\n    \n    annotationData.stats = stats;\n    await writeAnnotations(annotationData);\n}\n\n/**\n * 生成唯一ID\n */\nfunction generateId() {\n    const date = new Date();\n    const dateStr = date.toISOString().slice(0, 10).replace(/-/g, '');\n    const random = Math.random().toString(36).substring(2, 6);\n    return `ann_${dateStr}_${random}`;\n}\n\n/**\n * 验证管理员权限\n */\nfunction authenticateAdmin(req, res, next) {\n    const token = req.headers['x-admin-token'] || req.body.admin_token;\n    \n    if (!token || token !== ADMIN_TOKEN) {\n        return res.status(401).json({\n            success: false,\n            error: '未授权访问'\n        });\n    }\n    \n    next();\n}\n\n// ========== 读者端API ==========\n\n/**\n * 获取批注列表\n * GET /api/annotations?chapter=X\n */\napp.get('/api/annotations', async (req, res) => {\n    try {\n        const { chapter } = req.query;\n        const data = await readAnnotations();\n        \n        let annotations = data.annotations;\n        \n        if (chapter) {\n            annotations = annotations.filter(a => a.chapter === parseInt(chapter));\n        }\n        \n        // 只返回公开的批注\n        annotations = annotations.filter(a => a.visibility === 'public' || !a.visibility);\n        \n        // 按时间倒序\n        annotations.sort((a, b) => new Date(b.createdAt || b.created_at) - new Date(a.createdAt || a.created_at));\n        \n        res.json({\n            success: true,\n            data: {\n                annotations,\n                total: annotations.length,\n                stats: data.stats\n            }\n        });\n    } catch (error) {\n        console.error('获取批注失败:', error);\n        res.status(500).json({\n            success: false,\n            error: '服务器错误'\n        });\n    }\n});\n\n/**\n * 创建新批注 (支持新的数据结构)\n * POST /api/annotations\n * \n * 请求体:\n * {\n *   \"chapter\": 1,\n *   \"startOffset\": 100,\n *   \"endOffset\": 120,\n *   \"selectedText\": \"选中的文字\",\n *   \"type\": \"typo|suggestion|question|like\",\n *   \"content\": \"批注内容\",\n *   \"createdAt\": \"2026-02-21T21:00:00Z\"\n * }\n */\napp.post('/api/annotations', async (req, res) => {\n    try {\n        const { \n            chapter, \n            startOffset, \n            endOffset, \n            selectedText, \n            type, \n            content,\n            createdAt,\n            // 兼容旧字段\n            paragraph_id,\n            paragraph_text,\n            visibility,\n            author \n        } = req.body;\n        \n        // 验证必填字段\n        if (!chapter || !type || !content) {\n            return res.status(400).json({\n                success: false,\n                error: '缺少必填字段'\n            });\n        }\n        \n        // 验证内容长度\n        if (content.length > 500) {\n            return res.status(400).json({\n                success: false,\n                error: '批注内容不能超过500字'\n            });\n        }\n        \n        // 验证类型\n        const validTypes = ['typo', 'suggestion', 'question', 'like', 'comment', 'correction'];\n        if (!validTypes.includes(type)) {\n            return res.status(400).json({\n                success: false,\n                error: '无效的批注类型'\n            });\n        }\n        \n        const data = await readAnnotations();\n        \n        const annotation = {\n            id: generateId(),\n            chapter: parseInt(chapter),\n            // 新字段：文本选择范围\n            startOffset: startOffset !== undefined ? parseInt(startOffset) : null,\n            endOffset: endOffset !== undefined ? parseInt(endOffset) : null,\n            selectedText: selectedText || paragraph_text || '',\n            type,\n            content,\n            // 兼容旧字段\n            paragraph_id: paragraph_id || null,\n            paragraph_text: paragraph_text || selectedText || '',\n            visibility: visibility || 'public',\n            status: 'pending',\n            author: author || '匿名读者',\n            createdAt: createdAt || new Date().toISOString(),\n            created_at: new Date().toISOString(),\n            updatedAt: new Date().toISOString(),\n            updated_at: new Date().toISOString()\n        };\n        \n        data.annotations.push(annotation);\n        await writeAnnotations(data);\n        await updateStats();\n        \n        console.log(`[批注] 新批注: 章节${chapter}, 类型:${type}, 内容:${content.substring(0, 30)}...`);\n        \n        res.json({\n            success: true,\n            data: {\n                id: annotation.id,\n                createdAt: annotation.createdAt\n            }\n        });\n    } catch (error) {\n        console.error('创建批注失败:', error);\n        res.status(500).json({\n            success: false,\n            error: '服务器错误'\n        });\n    }\n});\n\n// ========== 管理端API ==========\n\n/**\n * 获取所有批注（包括私有）\n * GET /api/admin/annotations\n */\napp.get('/api/admin/annotations', authenticateAdmin, async (req, res) => {\n    try {\n        const { status, chapter } = req.query;\n        const data = await readAnnotations();\n        \n        let annotations = data.annotations;\n        \n        if (status) {\n            annotations = annotations.filter(a => a.status === status);\n        }\n        \n        if (chapter) {\n            annotations = annotations.filter(a => a.chapter === parseInt(chapter));\n        }\n        \n        // 按时间倒序\n        annotations.sort((a, b) => new Date(b.createdAt || b.created_at) - new Date(a.createdAt || a.created_at));\n        \n        res.json({\n            success: true,\n            data: {\n                annotations,\n                total: annotations.length\n            }\n        });\n    } catch (error) {\n        console.error('获取批注列表失败:', error);\n        res.status(500).json({\n            success: false,\n            error: '服务器错误'\n        });\n    }\n});\n\n/**\n * 更新批注状态\n * PATCH /api/admin/annotations/:id\n */\napp.patch('/api/admin/annotations/:id', authenticateAdmin, async (req, res) => {\n    try {\n        const { id } = req.params;\n        const { status, admin_reply, admin_id } = req.body;\n        \n        const data = await readAnnotations();\n        const annotation = data.annotations.find(a => a.id === id);\n        \n        if (!annotation) {\n            return res.status(404).json({\n                success: false,\n                error: '批注不存在'\n            });\n        }\n        \n        if (status) {\n            annotation.status = status;\n        }\n        \n        if (admin_reply) {\n            annotation.admin_reply = admin_reply;\n            annotation.admin_id = admin_id || 'admin';\n            annotation.replied_at = new Date().toISOString();\n        }\n        \n        annotation.updatedAt = new Date().toISOString();\n        annotation.updated_at = annotation.updatedAt;\n        \n        await writeAnnotations(data);\n        await updateStats();\n        \n        res.json({\n            success: true,\n            data: annotation\n        });\n    } catch (error) {\n        console.error('更新批注失败:', error);\n        res.status(500).json({\n            success: false,\n            error: '服务器错误'\n        });\n    }\n});\n\n/**\n * 删除批注\n * DELETE /api/admin/annotations/:id\n */\napp.delete('/api/admin/annotations/:id', authenticateAdmin, async (req, res) => {\n    try {\n        const { id } = req.params;\n        const data = await readAnnotations();\n        \n        const index = data.annotations.findIndex(a => a.id === id);\n        \n        if (index === -1) {\n            return res.status(404).json({\n                success: false,\n                error: '批注不存在'\n            });\n        }\n        \n        data.annotations.splice(index, 1);\n        \n        await writeAnnotations(data);\n        await updateStats();\n        \n        res.json({\n            success: true,\n            message: '批注已删除'\n        });\n    } catch (error) {\n        console.error('删除批注失败:', 