{"type":"message","id":"5959b52c","parentId":"18263344","timestamp":"2026-03-10T12:05:52.944Z","message":{"role":"toolResult","toolCallId":"call_d78f5229b1604f0a85da6026","toolName":"read","content":[{"type":"text","text":"/**\n * 深渊代行者 - 批注系统后端服务器\n * 提供批注的增删改查API\n */\n\nconst express = require('express');\nconst cors = require('cors');\nconst bodyParser = require('body-parser');\nconst fs = require('fs').promises;\nconst path = require('path');\n\nconst app = express();\nconst PORT = process.env.PORT || 3002;\n\n// 中间件\napp.use(cors());\napp.use(bodyParser.json());\napp.use(bodyParser.urlencoded({ extended: true }));\n\n// 数据文件路径\nconst DATA_DIR = path.join(__dirname, 'data');\nconst ANNOTATIONS_FILE = path.join(DATA_DIR, 'annotations.json');\nconst CHAPTER_STATS_FILE = path.join(DATA_DIR, 'chapter_stats.json');\n\n// 管理员Token（生产环境应使用环境变量）\nconst ADMIN_TOKEN = process.env.ADMIN_TOKEN || 'abyss_admin_2026';\n\n/**\n * 读取批注数据\n */\nasync function readAnnotations() {\n    try {\n        const data = await fs.readFile(ANNOTATIONS_FILE, 'utf8');\n        return JSON.parse(data);\n    } catch (error) {\n        // 文件不存在，返回默认结构\n        return {\n            annotations: [],\n            stats: { total: 0, pending: 0, accepted: 0, rejected: 0 }\n        };\n    }\n}\n\n/**\n * 写入批注数据\n */\nasync function writeAnnotations(data) {\n    await fs.writeFile(ANNOTATIONS_FILE, JSON.stringify(data, null, 2), 'utf8');\n}\n\n/**\n * 读取章节统计\n */\nasync function readChapterStats() {\n    try {\n        const data = await fs.readFile(CHAPTER_STATS_FILE, 'utf8');\n        return JSON.parse(data);\n    } catch (error) {\n        return { chapters: {} };\n    }\n}\n\n/**\n * 写入章节统计\n */\nasync function writeChapterStats(data) {\n    await fs.writeFile(CHAPTER_STATS_FILE, JSON.stringify(data, null, 2), 'utf8');\n}\n\n/**\n * 更新统计数据\n */\nasync function updateStats() {\n    const annotationData = await readAnnotations();\n    const annotations = annotationData.annotations;\n    \n    // 计算总体统计\n    const stats = {\n        total: annotations.length,\n        pending: annotations.filter(a => a.status === 'pending').length,\n        accepted: annotations.filter(a => a.status === 'accepted').length,\n        rejected: annotations.filter(a => a.status === 'rejected').length\n    };\n    \n    annotationData.stats = stats;\n    await writeAnnotations(annotationData);\n    \n    // 计算章节统计\n    const chapterStats = { chapters: {} };\n    annotations.forEach(ann => {\n        const chapter = ann.chapter;\n        if (!chapterStats.chapters[chapter]) {\n            chapterStats.chapters[chapter] = {\n                total: 0,\n                pending: 0,\n                accepted: 0,\n                rejected: 0,\n                last_updated: null\n            };\n        }\n        \n        chapterStats.chapters[chapter].total++;\n        chapterStats.chapters[chapter][ann.status]++;\n        \n        const updatedAt = new Date(ann.updated_at || ann.created_at);\n        const lastUpdated = chapterStats.chapters[chapter].last_updated;\n        if (!lastUpdated || updatedAt > new Date(lastUpdated)) {\n            chapterStats.chapters[chapter].last_updated = ann.updated_at || ann.created_at;\n        }\n    });\n    \n    await writeChapterStats(chapterStats);\n}\n\n/**\n * 生成唯一ID\n */\nfunction generateId() {\n    const date = new Date();\n    const dateStr = date.toISOString().slice(0, 10).replace(/-/g, '');\n    const random = Math.random().toString(36).substring(2, 5);\n    return `ann_${dateStr}_${random}`;\n}\n\n/**\n * 验证管理员权限\n */\nfunction authenticateAdmin(req, res, next) {\n    const token = req.headers['x-admin-token'] || req.body.admin_token;\n    \n    if (!token || token !== ADMIN_TOKEN) {\n        return res.status(401).json({\n            success: false,\n            error: '未授权访问'\n        });\n    }\n    \n    next();\n}\n\n// ========== 读者端API ==========\n\n/**\n * 获取批注列表\n * GET /api/annotations\n */\napp.get('/api/annotations', async (req, res) => {\n    try {\n        const { chapter, visibility, status } = req.query;\n        const data = await readAnnotations();\n        \n        let annotations = data.annotations;\n        \n        // 筛选条件\n        if (chapter) {\n            annotations = annotations.filter(a => a.chapter === chapter);\n        }\n        \n        if (visibility) {\n            annotations = annotations.filter(a => a.visibility === visibility);\n        }\n        \n        if (status) {\n            annotations = annotations.filter(a => a.status === status);\n        }\n        \n        // 只返回公开的批注（除非是自己的）\n        // 这里简化处理，实际应该验证用户身份\n        annotations = annotations.filter(a => a.visibility === 'public');\n        \n        res.json({\n            success: true,\n            data: {\n                annotations,\n                total: annotations.length,\n                stats: data.stats\n            }\n        });\n    } catch (error) {\n        console.error('获取批注失败:', error);\n        res.status(500).json({\n            success: false,\n            error: '服务器错误'\n        });\n    }\n});\n\n/**\n * 创建新批注\n * POST /api/annotations\n */\napp.post('/api/annotations', async (req, res) => {\n    try {\n        const { chapter, paragraph_id, paragraph_text, content, type, visibility, author } = req.body;\n        \n        // 验证必填字段\n        if (!chapter || !paragraph_id || !paragraph_text || !content || !type || !visibility || !author) {\n            return res.status(400).json({\n                success: false,\n                error: '缺少必填字段'\n            });\n        }\n        \n        // 验证内容长度\n        if (content.length > 500) {\n            return res.status(400).json({\n                success: false,\n                error: '批注内容不能超过500字'\n            });\n        }\n        \n        // 验证类型\n        const validTypes = ['comment', 'correction', 'suggestion'];\n        if (!validTypes.includes(type)) {\n            return res.status(400).json({\n                success: false,\n                error: '无效的批注类型'\n            });\n        }\n        \n        // 验证可见性\n        const validVisibilities = ['public', 'private'];\n        if (!validVisibilities.includes(visibility)) {\n            return res.status(400).json({\n                success: false,\n                error: '无效的可见性设置'\n            });\n        }\n        \n        const data = await readAnnotations();\n        \n        // 生成用户ID（实际应用中应该使用浏览器指纹等）\n        const author_id = `user_${Date.now()}_${Math.random().toString(36).substring(2, 7)}`;\n        \n        // 创建批注\n        const annotation = {\n            id: generateId(),\n            chapter,\n            paragraph_id,\n            paragraph_text,\n            content,\n            type,\n            visibility,\n            status: 'accepted',\n            author,\n            author_id,\n            created_at: new Date().toISOString(),\n            updated_at: new Date().toISOString()\n        };\n        \n        data.annotations.push(annotation);\n        await writeAnnotations(data);\n        await updateStats();\n        \n        res.json({\n            success: true,\n            data: {\n                id: annotation.id,\n                created_at: annotation.created_at\n            }\n        });\n    } catch (error) {\n        console.error('创建批注失败:', error);\n        res.status(500).json({\n            success: false,\n            error: '服务器错误'\n        });\n    }\n});\n\n// ========== 管理端API ==========\n\n/**\n * 获取所有批注（包括私有）\n * GET /api/admin/annotations\n */\napp.get('/api/admin/annotations', authenticateAdmin, async (req, res) => {\n    try {\n        const { status, chapter } = req.query;\n        const data = await readAnnotations();\n        \n        let annotations = data.annotations;\n        \n        if (status) {\n            annotations = annotations.filter(a => a.status === status);\n        }\n        \n        if (chapter) {\n            annotations = anno