onst order of orders) {\n    if (order.userId === user.id) { ... }\n  }\n}\n\n// ✅ O(n) with Map\nconst orderMap = new Map(orders.map(o => [o.userId, o]));\nconst results = users.map(u => ({ ...u, order: orderMap.get(u.id) }));\n\\`\\`\\`\n\n### 3. Memory Allocation\n\\`\\`\\`javascript\n// ❌ Multiple iterations\narr.filter(x => x.active).map(x => transform(x)).filter(x => x.value > 0);\n\n// ✅ Single pass\nconst result = [];\nfor (const x of arr) {\n  if (!x.active) continue;\n  const t = transform(x);\n  if (t.value > 0) result.push(t);\n}\n\\`\\`\\``,\n    tags: [\"performance\", \"optimization\", \"n-plus-1\", \"caching\"]\n  },\n  {\n    name: \"Boundary Condition Fixes\",\n    summary: \"Handle edge cases including array bounds, integer overflow, and input validation.\",\n    content: `# Boundary Condition Fixes\n\n## Common Issues\n\n### 1. Array Bounds\n\\`\\`\\`javascript\n// ❌ Off-by-one\nfor (let i = 0; i <= arr.length; i++) { arr[i]; }\n\n// ✅ Fixed\nfor (let i = 0; i < arr.length; i++) { arr[i]; }\n\n// ✅ Safe access\nconst first = arr[0]?.name ?? null;\n\\`\\`\\`\n\n### 2. Null Input\n\\`\\`\\`javascript\n// ❌ No check\nfunction sum(items) {\n  return items.reduce((a, b) => a + b.price, 0);\n}\n\n// ✅ Fixed\nfunction sum(items) {\n  if (!items?.length) return 0;\n  return items.reduce((a, b) => a + (b.price ?? 0), 0);\n}\n\\`\\`\\`\n\n### 3. Integer Overflow\n\\`\\`\\`javascript\n// ❌ Potential overflow\nfunction factorial(n) {\n  return n <= 1 ? 1 : n * factorial(n - 1);\n}\n\n// ✅ Fixed with BigInt\nfunction factorial(n) {\n  return n <= 1n ? 1n : BigInt(n) * factorial(n - 1n);\n}\n\\`\\`\\``,\n    tags: [\"boundary-conditions\", \"edge-cases\", \"validation\", \"testing\"]\n  },\n  {\n    name: \"Async Error Handling\",\n    summary: \"Proper async error handling patterns including Promise rejection and error boundaries.\",\n    content: `# Async Error Handling\n\n## Common Patterns\n\n### 1. Try-Catch with Result Type\n\\`\\`\\`javascript\nasync fu