on\nconst config = {\n  database: process.env.DATABASE_URL,\n  apiKey: process.env.API_KEY,\n  port: process.env.PORT\n};\n\n// ✅ Fixed with validation\nimport { z } from 'zod';\n\nconst ConfigSchema = z.object({\n  database: z.string().url(),\n  apiKey: z.string().min(1),\n  port: z.coerce.number().int().min(1).max(65535).default(3000),\n  nodeEnv: z.enum(['development', 'production', 'test']).default('development')\n});\n\nfunction loadConfig() {\n  try {\n    return ConfigSchema.parse({\n      database: process.env.DATABASE_URL,\n      apiKey: process.env.API_KEY,\n      port: process.env.PORT,\n      nodeEnv: process.env.NODE_ENV\n    });\n  } catch (error) {\n    console.error('Configuration error:', error.errors);\n    process.exit(1);\n  }\n}\n\nconst config = loadConfig();\n\\`\\`\\`\n\n### 2. Type Coercion Issues\n\n\\`\\`\\`javascript\n// ❌ Wrong type\nconst config = {\n  debug: process.env.DEBUG, // String \"true\", not boolean!\n  timeout: process.env.TIMEOUT, // String \"5000\", not number!\n  features: process.env.FEATURES // String, not array!\n};\n\nif (config.debug) {\n  // Always runs because string is truthy\n}\n\n// ✅ Fixed with proper parsing\nconst config = {\n  debug: process.env.DEBUG === 'true',\n  timeout: parseInt(process.env.TIMEOUT ?? '5000', 10),\n  features: (process.env.FEATURES ?? '').split(',').filter(Boolean)\n};\n\n// ✅ Better: Use dotenv + schema\nimport dotenv from 'dotenv';\nimport { z } from 'zod';\n\ndotenv.config();\n\nconst ConfigSchema = z.object({\n  debug: z.coerce.boolean().default(false),\n  timeout: z.coerce.number().default(5000),\n  features: z.string().transform(s => s.split(',').filter(Boolean))\n});\n\\`\\`\\`\n\n### 3. Hardcoded Values\n\n\\`\\`\\`javascript\n// ❌ Hardcoded configuration\nconst config = {\n  apiUrl: 'https://api.production.com',\n  dbHost: 'prod-db.example.com',\n  dbPort: 5432\n};\n\n// ✅ Fixed with environment variables\nconst config = {\n  apiUrl: process.env.API_URL ?? 'https://api.default.c