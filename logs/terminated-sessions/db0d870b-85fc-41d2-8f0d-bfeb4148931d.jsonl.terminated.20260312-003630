ference\n  };\n}\n\n// ✅ Fixed - extract only needed data\nfunction createHandler() {\n  const length = 1000000;\n  return function() {\n    console.log(length);\n  };\n}\n\\`\\`\\`\n\n### 3. Caching Without Limits\n\\`\\`\\`javascript\n// ❌ Unlimited cache\nconst cache = {};\nfunction getData(key) {\n  if (!cache[key]) {\n    cache[key] = fetchData(key);\n  }\n  return cache[key];\n}\n\n// ✅ Fixed with LRU cache\nimport LRU from 'lru-cache';\nconst cache = new LRU({ max: 500, maxAge: 1000 * 60 * 60 });\n\\`\\`\\`\n\n### 4. Detached DOM Nodes\n\\`\\`\\`javascript\n// ❌ Detached node reference\nlet detachedNode;\nfunction removeElement() {\n  detachedNode = document.getElementById('element');\n  detachedNode.remove(); // Still referenced\n}\n\n// ✅ Fixed - nullify reference\nfunction removeElement() {\n  const node = document.getElementById('element');\n  node.remove();\n  node = null;\n}\n\\`\\`\\`\n\n## Detection Tools\n\n1. **Chrome DevTools Memory Panel**\n   - Take heap snapshots\n   - Compare snapshots before/after operations\n   - Look for detached DOM trees\n\n2. **Node.js --inspect flag**\n   - Connect Chrome DevTools to Node.js\n   - Use Memory panel for analysis\n\n3. **heapdump module**\n   \\`\\`\\`javascript\n   const heapdump = require('heapdump');\n   heapdump.writeSnapshot('/tmp/heap-' + Date.now() + '.heapsnapshot');\n   \\`\\`\\`\n\n## Best Practices\n\n- Always clean up event listeners\n- Use WeakMap/WeakSet for object references\n- Implement cache limits (LRU, TTL)\n- Nullify references when done\n- Profile memory in production regularly\n- Use streaming for large data processing`,\n    tags: [\"memory-leak\", \"debugging\", \"performance\", \"nodejs\", \"javascript\"],\n    confidence: 1\n  },\n  {\n    name: \"Null Pointer Exception Prevention Patterns\",\n    summary: \"Defensive programming patterns to prevent null/undefined errors with optional chaining, nullish coalescing, and type guards.\",\n    content: `# Null Pointer Exception Prevention Patterns\n\n## Modern JavaScript Solutions\n\n### 1. Optional Chaining (?.)\n\\`\\`\\`javascript\n// ❌ Unsafe access\nconst street = user.address.street.name;\n\n// ✅ Safe access with optional chaining\nconst street = user?.address?.street?.name;\n\\`\\`\\`\n\n### 2. Nullish Coalescing (??)\n\\`\\`\\`javascript\n// ❌ Problematic fallback\nconst name = user.name || 'Anonymous'; // Falsy values overwritten\n\n// ✅ Proper nullish coalescing\nconst name = user.name ?? 'Anonymous'; // Only null/undefined replaced\n\\`\\`\\`\n\n### 3. Combined Pattern\n\\`\\`\\`javascript\nconst config = {\n  api: {\n    endpoint: settings?.api?.endpoint ?? 'https://api.default.com',\n    timeout: settings?.api?.timeout ?? 5000,\n    retries: settings?.api?.retries ?? 3\n  }\n};\n\\`\\`\\`\n\n### 4. Array Safety\n\\`\\`\\`javascript\n// ❌ Unsafe array access\nconst firstItem = items[0].name;\n\n// ✅ Safe array access\nconst firstItem = items?.[0]?.name;\nconst firstItem = items.at(0)?.name; // Using at() method\n\\`\\`\\`\n\n### 5. Function Argument Defaults\n\\`\\`\\`javascript\n// ❌ Manual checks\nfunction greet(name) {\n  if (name === undefined || name === null) {\n    name = 'Guest';\n  }\n  return 'Hello ' + name;\n}\n\n// ✅ Default parameters\nfunction greet(name = 'Guest') {\n  return \\`Hello \\${name}\\`;\n}\n\\`\\`\\`\n\n### 6. Object Destructuring with Defaults\n\\`\\`\\`javascript\n// ❌ Unsafe destructuring\nconst { address: { city } } = user;\n\n// ✅ Safe destructuring\nconst { address: { city = 'Unknown' } = {} } = user || {};\n\\`\\`\\`\n\n### 7. Type Guards (TypeScript)\n\\`\\`\\`typescript\nfunction isUser(obj: unknown): obj is User {\n  return typeof obj === 'object' && obj !== null && 'id' in obj;\n}\n\nfunction processUser(data: unknown) {\n  if (isUser(data)) {\n    console.log(data.name); // Safe access\n  }\n}\n\\`\\`\\`\n\n### 8. Assertion Functions\n\\`\\`\\`typescript\nfunction assertDefined<T>(value: T | null | undefined, message: string): asserts value is T {\n  if (value === null || value === undefined) {\n    throw new Error(message);\n  }\n}\n\nconst input = getInput();\nassertDefined(input, 'Input is required');\n// Now TypeScript knows input is defined\n\\`\\`\\`\n\n## React/Component Patterns\n\n\\`\\`\\`jsx\n// ❌ Unsafe render\nfunction UserCard({ user }) {\n  return <div>{user.profile.avatar.url}</div>;\n}\n\n// ✅ Safe render\nfunction UserCard({ user }) {\n  return (\n    <div>\n      <img src={user?.profile?.avatar?.url ?? '/default-avatar.png'} />\n    </div>\n  );\n}\n\\`\\`\\`\n\n## Best Practices Checklist\n\n- [ ] Use optional chaining for nested property access\n- [ ] Use nullish coalescing for default values\n- [ ] Provide default parameters for functions\n- [ ] Use type guards in TypeScript\n- [ ] Validate external data at boundaries\n- [ ] Add null checks at API boundaries\n- [ ] Use strict mode in JavaScript\n- [ ] Enable TypeScript strictNullChecks`,\n    tags: [\"null-pointer\", \"defensive-programming\", \"javascript\", \"typescript\", \"error-prevention\"],\n    confidence: 1\n  },\n  {\n    name: \"Race Condition Detection and Fixes\",\n    summary: \"Identify and fix race conditions in async code using mutexes, proper async patterns, and atomic operations.\",\n    content: `# Race Condition Detection and Fixes\n\n## What is a Race Condition?\n\nA race condition occurs when multiple operations access shared data concurrently, and the final result depends on the order of execution.\n\n## Common Race Condition Patterns\n\n### 1. Multiple Async Updates\n\\`\\`\\`javascript\n// ❌ Race condition\nlet counter = 0;\nasync function increment() {\n  const current = counter;\n  await someAsyncOperation();\n  counter = current + 1; // Lost updates!\n}\n\n// ✅ Fixed with atomic update\nlet counter = 0;\nasync function increment() {\n  await someAsyncOperation();\n  counter++; // Atomic in JS single thread\n}\n\n// ✅ Better: use functional update\nsetState(prev => prev + 1);\n\\`\\`\\`\n\n### 2. Stale Closure Problem\n\\`\\`\\`javascript\n// ❌ Stale closure in async\nfunction Component() {\n  const [count, setCount] = useState(0);\n  \n  useEffect(() => {\n    const interval = setInterval(() => {\n      console.log(count); // Always logs 0!\n    }, 1000);\n    return () => clearInterval(interval);\n  }, []);\n}\n\n// ✅ Fixed with ref or dependency\nfunction Component() {\n  const [count, setCount] = useState(0);\n  const countRef = useRef(count);\n  countRef.current = count;\n  \n  useEffect(() => {\n    const interval = setInterval(() => {\n      console.log(countRef.current);\n    }, 1000);\n    return () => clearInterval(interval);\n  }, []);\n}\n\\`\\`\\`\n\n### 3. Promise Race Conditions\n\\`\\`\\`javascript\n// ❌ Multiple requests race\nlet latestData = null;\nsearchInput.addEventListener('input', async (e) => {\n  const results = await fetchResults(e.target.value);\n  latestData = results; // May overwrite newer results!\n  render(results);\n});\n\n// ✅ Fixed with abort controller\nlet abortController = null;\nsearchInput.addEventListener('input', async (e) => {\n  if (abortController) {\n    abortController.abort();\n  }\n  abortController = new AbortController();\n  \n  try {\n    const results = await fetchResults(e.target.value, {\n      signal: abortController.signal\n    });\n    render(results);\n  } catch (err) {\n    if (err.name !== 'AbortError') throw err;\n  }\n});\n\\`\\`\\`\n\n### 4. Database Race Conditions\n\\`\\`\\`javascript\n// ❌ Check-then-act pattern\nasync function transferMoney(from, to, amount) {\n  const balance = await getBalance(from);\n  if (balance < amount) throw new Error('Insufficient');\n  await deduct(from, amount);\n  await credit(to, amount); // Crash here = lost money!\n}\n\n// ✅ Fixed with transaction\nasync function transferMoney(from, to, amount) {\n  await db.transaction(async (trx) => {\n    const balance = await getBalance(from, trx);\n    if (balance < amount) throw new Error('Insufficient');\n    await deduct(from, amount, trx);\n    await credit(to, amount, trx);\n  });\n}\n\\`\\`\\`\n\n## Mutex/Semaphore Pattern\n\n\\`\\`\\`javascript\nclass Mutex {\n  constructor() {\n    this.queue = [];\n    this.locked = false;\n  }\n  \n  async lock() {\n    if (!this.locked) {\n      this.locked = true;\n      return;\n    }\n    await new Promise(resolve => this.queue.push(resolve));\n  }\n  \n  unlock() {\n    const next = this.queue.shift();\n    if (next) {\n      next();\n    } else {\n      this.locked = false;\n    }\n  }\n}\n\n// Usage\nconst mutex = new Mutex();\nasync function safeOperation() {\n  await mutex.lock();\n  try {\n    await criticalSection();\n  } finally {\n    mutex.unlock();\n  }\n}\n\\`\\`\\`\n\n## React Query / SWR Pattern\n\n\\`\\`\\`javascript\n// ✅ Using React Query for race-free data fetching\nimport { useQuery } from '@tanstack/react-query';\n\nfunction SearchResults({ query }) {\n  const { data, isLoading, error } = useQuery({\n    queryKey: ['search', query],\n    queryFn: () => fetchResults(query),\n    enabled: !!query,\n    staleTime: 5000,\n  });\n  \n  if (isLoading) return <Spinner />;\n  if (error) return <Error />;\n  return <Results data={data} />;\n}\n\\`\\`\\`\n\n## Detection Strategies\n\n1. **Code Review**: Look for shared mutable state\n2. **Testing**: Run tests with random delays\n3. **Logging**: Add timestamps to concurrent operations\n4. **Static Analysis**: Use TypeScript + strict mode\n5. **Concurrency Testing**: Use tools like concurrently\n\n## Best Practices\n\n- Prefer immutability over mutation\n- Use atomic operations when possible\n- Implement proper cancellation\n- Use transactions for database operations\n- Consider message passing instead of shared state\n- Test with simulated delays and failures`,\n    tags: [\"race-condition\", \"async\", \"concurrency\", \"debugging\", \"javascript\"],\n    confidence: 1\n  },\n  {\n    name: \"SQL Injection Prevention Patterns\",\n    summary: \"Prevent SQL injection with parameterized queries, ORM best practices, input validation, and least privilege database access.\",\n    content: `# SQL Injection Prevention Patterns\n\n## Understanding SQL Injection\n\nSQL injection occurs when user input is directly concatenated into SQL queries, allowing attackers to manipulate the query logic.\n\n## Attack Examples\n\n\\`\\`\\`sql\n-- Input: ' OR '1'='1\nSELECT * FROM users WHERE username = '' OR '1'='1' -- Returns all users!\n\n-- Input: '; DROP TABLE users; --\nSELECT * FROM users WHERE username = ''; DROP TABLE users; --'\n\\`\\`\\`\n\n## Prevention Strategies\n\n### 1. Parameterized Queries (Primary Defense)\n\n\\`\\`\\`javascript\n// ❌ Vulnerable code\nconst query = \\`SELECT * FROM users WHERE username = '\\${username}'\\`;\nawait db.query(query);\n\n// ✅ Parameterized query (Node.js + pg)\nconst query = 'SELECT * FROM users WHERE username = $1';\nawait db.query(query, [username]);\n\n// ✅ Parameterized query (Node.js + mysql2)\nconst query = 'SELECT * FROM users WHERE username = ?';\nawait db.query(query, [username]);\n\n// ✅ Named parameters (Prisma)\nawait prisma.users.findMany({\n  where: { username: username }\n});\n\\`\\`\\`\n\n### 2. ORM Best Practices\n\n\\`\\`\\`javascript\n// ✅ Prisma (safe by default)\nconst user = await prisma.user.findFirst({\n  where: {\n    email: userInput,\n    status: 'active'\n  }\n});\n\n// ✅ TypeORM (safe with query builder)\nconst user = await userRepository\n  .createQueryBuilder('user')\n  .where('user.email = :email', { email: userInput })\n  .getOne();\n\n// ❌ TypeORM raw query (dangerous!)\nconst user = await userRepository.query(\n  \\`SELECT * FROM users WHERE email = '\\${userInput}'\\`\n);\n\\`\\`\\`\n\n### 3. Input Validation\n\n\\`\\`\\`javascript\nimport { z } from 'zod';\n\n// Define schema\nconst UserSchema = z.object({\n  email: z.string().email(),\n  username: z.string().min(3).max(50).regex(/^[a-zA-Z0-9_]+$/),\n  age: z.number().int().min(0).max(150)\n});\n\n// Validate before query\nfunction validateInput(data) {\n  try {\n    return UserSchema.parse(data);\n  } catch (err) {\n    throw new Error('Invalid input');\n  }\n}\n\n// Usage\nconst validated = validateInput(req.body);\nconst user = await createUser(validated);\n\\`\\`\\`\n\n### 4. Least Privilege Principle\n\n\\`\\`\\`sql\n-- ❌ Application uses root/admin\nGRANT ALL PRIVILEGES ON *.* TO 'app_user'@'localhost';\n\n-- ✅ Minimal permissions\nGRANT SELECT, INSERT, UPDATE ON mydb.users TO 'app_user'@'localhost';\nGRANT SELECT ON mydb.public_data TO 'app_readonly'@'localhost';\n\\`\\`\\`\n\n### 5. Stored Procedures (Additional Layer)\n\n\\`\\`\\`sql\n-- Create stored procedure\nCREATE PROCEDURE GetUserByEmail(IN user_email VARCHAR(255))\nBEGIN\n  SELECT * FROM users WHERE email = user_email;\nEND;\n\n-- Call from application\nawait db.query('CALL GetUserByEmail(?)', [email]);\n\\`\\`\\`\n\n### 6. Escaping (Last Resort)\n\n\\`\\`\\`javascript\n// Only use if parameterized queries not available\nimport mysql from 'mysql2';\n\nconst escaped = mysql.escape(userInput);\nconst query = \\`SELECT * FROM users WHERE username = \\${escaped}\\`;\n\\`\\`\\`\n\n## ORM-Specific Patterns\n\n### Prisma\n\\`\\`\\`javascript\n// ✅ Safe: Prisma parameterizes automatically\nawait prisma.user.create({\n  data: { name: userInput }\n});\n\n// ⚠️ Caution: Raw queries need $queryRaw\nawait prisma.$queryRaw\\`SELECT * FROM users WHERE id = \\${id}\\`;\n\\`\\`\\`\n\n### TypeORM\n\\`\\`\\`javascript\n// ✅ Safe: QueryBuilder with parameters\nawait dataSource\n  .createQueryBuilder()\n  .select('*')\n  .from(User, 'user')\n  .where('user.email = :email', { email })\n  .execute();\n\\`\\`\\`\n\n### Sequelize\n\\`\\`\\`javascript\n// ✅ Safe: Sequelize methods\nawait User.findOne({ where: { email: userInput } });\n\n// ⚠️ Caution: Raw queries\nawait sequelize.query(\n  'SELECT * FROM users WHERE email = ?',\n  { replacements: [userInput], type: QueryTypes.SELECT }\n);\n\\`\\`\\`\n\n## Testing for SQL Injection\n\n\\`\\`\\`javascript\ndescribe('SQL Injection Prevention', () => {\n  const maliciousInputs = [\n    \"' OR '1'='1\",\n    \"'; DROP TABLE users; --\",\n    \"' UNION SELECT * FROM passwords --\",\n    \"admin'--\",\n    \"' OR 1=1 --\"\n  ];\n  \n  maliciousInputs.forEach(input => {\n    it(\\`should handle malicious input: \\${input.slice(0, 20)}\\`, async () => {\n      const result = await findUser(input);\n      expect(result).toBeNull(); // Should not return all users\n    });\n  });\n});\n\\`\\`\\`\n\n## Checklist\n\n- [ ] All queries use parameterized statements\n- [ ] No string concatenation in SQL\n- [ ] Input validated with schema\n- [ ] Database user has minimal privileges\n- [ ] Error messages don't expose SQL\n- [ ] Regular security audits\n- [ ] Automated SQL injection testing`,\n    tags: [\"sql-injection\", \"security\", \"database\", \"parameterized-queries\", \"orm\"],\n    confidence: 1\n  },\n  {\n    name: \"XSS Prevention and Content Security Policy\",\n    summary: \"Comprehensive XSS prevention with output encoding, CSP headers, sanitization libraries, and React/Vue auto-escaping.\",\n    content: `# XSS Prevention and Content Security Policy\n\n## Understanding XSS\n\nCross-Site Scripting (XSS) allows attackers to inject malicious scripts into web pages viewed by other users.\n\n## Types of XSS\n\n1. **Reflected XSS**: Script from URL/request reflected in response\n2. **Stored XSS**: Script stored in database, served to all users\n3. **DOM-based XSS**: Script injected via DOM manipulation\n\n## Prevention Strategies\n\n### 1. Output Encoding\n\n\\`\\`\\`javascript\n// ❌ Vulnerable: Direct HTML insertion\nelement.innerHTML = userInput;\n\n// ✅ Safe: Text content\nelement.textContent = userInput;\n\n// ✅ Safe: Use encoding library\nimport { escape } from 'lodash';\nelement.innerHTML = escape(userInput);\n\n// ✅ Safe: DOMPurify for HTML content\nimport DOMPurify from 'dompurify';\nelement.innerHTML = DOMPurify.sanitize(userInput);\n\\`\\`\\`\n\n### 2. Content Security Policy (CSP)\n\n\\`\\`\\`javascript\n// Express.js CSP middleware\nimport helmet from 'helmet';\n\napp.use(helmet.contentSecurityPolicy({\n  directives: {\n    defaultSrc: [\"'self'\"],\n    scriptSrc: [\"'self'\", \"https://trusted.cdn.com\"],\n    styleSrc: [\"'self'\", \"'unsafe-inline'\"],\n    imgSrc: [\"'self'\", \"data:\", \"https:\"],\n    connectSrc: [\"'self'\", \"https://api.example.com\"],\n    fontSrc: [\"'self'\", \"https://fonts.gstatic.com\"],\n    objectSrc: [\"'none'\"],\n    frameSrc: [\"'none'\"],\n    baseUri: [\"'self'\"],\n    formAction: [\"'self'\"],\n    frameAncestors: [\"'none'\"],\n    upgradeInsecureRequests: [],\n  },\n}));\n\n// Report-only mode (testing)\napp.use(helmet.contentSecurityPolicy({\n  useDefaults: false,\n  directives: {\n    defaultSrc: [\"'self'\"],\n    reportUri: ['/csp-report'],\n  },\n  reportOnly: true,\n}));\n\\`\\`\\`\n\n### 3. React Auto-Escaping\n\n\\`\\`\\`jsx\n// ✅ React escapes by default\nfunction SafeComponent({ userInput }) {\n  return <div>{userInput}</div>; // Automatically escaped\n}\n\n// ❌ Dangerous: dangerouslySetInnerHTML\nfunction UnsafeComponent({ html }) {\n  return <div dangerouslySetInnerHTML={{ __html: html }} />;\n}\n\n// ✅ Safe with sanitization\nfunction SafeHtmlComponent({ html }) {\n  const sanitized = DOMPurify.sanitize(html);\n  return <div dangerouslySetInnerHTML={{ __html: sanitized }} />;\n}\n\\`\\`\\`\n\n### 4. Vue.js Auto-Escaping\n\n\\`\\`\\`vue\n<template>\n  <!-- ✅ Safe: Auto-escaped -->\n  <div>{{ userInput }}</div>\n  \n  <!-- ❌ Dangerous: v-html -->\n  <div v-html=\"userInput\"></div>\n  \n  <!-- ✅ Safe with sanitization -->\n  <div v-html=\"sanitizedHtml\"></div>\n</template>\n\n<script>\nimport DOMPurify from 'dompurify';\n\nexport default {\n  computed: {\n    sanitizedHtml() {\n      return DOMPurify.sanitize(this.userInput);\n    }\n  }\n}\n</script>\n\\`\\`\\`\n\n### 5. URL Validation\n\n\\`\\`\\`javascript\n// ❌ Dangerous: Direct redirect\napp.get('/redirect', (req, res) => {\n  res.redirect(req.query.url); // Open redirect!\n});\n\n// ✅ Safe: Validate URL\nfunction isSafeRedirect(url) {\n  try {\n    const parsed = new URL(url, 'https://example.com');\n    return parsed.origin === 'https://example.com';\n  } catch {\n    return false;\n  }\n}\n\napp.get('/redirect', (req, res) => {\n  if (isSafeRedirect(req.query.url)) {\n    res.redirect(req.query.url);\n  } else {\n    res.status(400).send('Invalid redirect URL');\n  }\n});\n\\`\\`\\`\n\n### 6. Cookie Security\n\n\\`\\`\\`javascript\n// ❌ Insecure cookies\nres.cookie('session', token);\n\n// ✅ Secure cookies\nres.cookie('session', token, {\n  httpOnly: true,    // Not accessible via JavaScript\n  secure: true,      // Only over HTTPS\n  sameSite: 'strict', // CSRF protection\n  maxAge: 3600000,\n  path: '/',\n  domain: 'example.com'\n});\n\\`\\`\\`\n\n## DOMPurify Configuration\n\n\\`\\`\\`javascript\nimport DOMPurify from 'dompurify';\n\n// Strict configuration\nconst clean = DOMPurify.sanitize(dirty, {\n  ALLOWED_TAGS: ['p', 'b', 'i', 'em', 'strong', 'a'],\n  ALLOWED_ATTR: ['href'],\n  ALLOW_DATA_ATTR: false,\n  FORBID_TAGS: ['script', 'style', 'iframe', 'object'],\n  FORBID_ATTR: ['onerror', 'onload', 'onclick'],\n});\n\n// Allow specific data attributes\nconst clean = DOMPurify.sanitize(dirty, {\n  ADD_ATTR: ['data-id', 'data-type'],\n});\n\\`\\`\\`\n\n## CSP Reporting\n\n\\`\\`\\`javascript\n// CSP violation report endpoint\napp.post('/csp-report', express.json({ type: 'application/csp-report' }), (req, res) => {\n  console.log('CSP Violation:', req.body);\n  // Log to monitoring service\n  res.status(204).end();\n});\n\\`\\`\\`\n\n## Testing for XSS\n\n\\`\\`\\`javascript\nconst xssPayloads = [\n  '<script>alert(1)</script>',\n  '<img src=x onerror=alert(1)>',\n  '\"><script>alert(1)</script>',\n  \"javascript:alert(1)\",\n  '<svg onload=alert(1)>',\n];\n\nxssPayloads.forEach(payload => {\n  it(\\`should sanitize: \\${payload.slice(0, 30)}\\`, () => {\n    const sanitized = DOMPurify.sanitize(payload);\n    expect(sanitized).not.toContain('alert');\n    expect(sanitized).not.toContain('<script>');\n  });\n});\n\\`\\`\\`\n\n## Checklist\n\n- [ ] All user input encoded before display\n- [ ] CSP headers configured\n- [ ] No use of innerHTML without sanitization\n- [ ] Cookies use httpOnly and secure flags\n- [ ] URL redirects validated\n- [ ] Regular XSS testing with automated tools\n- [ ] Security headers audit (use securityheaders.com)`,\n    tags: [\"xss\", \"security\", \"csp\", \"sanitization\", \"web-security\"],\n    confidence: 1\n  },\n  {\n    name: \"Deadlock Detection and Resolution\",\n    summary: \"Identify and fix deadlocks with proper lock ordering, timeout strategies, and deadlock detection algorithms.\",\n    content: `# Deadlock Detection and Resolution\n\n## Understanding Deadlocks\n\nA deadlock occurs when two or more processes are waiting for each other's resources, creating a circular dependency.\n\n## Deadlock Conditions (All Must Be Present)\n\n1. **Mutual Exclusion**: Resources cannot be shared\n2. **Hold and Wait**: Process holds resource while waiting for another\n3. **No Preemption**: Resources cannot be forcibly taken\n4. **Circular Wait**: Circular chain of waiting processes\n\n## Common Deadlock Patterns\n\n### 1. Database Deadlocks\n\n\\`\\`\\`javascript\n// ❌ Deadlock-prone: Different lock orders\nasync function transferMoney(fromId, toId, amount) {\n  const fromAccount = await getAccountWithLock(fromId);\n  const toAccount = await getAccountWithLock(toId);\n  // If A→B and B→A happen simultaneously, deadlock!\n}\n\n// ✅ Fixed: Consistent lock ordering\nasync function transferMoney(fromId, toId, amount) {\n  // Always lock in consistent order (by ID)\n  const [first, second] = [fromId, toId].sort();\n  const firstAccount = await getAccountWithLock(first);\n  const secondAccount = await getAccountWithLock(second);\n  \n  if (first === fromId) {\n    await deduct(firstAccount, amount);\n    await credit(secondAccount, amount);\n  } else {\n    await credit(firstAccount, amount);\n    await deduct(secondAccount, amount);\n  }\n}\n\\`\\`\\`\n\n### 2. Async/Await Deadlocks\n\n\\`\\`\\`javascript\n// ❌ Potential deadlock: Nested async with same mutex\nconst mutex = new Mutex();\n\nasync function processA() {\n  await mutex.lock();\n  await processB(); // If B also needs mutex, deadlock!\n  mutex.unlock();\n}\n\nasync function processB() {\n  await mutex.lock();\n  // Do work\n  mutex.unlock();\n}\n\n// ✅ Fixed: Reentrant mutex or avoid nested locks\nclass ReentrantMutex {\n  constructor() {\n    this.owner = null;\n    this.count = 0;\n    this.queue = [];\n  }\n  \n  async lock() {\n    const currentId = asyncLocalStorage.getStore();\n    if (this.owner === currentId) {\n      this.count++;\n      return;\n    }\n    // ... standard lock logic\n  }\n}\n\\`\\`\\`\n\n### 3. Promise Deadlocks\n\n\\`\\`\\`javascript\n// ❌ Deadlock: Circular promise dependencies\nconst p1 = p2.then(() => doSomething());\nconst p2 = p1.then(() => doSomethingElse()); // Circular!\n\n// ✅ Fixed: Break the cycle\nlet p1Resolve;\nconst p1 = new Promise(resolve => { p1Resolve = resolve; });\nconst p2 = p1.then(() => doSomething());\np2.then(() => doSomethingElse()).then(p1Resolve);\n\\`\\`\\`\n\n## Prevention Strategies\n\n### 1. Lock Ordering\n\n\\`\\`\\`javascript\n// Global ordering for all resources\nconst RESOURCE_ORDER = {\n  DATABASE: 1,\n  FILE_SYSTEM: 2,\n  NETWORK: 3,\n  CACHE: 4,\n};\n\nasync function acquireResources(resources) {\n  // Sort by global order\n  const sorted = resources.sort((a, b) => \n    RESOURCE_ORDER[a.type] - RESOURCE_ORDER[b.type]\n  );\n  \n  for (const resource of sorted) {\n    await acquire(resource);\n  }\n}\n\\`\\`\\`\n\n### 2. Lock Timeout\n\n\\`\\`\\`javascript\nasync function lockWithTimeout(mutex, timeoutMs = 5000) {\n  return Promise.race([\n    mutex.lock(),\n    new Promise((_, reject) => \n      setTimeout(() => reject(new Error('Lock timeout')), timeoutMs)\n    )\n  ]);\n}\n\n// Usage\ntry {\n  await lockWithTimeout(mutex, 5000);\n  // Critical section\n} catch (err) {\n  if (err.message === 'Lock timeout') {\n    // Handle deadlock possibility\n    await rollback();\n  }\n  throw err;\n} finally {\n  mutex.unlock();\n}\n\\`\\`\\`\n\n### 3. Try-Lock Pattern\n\n\\`\\`\\`javascript\nclass Mutex {\n  tryLock() {\n    if (!this.locked) {\n      this.locked = true;\n      return true;\n    }\n    return false;\n  }\n}\n\nasync function safeOperation(mutex) {\n  if (mutex.tryLock()) {\n    try {\n      await criticalSection();\n    } finally {\n      mutex.unlock();\n    }\n  } else {\n    // Handle contention\n    await alternativePath();\n  }\n}\n\\`\\`\\`\n\n### 4. Two-Phase Locking with Timeout\n\n\\`\\`\\`javascript\nasync function transferWithRetry(fromId, toId, amount, maxRetries = 3) {\n  for (let attempt = 0; attempt < maxRetries; attempt++) {\n    try {\n      return await db.transaction(async (trx) => {\n        const [from, to] = await Promise.all([\n          trx.select('*').from('accounts').where('id', fromId).forUpdate().timeout(5000),\n          trx.select('*').from('accounts').where('id', toId).forUpdate().timeout(5000)\n        ]);\n        \n        if (from.balance < amount) throw new Error('Insufficient funds');\n        \n        await Promise.all([\n          trx('accounts').where('id', fromId).decrement('balance', amount),\n          trx('accounts').where('id', toId).increment('balance', amount)\n        ]);\n      });\n    } catch (err) {\n      if (err.code === 'LOCK_DEADLOCK' && attempt < maxRetries - 1) {\n        await sleep(100 * Math.pow(2, attempt)); // Exponential backoff\n        continue;\n      }\n      throw err;\n    }\n  }\n}\n\\`\\`\\`\n\n## Detection Strategies\n\n### 1. Wait-for Graph\n\n\\`\\`\\`javascript\nclass DeadlockDetector {\n  constructor() {\n    this.waitForGraph = new Map(); // process -> set of processes it's waiting for\n  }\n  \n  addEdge(waiter, resource) {\n    if (!this.waitForGraph.has(waiter)) {\n      this.waitForGraph.set(waiter, new Set());\n    }\n    this.waitForGraph.get(waiter).add(resource);\n  }\n  \n  detectCycle() {\n    const visited = new Set();\n    const recursionStack = new Set();\n    \n    for (const [node] of this.waitForGraph) {\n      if (this.detectCycleDFS(node, visited, recursionStack)) {\n        return true;\n      }\n    }\n    return false;\n  }\n  \n  detectCycleDFS(node, visited, recursionStack) {\n    if (recursionStack.has(node)) return true;\n    if (visited.has(node)) return false;\n    \n    visited.add(node);\n    recursionStack.add(node);\n    \n    const neighbors = this.waitForGraph.get(node) || new Set();\n    for (const neighbor of neighbors) {\n      if (this.detectCycleDFS(neighbor, visited, recursionStack)) {\n        return true;\n      }\n    }\n    \n    recursionStack.delete(node);\n    return false;\n  }\n}\n\\`\\`\\`\n\n### 2. Database Deadlock Logging\n\n\\`\\`\\`sql\n-- MySQL: Enable deadlock logging\nSET GLOBAL innodb_print_all_deadlocks = ON;\n\n-- PostgreSQL: View recent deadlocks\nSELECT * FROM pg_stat_activity \nWHERE wait_event_type = 'Lock';\n\\`\\`\\`\n\n## Checklist\n\n- [ ] All locks acquired in consistent order\n- [ ] Timeouts configured for all lock operations\n- [ ] Retry logic for deadlock recovery\n- [ ] No circular dependencies in code\n- [ ] Database transactions minimized\n- [ ] Monitoring for deadlock events\n- [ ] Regular deadlock analysis in production`,\n    tags: [\"deadlock\", \"concurrency\", \"database\", \"async\", \"debugging\"],\n    confidence: 1\n  },\n  {\n    name: \"Performance Bottleneck Fixes\",\n    summary: \"Identify and fix performance bottlenecks including N+1 queries, inefficient loops, memory allocation issues, and caching strategies.\",\n    content: `# Performance Bottleneck Fixes\n\n## Common Performance Issues\n\n### 1. N+1 Query Problem\n\n\\`\\`\\`javascript\n// ❌ N+1 queries: 1 for users + N for profiles\nco