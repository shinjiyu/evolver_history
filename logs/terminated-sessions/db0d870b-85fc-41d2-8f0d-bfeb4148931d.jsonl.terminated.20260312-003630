e: Text content\nelement.textContent = userInput;\n\n// ✅ Safe: DOMPurify for HTML content\nimport DOMPurify from 'dompurify';\nelement.innerHTML = DOMPurify.sanitize(userInput);\n\\`\\`\\`\n\n### 2. Content Security Policy (CSP)\n\n\\`\\`\\`javascript\n// Express.js CSP middleware\nimport helmet from 'helmet';\n\napp.use(helmet.contentSecurityPolicy({\n  directives: {\n    defaultSrc: [\"'self'\"],\n    scriptSrc: [\"'self'\", \"https://trusted.cdn.com\"],\n    styleSrc: [\"'self'\", \"'unsafe-inline'\"],\n    imgSrc: [\"'self'\", \"data:\", \"https:\"],\n    connectSrc: [\"'self'\", \"https://api.example.com\"],\n    objectSrc: [\"'none'\"],\n    frameSrc: [\"'none'\"],\n  },\n}));\n\\`\\`\\`\n\n### 3. React Auto-Escaping\n\n\\`\\`\\`jsx\n// ✅ React escapes by default\nfunction SafeComponent({ userInput }) {\n  return <div>{userInput}</div>; // Automatically escaped\n}\n\n// ✅ Safe with sanitization\nfunction SafeHtmlComponent({ html }) {\n  const sanitized = DOMPurify.sanitize(html);\n  return <div dangerouslySetInnerHTML={{ __html: sanitized }} />;\n}\n\\`\\`\\`\n\n### 4. Cookie Security\n\n\\`\\`\\`javascript\n// ✅ Secure cookies\nres.cookie('session', token, {\n  httpOnly: true,    // Not accessible via JavaScript\n  secure: true,      // Only over HTTPS\n  sameSite: 'strict' // CSRF protection\n});\n\\`\\`\\`\n\n## Checklist\n\n- [ ] All user input encoded before display\n- [ ] CSP headers configured\n- [ ] No use of innerHTML without sanitization\n- [ ] Cookies use httpOnly and secure flags`,\n    tags: [\"xss\", \"security\", \"csp\", \"sanitization\", \"web-security\"],\n    confidence: 1\n  },\n  {\n    name: \"Deadlock Detection and Resolution\",\n    summary: \"Identify and fix deadlocks with proper lock ordering, timeout strategies, and deadlock detection algorithms.\",\n    content: `# Deadlock Detection and Resolution\n\n## Deadlock Conditions (All Must Be Present)\n\n1. **Mutual Exclusion**: Resources cannot be shared\n2. **Hold and Wait**: Process 