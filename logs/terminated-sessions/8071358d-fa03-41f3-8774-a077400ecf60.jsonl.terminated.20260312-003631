\"\nNEW_SWAP=$(free -m | awk '/Swap:/ {print $2}')\nif [ \"$NEW_SWAP\" -gt 1900 ]; then\n    echo \"   ✅ Swap 配置成功：${NEW_SWAP} MB\"\nelse\n    echo \"   ⚠️ Swap 配置可能有问题：${NEW_SWAP} MB\"\nfi\necho \"\"\n\n# 添加到 /etc/fstab（持久化）\necho \"配置持久化...\"\nif grep -q \"$SWAP_FILE\" /etc/fstab; then\n    echo \"   ✅ /etc/fstab 已包含 Swap 配置\"\nelse\n    echo \"$SWAP_FILE none swap sw 0 0\" >> /etc/fstab\n    echo \"   ✅ 已添加到 /etc/fstab\"\nfi\necho \"\"\n\n# 优化 Swap 使用策略（可选）\necho \"优化 Swap 使用策略...\"\necho \"   设置 swappiness = 10（降低 Swap 使用频率）\"\nsysctl vm.swappiness=10\nif grep -q \"vm.swappiness\" /etc/sysctl.conf; then\n    sed -i 's/vm.swappiness=.*/vm.swappiness=10/' /etc/sysctl.conf\nelse\n    echo \"vm.swappiness=10\" >> /etc/sysctl.conf\nfi\necho \"   ✅ swappiness 已设置为 10\"\necho \"\"\n\n# 输出完成确认\necho \"========================================\"\necho \"✅ Swap 配置完成\"\necho \"========================================\"\necho \"\"\necho \"Swap 大小: $SWAP_SIZE\"\necho \"Swap 文件: $SWAP_FILE\"\necho \"Swappiness: 10\"\necho \"\"\necho \"当前内存状态:\"\nfree -h\necho \"\"\n"}},{"type":"toolCall","id":"call_e5c154532a6a483184dbd871","name":"exec","arguments":{"command":"chmod +x /root/.openclaw/workspace/evolver/fixes/configure-swap.sh && ls -lh /root/.openclaw/workspace/evolver/fixes/configure-swap.sh"}},{"type":"toolCall","id":"call_22200d9583e34895b589469d","name":"read","arguments":{"path":"/root/.openclaw/workspace/evolver_history/projects/openclaw/pattern-registry.md","limit":50}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":670,"output":1066,"cacheRead":37248,"cacheWrite":0,"totalTokens":38984,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772742707224}}
