{"type":"message","id":"d0bc0134","parentId":"1b8a90f4","timestamp":"2026-02-25T11:14:26.190Z","message":{"role":"toolResult","toolCallId":"call_18a19e3331b14f0fbf5d4a42","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * EvoMap ж–°иҠӮзӮ№жіЁеҶҢи„ҡжң¬ (еёҰйҮҚиҜ•)\n * з”ЁйҖ”: еҲӣе»әиҝҗиҗҘдё“з”Ёзҡ„ EvoMap иҠӮзӮ№\n * зү№жҖ§: жңҖеӨҡйҮҚиҜ• 10 ж¬ЎпјҢжҜҸж¬Ўй—ҙйҡ” 5 еҲҶй’ҹ\n */\n\nconst https = require('https');\nconst crypto = require('crypto');\nconst fs = require('fs');\nconst path = require('path');\n\nconst OUTPUT_DIR = '/root/.openclaw/workspace/memory/evomap-operation-plan';\nconst MAX_RETRIES = 10;\nconst RETRY_INTERVAL_MS = 5 * 60 * 1000; // 5 еҲҶй’ҹ\n\nlet retryCount = 0;\n\nfunction registerNode() {\n  return new Promise((resolve, reject) => {\n    const senderId = 'node_openclaw_' + crypto.randomBytes(8).toString('hex');\n    const messageId = 'msg_' + Date.now() + '_' + crypto.randomBytes(4).toString('hex');\n    const timestamp = new Date().toISOString();\n\n    const payload = {\n      protocol: 'gep-a2a',\n      protocol_version: '1.0.0',\n      message_type: 'hello',\n      message_id: messageId,\n      sender_id: senderId,\n      timestamp: timestamp,\n      payload: {\n        capabilities: {\n          domains: ['automation', 'devops', 'architecture', 'optimization'],\n          languages: ['zh-CN', 'en'],\n          a2a_services: ['architecture-review', 'troubleshooting', 'code-optimization']\n        },\n        gene_count: 0,\n        capsule_count: 0,\n        env_fingerprint: {\n          platform: process.platform,\n          arch: process.arch,\n          node_version: process.version\n        },\n        alias: 'OpenClaw Agent',\n        description: 'е…ЁиҮӘеҠЁ EvoMap иҝҗиҗҘ Agent - Capsule еҸ‘еёғ + Bounty зҢҺеҸ– + A2A жңҚеҠЎ'\n      }\n    };\n    \n    // йӘҢиҜҒ payload\n    const requiredFields = ['protocol', 'protocol_version', 'message_type', 'message_id', 'sender_id', 'timestamp', 'payload'];\n    for (const field of requiredFields) {\n      if (!payload[field]) {\n        console.error(`вқҢ зјәе°‘еҝ…йңҖеӯ—ж®ө: ${field}`);\n        reject(new Error(`Missing required field: ${field}`));\n        return;\n      }\n    }\n\n    console.log(`\\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ`);\n    console.log(`  EvoMap ж–°иҠӮзӮ№жіЁеҶҢ (е°қиҜ• ${retryCount + 1}/${MAX_RETRIES})`);\n    console.log(`в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\\n`);\n    console.log('Node ID:', senderId);\n    console.log('Alias: OpenClaw Agent');\n    console.log('Timestamp:', timestamp);\n    console.log('\\nжӯЈеңЁиҝһжҺҘ EvoMap Hub...\\n');\n\n    const data = JSON.stringify(payload);\n\n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: '/a2a/hello',\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'Content-Length': Buffer.byteLength(data)\n      }\n    };\n\n    const req = https.request(options, (res) => {\n      let body = '';\n      res.on('data', (chunk) => { body += chunk; });\n      res.on('end', () => {\n        console.log('зҠ¶жҖҒз Ғ:', res.statusCode);\n        \n        try {\n          const result = JSON.parse(body);\n          \n          if (res.statusCode === 200 && result.status === 'acknowledged') {\n            console.log('\\nвң… жіЁеҶҢжҲҗеҠҹ!\\n');\n            console.log('в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ');\n            console.log('  иҠӮзӮ№дҝЎжҒҜ');\n            console.log('в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ');\n            console.log('  Node ID:', result.your_node_id || senderId);\n            console.log('  Alias: OpenClaw Agent');\n            console.log('  Claim Code:', result.claim_code);\n            console.log('  Claim URL:', result.claim_url);\n            console.log('  Hub Node ID:', result.hub_node_id);\n            console.log('в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\\n');\n            \n            // дҝқеӯҳеҮӯиҜҒ\n            const credentials = {\n              node_id: result.your_node_id || senderId,\n              sender_id: senderId,\n              alias: 'OpenClaw Agent',\n              claim_code: result.claim_code,\n              claim_url: result.claim_url,\n              hub_node_id: result.hub_node_id,\n              registered_at: timestamp,\n              capabilities: payload.payload.capabilities,\n              description: payload.payload.description,\n              status: 'registered',\n              purpose: 'EvoMap е…ЁиҮӘеҠЁиҝҗиҗҘиҠӮзӮ№'\n            };\n            \n            const credPath = path.join(OUTPUT_DIR, 'node-credentials.json');\n            fs.writeFileSync(credPath, JSON.stringify(credentials, null, 2));\n            console.log('вң… еҮӯиҜҒе·ІдҝқеӯҳеҲ°:', credPath);\n            \n            // з”ҹжҲҗиҠӮзӮ№й…ҚзҪ®ж–Үд»¶\n            const configPath = path.join(OUTPUT_DIR, 'node-config.json');\n            const config = {\n              node_id: credentials.node_id,\n              sender_id: senderId,\n              alias: 'OpenClaw Agent',\n              hub_url: 'https://evomap.ai',\n              heartbeat_interval_ms: 900000,\n              work_cycle_interval_ms: 14400000,\n              auto_publish: true,\n              auto_claim_bounty: true,\n              max_concurrent_tasks: 3,\n              cron_tasks: [\n                { name: 'evomap-daily-publish', frequency: 'every 6 hours' },\n                { name: 'evomap-bounty-hunter', frequency: 'every 4 hours' },\n                { name: 'evomap-a2a-service', frequency: 'every 8 hours' },\n                { name: 'evomap-reputation-monitor', frequency: 'every 12 hours' }\n              ]\n            };\n            fs.writeFileSync(configPath, JSON.stringify(config, null, 2));\n            console.log('вң… й…ҚзҪ®е·ІдҝқеӯҳеҲ°:', configPath);\n            \n            console.log('\\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ');\n            console.log('  дёӢдёҖжӯҘ');\n            console.log('в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ');\n            console.log('1. и®ҝй—® Claim URL з»‘е®ҡиҠӮзӮ№еҲ°дҪ зҡ„иҙҰжҲ·');\n            console.log('2. е®ҡж—¶д»»еҠЎе°ҶиҮӘеҠЁејҖе§ӢиҝҗиЎҢ');\n            console.log('3. жҜҸ 6 е°Ҹж—¶иҮӘеҠЁеҸ‘еёғ Capsule');\n            console.log('4. жҜҸ 4 е°Ҹж—¶иҮӘеҠЁжү«жҸҸ Bounty');\n            console.log('в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\\n');\n            \n            resolve(credentials);\n            \n          } else {\n            console.log('вқҢ жіЁеҶҢеӨұиҙҘ');\n            console.log('й”ҷиҜҜдҝЎжҒҜ:', result.error || result.message || body);\n            reject(new Error(result.error || result.message || 'Registration failed'));\n          }\n          \n        } catch (e) {\n          console.log('вқҢ и§Јжһҗе“Қеә”еӨұиҙҘ');\n          console.log('еҺҹе§Ӣе“Қеә”:', body);\n          console.log('й”ҷиҜҜ:', e.message);\n          reject(e);\n        }\n      });\n    });\n\n    req.on('error', (e) => {\n      console.error('вқҢ иҜ·жұӮеӨұиҙҘ:', e.message);\n      reject(e);\n    });\n\n    req.on('timeout', () => {\n      console.error('вқҢ иҜ·жұӮи¶…ж—¶');\n      req.destroy();\n      reject(new Error('Request timeout'));\n    });\n\n    req.setTimeout(30000); // 30 з§’и¶…ж—¶\n    req.write(data);\n    req.end();\n  });\n}\n\nasync function registerWithRetry() {\n  while (retryCount < MAX_RETRIES) {\n    try {\n      const credentials = await registerNode();\n      console.log('\\nвң… иҠӮзӮ№жіЁеҶҢжҲҗеҠҹпјҒ');\n      process.exit(0);\n    } catch (error) {\n      retryCount++;\n      \n      if (retryCount < MAX_RETRIES) {\n        console.log(`\\nвҡ пёҸ  жіЁеҶҢеӨұиҙҘпјҢ${RETRY_INTERVAL_MS / 60000} еҲҶй’ҹеҗҺйҮҚиҜ•...`);\n        console.log(`   е·Іе°қиҜ•: ${retryCount}/${MAX_RETRIES}`);\n        await new Promise(resolve => setTimeout(resolve, RETRY_INTERVAL_MS));\n      } else {\n        console.log(`\\nвқҢ е·ІиҫҫеҲ°жңҖеӨ§йҮҚиҜ•ж¬Ўж•° (${MAX_RETRIES})пјҢжіЁеҶҢеӨұиҙҘ`);\n        console.log('   иҜ·жЈҖжҹҘзҪ‘з»ңиҝһжҺҘжҲ– EvoMap Hub зҠ¶жҖҒ');\n        process.exit(1);\n      }\n    }\n  }\n}\n\n// еҗҜеҠЁжіЁеҶҢ\nregisterWithRetry();\n"}],"isError":false,"timestamp":1772018066189}}
