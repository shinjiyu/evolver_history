{"type":"message","id":"f7b6ed79","parentId":"e2057836","timestamp":"2026-02-26T12:59:10.496Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to update the main function to use the new function names (fetchTasks instead of fetchBounties, claimTask instead of claimBounty).","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_0385a81a9f5446489063ff94","name":"edit","arguments":{"newText":"// 主函数\nasync function main() {\n  log('═══════════════════════════════════════════');\n  log('  EvoMap Bounty 猎取任务');\n  log('═══════════════════════════════════════════');\n  \n  // 检查凭证\n  const credentials = getCredentials();\n  if (!credentials) {\n    log('❌ 未找到节点凭证，请先注册节点');\n    process.exit(1);\n  }\n  \n  log(`节点: ${credentials.node_id}`);\n  \n  // 读取数据库\n  const db = getBountyDB();\n  \n  // 获取任务列表\n  log('\\n正在扫描任务...\\n');\n  \n  try {\n    const tasks = await fetchTasks(credentials);\n    log(`发现 ${tasks.length} 个任务`);\n    \n    // 评估每个任务\n    const eligibleTasks = [];\n    for (const task of tasks) {\n      const eval = evaluateTask(task, credentials, db);\n      log(`  - ${task.id || task.task_id}: ${eval.eligible ? '✅' : '❌'} ${eval.reason}`);\n      \n      if (eval.eligible) {\n        eligibleTasks.push({ task, score: eval.score });\n      }\n    }\n    \n    // 按分数排序\n    eligibleTasks.sort((a, b) => b.score - a.score);\n    \n    // Claim 最多 1 个任务\n    if (eligibleTasks.length > 0) {\n      const { task } = eligibleTasks[0];\n      const taskId = task.id || task.task_id;\n      log(`\\n选择任务: ${taskId}`);\n      log(`  描述: ${task.description || task.title || 'N/A'}`);\n      log(`  奖励: ${task.reward || task.credits || '?'} credits`);\n      \n      try {\n        const result = await claimTask(credentials, taskId);\n        log(`  ✅ 认领成功`);\n        \n        // 记录到数据库\n        db.claimed.push(taskId);\n        saveBountyDB(db);\n        \n      } catch (error) {\n        log(`  ❌ 认领失败: ${error.message}`);\n      }\n      \n    } else {\n      log('\\n没有符合条件的任务');\n    }\n    \n  } catch (error) {\n    log(`❌ 获取任务列表失败: ${error.message}`);\n  }\n  \n  log('\\n═══════════════════════════════════════════');\n  log('  Bounty 猎取任务完成');\n  log('═══════════════════════════════════════════\\n');\n}","oldText":"// 主函数\nasync function main() {\n  log('═══════════════════════════════════════════');\n  log('  EvoMap Bounty 猎取任务');\n  log('═══════════════════════════════════════════');\n  \n  // 检查凭证\n  const credentials = getCredentials();\n  if (!credentials) {\n    log('❌ 未找到节点凭证，请先注册节点');\n    process.exit(1);\n  }\n  \n  log(`节点: ${credentials.node_id}`);\n  \n  // 读取数据库\n  const db = getBountyDB();\n  \n  // 获取 Bounty 列表\n  log('\\n正在扫描 Bounty 任务...\\n');\n  \n  try {\n    const bounties = await fetchBounties(credentials);\n    log(`发现 ${bounties.length} 个 Bounty 任务`);\n    \n    // 评估每个任务\n    const eligibleTasks = [];\n    for (const bounty of bounties) {\n      const eval = evaluateBounty(bounty, credentials, db);\n      log(`  - ${bounty.id}: ${eval.eligible ? '✅' : '❌'} ${eval.reason}`);\n      \n      if (eval.eligible) {\n        eligibleTasks.push({ bounty, score: eval.score });\n      }\n    }\n    \n    // 按分数排序\n    eligibleTasks.sort((a, b) => b.score - a.score);\n    \n    // Claim 最多 1 个任务\n    if (eligibleTasks.length > 0) {\n      const { bounty } = eligibleTasks[0];\n      log(`\\n选择任务: ${bounty.id}`);\n      log(`  描述: ${bounty.description || 'N/A'}`);\n      log(`  奖励: ${bounty.reward} credits`);\n      \n      try {\n        const result = await claimBounty(credentials, bounty.id);\n        log(`  ✅ 认领成功`);\n        \n        // 记录到数据库\n        db.claimed.push(bounty.id);\n        saveBountyDB(db);\n        \n      } catch (error) {\n        log(`  ❌ 认领失败: ${error.message}`);\n      }\n      \n    } else {\n      log('\\n没有符合条件的任务');\n    }\n    \n  } catch (error) {\n    log(`❌ 获取 Bounty 列表失败: ${error.message}`);\n  }\n  \n  log('\\n═══════════════════════════════════════════');\n  log('  Bounty 猎取任务完成');\n  log('═══════════════════════════════════════════\\n');\n}","path":"/root/.openclaw/workspace/cron/evomap-bounty-hunter.js"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":706,"output":1242,"cacheRead":18880,"cacheWrite":0,"totalTokens":20828,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772110713360}}
