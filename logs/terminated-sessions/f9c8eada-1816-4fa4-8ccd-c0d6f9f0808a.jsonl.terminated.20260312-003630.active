beration status\"},{\"method\":\"POST\",\"path\":\"/a2a/pipeline/create\",\"description\":\"Create pipeline\"},{\"method\":\"POST\",\"path\":\"/a2a/pipeline/:id/advance\",\"description\":\"Advance pipeline\"},{\"method\":\"GET\",\"path\":\"/a2a/pipeline/:id\",\"description\":\"Pipeline details\"},{\"method\":\"GET\",\"path\":\"/a2a/pipeline/templates\",\"description\":\"Pipeline templates\"},{\"method\":\"POST\",\"path\":\"/a2a/recipe\",\"description\":\"Create recipe\"},{\"method\":\"PATCH\",\"path\":\"/a2a/recipe/:id\",\"description\":\"Update recipe\"},{\"method\":\"POST\",\"path\":\"/a2a/recipe/:id/publish\",\"description\":\"Publish recipe\"},{\"method\":\"POST\",\"path\":\"/a2a/recipe/:id/archive\",\"description\":\"Archive recipe\"},{\"method\":\"POST\",\"path\":\"/a2a/recipe/:id/fork\",\"description\":\"Fork recipe\"},{\"method\":\"POST\",\"path\":\"/a2a/recipe/:id/express\",\"description\":\"Express into organism\"},{\"method\":\"GET\",\"path\":\"/a2a/recipe/list\",\"description\":\"List recipes\"},{\"method\":\"GET\",\"path\":\"/a2a/recipe/search\",\"description\":\"Search recipes\"},{\"method\":\"GET\",\"path\":\"/a2a/recipe/stats\",\"description\":\"Recipe statistics\"},{\"method\":\"GET\",\"path\":\"/a2a/recipe/:id\",\"description\":\"Recipe details\"},{\"method\":\"GET\",\"path\":\"/a2a/organism/active\",\"description\":\"Active organisms\"},{\"method\":\"GET\",\"path\":\"/a2a/organism/:id\",\"description\":\"Organism details\"},{\"method\":\"PATCH\",\"path\":\"/a2a/organism/:id\",\"description\":\"Update organism\"},{\"method\":\"POST\",\"path\":\"/a2a/organism/:id/express-gene\",\"description\":\"Execute gene step\"},{\"method\":\"POST\",\"path\":\"/a2a/service/publish\",\"description\":\"Publish service listing\"},{\"method\":\"POST\",\"path\":\"/a2a/service/update\",\"description\":\"Update service\"},{\"method\":\"POST\",\"path\":\"/a2a/service/archive\",\"description\":\"Archive service\"},{\"method\":\"GET\",\"path\":\"/a2a/service/search\",\"description\":\"Search services\"},{\"method\":\"GET\",\"path\":\"/a2a/service/list\",\"description\":\"List services\"},{\"method\":\"GET\",\"path\":\"/a2a/service/:id\",\"description\":\"Service details\"},{\"method\":\"POST\",\"path\":\"/a2a/service/rate\",\"description\":\"Rate service\"},{\"method\":\"POST\",\"path\":\"/a2a/service/order\",\"description\":\"Place order\"},{\"method\":\"POST\",\"path\":\"/a2a/bid/place\",\"description\":\"Place bid\"},{\"method\":\"POST\",\"path\":\"/a2a/bid/accept\",\"description\":\"Accept bid\"},{\"method\":\"POST\",\"path\":\"/a2a/bid/withdraw\",\"description\":\"Withdraw bid\"},{\"method\":\"GET\",\"path\":\"/a2a/bid/list\",\"description\":\"List bids (?bounty_id)\"},{\"method\":\"POST\",\"path\":\"/a2a/dispute/open\",\"description\":\"Open dispute\"},{\"method\":\"POST\",\"path\":\"/a2a/dispute/evidence\",\"description\":\"Submit evidence\"},{\"method\":\"POST\",\"path\":\"/a2a/dispute/rule\",\"description\":\"Issue ruling\"},{\"method\":\"GET\",\"path\":\"/a2a/dispute/:id\",\"description\":\"Dispute details\"},{\"method\":\"GET\",\"path\":\"/a2a/dispute/:id/messages\",\"description\":\"Dispute messages\"},{\"method\":\"GET\",\"path\":\"/a2a/disputes\",\"description\":\"List disputes\"},{\"method\":\"GET\",\"path\":\"/a2a/credit/price\",\"description\":\"Credit pricing\"},{\"method\":\"GET\",\"path\":\"/a2a/credit/estimate\",\"description\":\"Cost estimation\"},{\"method\":\"GET\",\"path\":\"/a2a/credit/economics\",\"description\":\"Economy overview\"},{\"method\":\"POST\",\"path\":\"/a2a/airdrop/redeem\",\"description\":\"Redeem airdrop code\"},{\"method\":\"POST\",\"path\":\"/a2a/worker/register\",\"description\":\"Register as worker\"},{\"method\":\"GET\",\"path\":\"/a2a/work/available\",\"description\":\"Available work (?node_id)\"},{\"method\":\"POST\",\"path\":\"/a2a/work/claim\",\"description\":\"Claim work\"},{\"method\":\"POST\",\"path\":\"/a2a/work/accept\",\"description\":\"Accept work\"},{\"method\":\"POST\",\"path\":\"/a2a/work/complete\",\"description\":\"Complete work\"},{\"method\":\"GET\",\"path\":\"/a2a/work/my\",\"description\":\"My assignments\"}]},\"quick_start\":[\"1. POST /a2a/hello -- Register your agent node (protocol envelope required)\",\"2. POST /a2a/heartbeat -- Keep alive every 15 min\",\"3. GET  /a2a/task/list -- Find available tasks\",\"4. GET  /a2a/skill?topic=envelope -- Learn the protocol\"]}\n\n═══════════════════════════════════════════\n  Bounty 猎取任务完成\n═══════════════════════════════════════════","cwd":"/root/.openclaw/workspace"},"isError":false,"timestamp":1772110656086}}
{"type":"message","id":"6314775d","parentId":"29a5c2ca","timestamp":"2026-02-26T12:57:48.152Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Interesting! The API now returns a 404 with helpful JSON that shows available routes. I can see the correct endpoints now:\n\n- `/a2a/task/list` - List tasks\n- `/a2a/task/claim` - Claim task\n- `/a2a/task/complete` - Complete task\n\nSo the bounty hunter script is using the wrong endpoint `/a2a/bounties` when it should be using `/a2a/task/list`. I need to update the script to use the correct API.\n\nLet me update the bounty hunter script to use the correct endpoints.","thinkingSignature":"reasoning_content"},{"type":"text","text":"API 返回了可用端点信息！发现 Bounty 系统使用的是 `/a2a/task/*` 端点，而非 `/a2a/bounties`。需要更新脚本："},{"type":"toolCall","id":"call_8b806841533d42c6b99eca1d","name":"read","arguments":{"file_path":"/root/.openclaw/workspace/cron/evomap-bounty-hunter.js"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":2584,"output":188,"cacheRead":13760,"cacheWrite":0,"totalTokens":16532,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772110656088}}
{"type":"message","id":"09786a1c","parentId":"6314775d","timestamp":"2026-02-26T12:57:48.325Z","message":{"role":"toolResult","toolCallId":"call_8b806841533d42c6b99eca1d","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * EvoMap Bounty 猎取任务\n * 频率: 每 4 小时\n * 功能: 扫描、评估并完成 Bounty 任务\n */\n\nconst https = require('https');\nconst fs = require('fs');\n\nconst LOG_FILE = '/root/.openclaw/workspace/logs/evomap-bounty.log';\nconst CREDENTIALS_FILE = '/root/.openclaw/workspace/memory/evomap-operation-plan/node-credentials.json';\nconst BOUNTY_DB = '/root/.openclaw/workspace/memory/evomap-bounty-db.json';\n\n// 日志函数\nfunction log(message) {\n  const timestamp = new Date().toISOString();\n  const logLine = `[${timestamp}] ${message}\\n`;\n  console.log(message);\n  fs.appendFileSync(LOG_FILE, logLine);\n}\n\n// 读取节点凭证\nfunction getCredentials() {\n  if (!fs.existsSync(CREDENTIALS_FILE)) {\n    return null;\n  }\n  return JSON.parse(fs.readFileSync(CREDENTIALS_FILE, 'utf8'));\n}\n\n// 读取 Bounty 数据库\nfunction getBountyDB() {\n  if (!fs.existsSync(BOUNTY_DB)) {\n    return { completed: [], claimed: [] };\n  }\n  return JSON.parse(fs.readFileSync(BOUNTY_DB, 'utf8'));\n}\n\n// 保存 Bounty 数据库\nfunction saveBountyDB(db) {\n  fs.writeFileSync(BOUNTY_DB, JSON.stringify(db, null, 2));\n}\n\n// 获取 Bounty 列表\nfunction fetchBounties(credentials) {\n  return new Promise((resolve, reject) => {\n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: '/a2a/bounties',\n      method: 'GET',\n      headers: {\n        'X-Node-ID': credentials.node_id\n      }\n    };\n    \n    const req = https.request(options, (res) => {\n      let body = '';\n      res.on('data', (chunk) => { body += chunk; });\n      res.on('end', () => {\n        if (res.statusCode === 200) {\n          try {\n            const result = JSON.parse(body);\n            resolve(result.bounties || []);\n          } catch (e) {\n            reject(new Error('Invalid response: ' + body));\n          }\n        } else {\n          reject(new Error(`HTTP ${res.statusCode}: ${body}`));\n        }\n      });\n    });\n    \n    req.on('error', reject);\n    req.setTimeout(30000, () => {\n      req.destroy();\n      reject(new Error('Request timeout'));\n    });\n    \n    req.end();\n  });\n}\n\n// 评估 Bounty 任务\nfunction evaluateBounty(bounty, credentials, db) {\n  // 跳过已完成的任务\n  if (db.completed.includes(bounty.id)) {\n    return { eligible: false, reason: 'Already completed' };\n  }\n  \n  // 跳过已认领的任务\n  if (db.claimed.includes(bounty.id)) {\n    return { eligible: false, reason: 'Already claimed' };\n  }\n  \n  // 检查信誉要求\n  if (bounty.min_reputation && bounty.min_reputation > 50) {\n    return { eligible: false, reason: `Reputation too low (required: ${bounty.min_reputation})` };\n  }\n  \n  // 检查领域匹配\n  const supportedDomains = ['architecture', 'devops', 'automation', 'optimization'];\n  const bountyDomains = bounty.domains || [];\n  const hasMatch = bountyDomains.some(d => supportedDomains.includes(d));\n  \n  if (!hasMatch && bountyDomains.length > 0) {\n    return { eligible: false, reason: 'Domain mismatch' };\n  }\n  \n  // 评估分数\n  let score = 0;\n  score += (bounty.reward || 10); // 基础奖励\n  score += bounty.priority === 'high' ? 20 : 0; // 高优先级\n  score += bountyDomains.includes('automation') ? 10 : 0; // 自动化领域加分\n  \n  return {\n    eligible: true,\n    score: score,\n    reason: 'Eligible'\n  };\n}\n\n// Claim Bounty\nfunction claimBounty(credentials, bountyId) {\n  return new Promise((resolve, reject) => {\n    const payload = {\n      node_id: credentials.node_id,\n      bounty_id: bountyId,\n      timestamp: new Date().toISOString()\n    };\n    \n    const data = JSON.stringify(payload);\n    \n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: `/a2a/bounties/${bountyId}/claim`,\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'Content-Length': Buffer.byteLength(data)\n      }\n    };\n    \n    const req = https.request(options, (res) => {\n      let body = '';\n      res.on('data', (chunk) => { body += chunk; });\n      res.on('end', () => {\n        if (res.statusCode === 200) {\n          try {\n            resolve(JSON.parse(body));\n          } catch (e) {\n            reject(new Error('Invalid response: ' + body));\n          }\n        } else {\n          reject(new Error(`HTTP ${res.statusCode}: ${body}`));\n        }\n      });\n    });\n    \n    req.on('error', reject);\n    req.setTimeout(30000, () => {\n      req.destroy();\n      reject(new Error('Request timeout'));\n    });\n    \n    req.write(data);\n    req.end();\n  });\n}\n\n// 主函数\nasync function main() {\n  log('═══════════════════════════════════════════');\n  log('  EvoMap Bounty 猎取任务');\n  log('═══════════════════════════════════════════');\n  \n  // 检查凭证\n  const credentials = getCredentials();\n  if (!credentials) {\n    log('❌ 未找到节点凭证，请先注册节点');\n    process.exit(1);\n  }\n  \n  log(`节点: ${credentials.node_id}`);\n  \n  // 读取数据库\n  const db = getBountyDB();\n  \n  // 获取 Bounty 列表\n  log('\\n正在扫描 Bounty 任务...\\n');\n  \n  try {\n    const bounties = await fetchBounties(credentials);\n    log(`发现 ${bounties.length} 个 Bounty 任务`);\n    \n    // 评估每个任务\n    const eligibleTasks = [];\n    for (const bounty of bounties) {\n      const eval = evaluateBounty(bounty, credentials, db);\n      log(`  - ${bounty.id}: ${eval.eligible ? '✅' : '❌'} ${eval.reason}`);\n      \n      if (eval.eligible) {\n        eligibleTasks.push({ bounty, score: eval.score });\n      }\n    }\n    \n    // 按分数排序\n    eligibleTasks.sort((a, b) => b.score - a.score);\n    \n    // Claim 最多 1 个任务\n    if (eligibleTasks.length > 0) {\n      const { bounty } = eligibleTasks[0];\n      log(`\\n选择任务: ${bounty.id}`);\n      log(`  描述: ${bounty.description || 'N/A'}`);\n      log(`  奖励: ${bounty.reward} credits`);\n      \n      try {\n        const result = await claimBounty(credentials, bounty.id);\n        log(`  ✅ 认领成功`);\n        \n        // 记录到数据库\n        db.claimed.push(bounty.id);\n        saveBountyDB(db);\n        \n      } catch (error) {\n        log(`  ❌ 认领失败: ${error.message}`);\n      }\n      \n    } else {\n      log('\\n没有符合条件的任务');\n    }\n    \n  } catch (error) {\n    log(`❌ 获取 Bounty 列表失败: ${error.message}`);\n  }\n  \n  log('\\n═══════════════════════════════════════════');\n  log('  Bounty 猎取任务完成');\n  log('═══════════════════════════════════════════\\n');\n}\n\nmain().catch(error => {\n  log(`❌ 任务执行失败: ${error.message}`);\n  process.exit(1);\n});\n"}],"isError":false,"timestamp":1772110668321}}
{"type":"message","id":"8d8176cb","parentId":"09786a1c","timestamp":"2026-02-26T12:58:10.137Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I need to update the script to use the correct API endpoints:\n- `/a2a/task/list` instead of `/a2a/bounties`\n- `/a2a/task/claim` instead of `/a2a/bounties/:id/claim`\n\nLet me update the script with the correct endpoints.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_9bb70810e9954e1bb0750a66","name":"edit","arguments":{"path":"/root/.openclaw/workspace/cron/evomap-bounty-hunter.js","oldText":"// 获取 Bounty 列表\nfunction fetchBounties(credentials) {\n  return new Promise((resolve, reject) => {\n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: '/a2a/bounties',\n      method: 'GET',\n      headers: {\n        'X-Node-ID': credentials.node_id\n      }\n    };\n    \n    const req = https.request(options, (res) => {\n      let body = '';\n      res.on('data', (chunk) => { body += chunk; });\n      res.on('end', () => {\n        if (res.statusCode === 200) {\n          try {\n            const result = JSON.parse(body);\n            resolve(result.bounties || []);\n          } catch (e) {\n            reject(new Error('Invalid response: ' + body));\n          }\n        } else {\n          reject(new Error(`HTTP ${res.statusCode}: ${body}`));\n        }\n      });\n    });\n    \n    req.on('error', reject);\n    req.setTimeout(30000, () => {\n      req.destroy();\n      reject(new Error('Request timeout'));\n    });\n    \n    req.end();\n  });\n}","newText":"// 获取任务列表\nfunction fetchTasks(credentials) {\n  return new Promise((resolve, reject) => {\n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: '/a2a/task/list?limit=20',\n      method: 'GET',\n      headers: {\n        'X-Node-ID': credentials.node_id\n      }\n    };\n    \n    const req = https.request(options, (res) => {\n      let body = '';\n      res.on('data', (chunk) => { body += chunk; });\n      res.on('end', () => {\n        if (res.statusCode === 200) {\n          try {\n            const result = JSON.parse(body);\n            resolve(result.tasks || result.data || []);\n          } catch (e) {\n            reject(new Error('Invalid response: ' + body));\n          }\n        } else {\n          reject(new Error(`HTTP ${res.statusCode}: ${body}`));\n        }\n      });\n    });\n    \n    req.on('error', reject);\n    req.setTimeout(30000, () => {\n      req.destroy();\n      reject(new Error('Request timeout'));\n    });\n    \n    req.end();\n  });\n}"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":2000,"output":586,"cacheRead":16320,"cacheWrite":0,"totalTokens":18906,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772110668325}}
