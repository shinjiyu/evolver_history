{"type":"message","id":"84a52d28","parentId":"ab2aa77c","timestamp":"2026-02-25T20:57:35.185Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"这是一个 cron 任务，要求我执行 EvoMap Bounty 猎取任务。让我先看看这个脚本是什么内容。\n\n我需要：\n1. 先读取这个 JS 文件，了解它的功能\n2. 然后执行它","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_5c6d0e8c16d24ddb9f8de8d4","name":"read","arguments":{"file_path":"/root/.openclaw/workspace/cron/evomap-bounty-hunter.js"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":178,"output":75,"cacheRead":10112,"cacheWrite":0,"totalTokens":10365,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772053051158}}
{"type":"message","id":"d39c6968","parentId":"84a52d28","timestamp":"2026-02-25T20:57:35.191Z","message":{"role":"toolResult","toolCallId":"call_5c6d0e8c16d24ddb9f8de8d4","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * EvoMap Bounty 猎取任务\n * 频率: 每 4 小时\n * 功能: 扫描、评估并完成 Bounty 任务\n */\n\nconst https = require('https');\nconst fs = require('fs');\n\nconst LOG_FILE = '/root/.openclaw/workspace/logs/evomap-bounty.log';\nconst CREDENTIALS_FILE = '/root/.openclaw/workspace/memory/evomap-operation-plan/node-credentials.json';\nconst BOUNTY_DB = '/root/.openclaw/workspace/memory/evomap-bounty-db.json';\n\n// 日志函数\nfunction log(message) {\n  const timestamp = new Date().toISOString();\n  const logLine = `[${timestamp}] ${message}\\n`;\n  console.log(message);\n  fs.appendFileSync(LOG_FILE, logLine);\n}\n\n// 读取节点凭证\nfunction getCredentials() {\n  if (!fs.existsSync(CREDENTIALS_FILE)) {\n    return null;\n  }\n  return JSON.parse(fs.readFileSync(CREDENTIALS_FILE, 'utf8'));\n}\n\n// 读取 Bounty 数据库\nfunction getBountyDB() {\n  if (!fs.existsSync(BOUNTY_DB)) {\n    return { completed: [], claimed: [] };\n  }\n  return JSON.parse(fs.readFileSync(BOUNTY_DB, 'utf8'));\n}\n\n// 保存 Bounty 数据库\nfunction saveBountyDB(db) {\n  fs.writeFileSync(BOUNTY_DB, JSON.stringify(db, null, 2));\n}\n\n// 获取 Bounty 列表\nfunction fetchBounties(credentials) {\n  return new Promise((resolve, reject) => {\n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: '/a2a/bounties',\n      method: 'GET',\n      headers: {\n        'X-Node-ID': credentials.node_id\n      }\n    };\n    \n    const req = https.request(options, (res) => {\n      let body = '';\n      res.on('data', (chunk) => { body += chunk; });\n      res.on('end', () => {\n        if (res.statusCode === 200) {\n          try {\n            const result = JSON.parse(body);\n            resolve(result.bounties || []);\n          } catch (e) {\n            reject(new Error('Invalid response: ' + body));\n          }\n        } else {\n          reject(new Error(`HTTP ${res.statusCode}: ${body}`));\n        }\n      });\n    });\n    \n    req.on('error', reject);\n    req.setTimeout(30000, () => {\n      req.destroy();\n      reject(new Error('Request timeout'));\n    });\n    \n    req.end();\n  });\n}\n\n// 评估 Bounty 任务\nfunction evaluateBounty(bounty, credentials, db) {\n  // 跳过已完成的任务\n  if (db.completed.includes(bounty.id)) {\n    return { eligible: false, reason: 'Already completed' };\n  }\n  \n  // 跳过已认领的任务\n  if (db.claimed.includes(bounty.id)) {\n    return { eligible: false, reason: 'Already claimed' };\n  }\n  \n  // 检查信誉要求\n  if (bounty.min_reputation && bounty.min_reputation > 50) {\n    return { eligible: false, reason: `Reputation too low (required: ${bounty.min_reputation})` };\n  }\n  \n  // 检查领域匹配\n  const supportedDomains = ['architecture', 'devops', 'automation', 'optimization'];\n  const bountyDomains = bounty.domains || [];\n  const hasMatch = bountyDomains.some(d => supportedDomains.includes(d));\n  \n  if (!hasMatch && bountyDomains.length > 0) {\n    return { eligible: false, reason: 'Domain mismatch' };\n  }\n  \n  // 评估分数\n  let score = 0;\n  score += (bounty.reward || 10); // 基础奖励\n  score += bounty.priority === 'high' ? 20 : 0; // 高优先级\n  score += bountyDomains.includes('automation') ? 10 : 0; // 自动化领域加分\n  \n  return {\n    eligible: true,\n    score: score,\n    reason: 'Eligible'\n  };\n}\n\n// Claim Bounty\nfunction claimBounty(credentials, bountyId) {\n  return new Promise((resolve, reject) => {\n    const payload = {\n      node_id: credentials.node_id,\n      bounty_id: bountyId,\n      timestamp: new Date().toISOString()\n    };\n    \n    const data = JSON.stringify(payload);\n    \n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: `/a2a/bounties/${bountyId}/claim`,\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'Content-Length': Buffer.byteLength(data)\n      }\n    };\n    \n    const req = https.request(options, (res) => {\n      let body = '';\n      res.on('data', (chunk) => { body += chunk; });\n      res.on('end', () => {\n        if (res.statusCode === 200) {\n          try {\n            resolve(JSON.parse(body));\n          } catch (e) {\n            reject(new Error('Invalid response: ' + body));\n          }\n        } else {\n          reject(new Error(`HTTP ${res.statusCode}: ${body}`));\n        }\n      });\n    });\n    \n    req.on('error', reject);\n    req.setTimeout(30000, () => {\n      req.destroy();\n      reject(new Error('Request timeout'));\n    });\n    \n    req.write(data);\n    req.end();\n  });\n}\n\n// 主函数\nasync function main() {\n  log('═══════════════════════════════════════════');\n  log('  EvoMap Bounty 猎取任务');\n  log('═══════════════════════════════════════════');\n  \n  // 检查凭证\n  const credentials = getCredentials();\n  if (!credentials) {\n    log('❌ 未找到节点凭证，请先注册节点');\n    process.exit(1);\n  }\n  \n  log(`节点: ${credentials.node_id}`);\n  \n  // 读取数据库\n  const db = getBountyDB();\n  \n  // 获取 Bounty 列表\n  log('\\n正在扫描 Bounty 任务...\\n');\n  \n  try {\n    const bounties = await fetchBounties(credentials);\n    log(`发现 ${bounties.length} 个 Bounty 任务`);\n    \n    // 评估每个任务\n    const eligibleTasks = [];\n    for (const bounty of bounties) {\n      const eval = evaluateBounty(bounty, credentials, db);\n      log(`  - ${bounty.id}: ${eval.eligible ? '✅' : '❌'} ${eval.reason}`);\n      \n      if (eval.eligible) {\n        eligibleTasks.push({ bounty, score: eval.score });\n      }\n    }\n    \n    // 按分数排序\n    eligibleTasks.sort((a, b) => b.score - a.score);\n    \n    // Claim 最多 1 个任务\n    if (eligibleTasks.length > 0) {\n      const { bounty } = eligibleTasks[0];\n      log(`\\n选择任务: ${bounty.id}`);\n      log(`  描述: ${bounty.description || 'N/A'}`);\n      log(`  奖励: ${bounty.reward} credits`);\n      \n      try {\n        const result = await claimBounty(credentials, bounty.id);\n        log(`  ✅ 认领成功`);\n        \n        // 记录到数据库\n        db.claimed.push(bounty.id);\n        saveBountyDB(db);\n        \n      } catch (error) {\n        log(`  ❌ 认领失败: ${error.message}`);\n      }\n      \n    } else {\n      log('\\n没有符合条件的任务');\n    }\n    \n  } catch (error) {\n    log(`❌ 获取 Bounty 列表失败: ${error.message}`);\n  }\n  \n  log('\\n═══════════════════════════════════════════');\n  log('  Bounty 猎取任务完成');\n  log('═══════════════════════════════════════════\\n');\n}\n\nmain().catch(error => {\n  log(`❌ 任务执行失败: ${error.message}`);\n  process.exit(1);\n});\n"}],"isError":false,"timestamp":1772053055190}}
