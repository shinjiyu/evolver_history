Ҡ¶жҖҒ\\nif [ \\\"$SKIP_NETWORK\\\" = \\\"false\\\" ]; then\\n  echo \\\"1пёҸвғЈ жЈҖжҹҘзҪ‘з»ңзҠ¶жҖҒ...\\\"\\n  \\n  # жЁЎжӢҹзҪ‘з»ңзҠ¶жҖҒжЈҖжҹҘпјҲе®һйҷ…дҪҝз”Ёж—¶жӣҝжҚўдёәзңҹе®һ APIпјү\\n  # network_status=$(curl -s -m 10 https://api.evomap.ai/network/status | jq -r '.status')\\n  \\n  # дҪҝз”Ёз®ҖеҚ•зҡ„зҪ‘з»ңжЈҖжҹҘдҪңдёәзӨәдҫӢ\\n  if ping -c 1 -W 5 8.8.8.8 > /dev/null 2>&1; then\\n    echo \\\"вң… зҪ‘з»ңзҠ¶жҖҒпјҡжӯЈеёё\\\"\\n  else\\n    echo \\\"вҡ пёҸ зҪ‘з»ңдёҚеҸҜз”ЁпјҢи·іиҝҮжЈҖжҹҘ\\\"\\n  fi\\nelse\\n  echo \\\"1пёҸвғЈ и·іиҝҮзҪ‘з»ңзҠ¶жҖҒжЈҖжҹҘ\\\"\\nfi\\n\\necho \\\"\\\"\\n\\n# жЈҖжҹҘ 2: Gene зӯ–з•ҘйӘҢиҜҒ\\necho \\\"2пёҸвғЈ йӘҢиҜҒ Gene зӯ–з•Ҙ...\\\"\\nif [ ! -f \\\"$CAPSULE_FILE\\\" ]; then\\n  echo \\\"вқҢ Capsule ж–Үд»¶дёҚеӯҳеңЁпјҡ$CAPSULE_FILE\\\"\\n  exit 1\\nfi\\n\\n# жЈҖжҹҘж–Үд»¶ж јејҸ\\nif ! jq empty \\\"$CAPSULE_FILE\\\" 2>/dev/null; then\\n  echo \\\"вқҢ Capsule ж–Үд»¶ж јејҸй”ҷиҜҜпјҲдёҚжҳҜжңүж•Ҳзҡ„ JSONпјү\\\"\\n  exit 1\\nfi\\n\\n# жЈҖжҹҘ Gene зӯ–з•ҘжҳҜеҗҰеӯҳеңЁ\\nif ! jq -e '.gene_strategy.steps' \\\"$CAPSULE_FILE\\\" > /dev/null 2>&1; then\\n  echo \\\"вҡ пёҸ жңӘжүҫеҲ° Gene зӯ–з•ҘпјҢи·іиҝҮйӘҢиҜҒ\\\"\\nelse\\n  invalid_steps=0\\n  step_count=0\\n  \\n  while IFS= read -r step; do\\n    step_count=$((step_count + 1))\\n    length=${#step}\\n    \\n    if [ $length -lt 15 ]; then\\n      echo \\\"вқҢ жӯҘйӘӨ #$step_count еӨӘзҹӯпјҲ${length} еӯ—з¬Ұпјүпјҡ$step\\\"\\n      invalid_steps=$((invalid_steps + 1))\\n    else\\n      echo \\\"вң… жӯҘйӘӨ #$step_count еҗҲж јпјҲ${length} еӯ—з¬Ұпјү\\\"\\n    fi\\n  done < <(jq -r '.gene_strategy.steps[]?' \\\"$CAPSULE_FILE\\\")\\n  \\n  echo \\\"\\\"\\n  \\n  if [ $invalid_steps -gt 0 ]; then\\n    echo \\\"вқҢ еҸ‘зҺ° $invalid_steps дёӘжӯҘйӘӨдёҚз¬ҰеҗҲиҰҒжұӮпјҲиҮіе°‘ 15 еӯ—з¬Ұпјү\\\"\\n    \\n    if [ \\\"$AUTO_FIX\\\" = \\\"true\\\" ]; then\\n      echo \\\"рҹ”§ иҮӘеҠЁдҝ®еӨҚ Gene зӯ–з•Ҙ...\\\"\\n      \\n      # еҲӣе»әдҝ®еӨҚеҗҺзҡ„ж–Үд»¶\\n      output_file=\\\"${CAPSULE_FILE}.fixed\\\"\\n      jq '.gene_strategy.steps |= 