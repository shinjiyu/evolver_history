{"type":"message","id":"d30ab06b","parentId":"76a8265d","timestamp":"2026-02-27T12:32:26.874Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"紧急内存释放脚本已运行，释放了 14MB。但主要问题仍然是 Gateway 占用 1.7GB 内存。\n\n现在让我：\n1. 创建自动重启 Gateway 的脚本\n2. 更新 pattern-registry\n3. 生成进化报告","thinkingSignature":"reasoning_content"},{"type":"text","text":"### 创建自动重启脚本（低峰期安全重启）"},{"type":"toolCall","id":"call_738261c248154b58bcafe6e5","name":"write","arguments":{"path":"/root/.openclaw/workspace/evolver/fixes/safe-gateway-restart.sh","content":"#!/bin/bash\n# safe-gateway-restart.sh - Gateway 安全重启脚本\n# 创建时间: 2026-02-27 20:31 (Round 250)\n# 用途: 在低峰期安全重启 Gateway，释放内存泄漏\n\nset -euo pipefail\n\n# 颜色定义\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nNC='\\033[0m'\n\n# 配置\nLOG_FILE=\"/var/log/gateway-restart.log\"\nMAX_MEMORY_MB=1500\nMIN_UPTIME_HOURS=4\n\nlog() {\n  echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $1\" | tee -a \"$LOG_FILE\"\n}\n\necho \"=========================================\"\necho \"🔄 Gateway 安全重启工具\"\necho \"时间: $(date '+%Y-%m-%d %H:%M:%S')\"\necho \"=========================================\"\necho \"\"\n\n# 检查是否为低峰期（22:00-06:00）\nCURRENT_HOUR=$(date +%H)\n\nif [[ $CURRENT_HOUR -ge 22 ]] || [[ $CURRENT_HOUR -lt 6 ]]; then\n  log \"✅ 当前为低峰期 ($CURRENT_HOUR:00)\"\n  LOW_PEAK=true\nelse\n  log \"⚠️  当前为高峰期 ($CURRENT_HOUR:00)\"\n  LOW_PEAK=false\n\n  # 如果不是强制模式，退出\n  if [[ \"${1:-}\" != \"--force\" ]]; then\n    log \"使用 --force 参数强制重启\"\n    echo \"\"\n    echo \"建议在低峰期执行 (22:00-06:00)\"\n    echo \"或使用: $0 --force\"\n    exit 1\n  fi\nfi\n\necho \"\"\n\n# 获取 Gateway 信息\nGATEWAY_PID=$(ps aux | grep \"openclaw-gateway\" | grep -v grep | awk '{print $2}')\n\nif [[ -z \"$GATEWAY_PID\" ]]; then\n  log \"❌ Gateway 未运行\"\n  exit 1\nfi\n\nGATEWAY_MEM=$(ps -p $GATEWAY_PID -o rss --no-headers 2>/dev/null | awk '{print int($1/1024)}')\nGATEWAY_UPTIME=$(ps -p $GATEWAY_PID -o etime --no-headers 2>/dev/null | tr -d ' ')\n\nlog \"Gateway 状态:\"\nlog \"  PID: $GATEWAY_PID\"\nlog \"  内存: ${GATEWAY_MEM}MB\"\nlog \"  运行时间: $GATEWAY_UPTIME\"\necho \"\"\n\n# 检查是否需要重启\nNEED_RESTART=false\n\nif [[ $GATEWAY_MEM -gt $MAX_MEMORY_MB ]]; then\n  log \"⚠️  内存使用过高 (${GATEWAY_MEM}MB > ${MAX_MEMORY_MB}MB)\"\n  NEED_RESTART=true\nfi\n\n# 计算运行时间（小时）\nUPTIME_HOURS=$(echo \"$GATEWAY_UPTIME\" | awk -F: '{if (NF==3) print $1; else print 0}')\n\nif [[ $UPTIME_HOURS -gt $MIN_UPTIME_HOURS ]]; then\n  log \"ℹ️  运行时间较长 (${UPTIME_HOURS}h > ${MIN_UPTIME_HOURS}h)\"\n  NEED_RESTART=true\nfi\n\nif [[ \"$NEED_RESTART\" == \"false\" ]]; then\n  log \"✅ Gateway 状态正常，无需重启\"\n  exit 0\nfi\n\necho \"\"\nlog \"开始重启 Gateway...\"\necho \"\"\n\n# 重启前检查\nlog \"1. 检查活跃连接...\"\nACTIVE_CONNECTIONS=$(ss -tnp | grep \":3000\" | wc -l || echo 0)\nlog \"   活跃连接数: $ACTIVE_CONNECTIONS\"\n\nif [[ $ACTIVE_CONNECTIONS -gt 10 ]] && [[ \"$LOW_PEAK\" == \"false\" ]]; then\n  log \"⚠️  活跃连接较多，建议等待低峰期\"\n  if [[ \"${1:-}\" != \"--force\" ]]; then\n    log \"使用 --force 强制重启\"\n    exit 1\n  fi\nfi\n\n# 执行重启\nlog \"2. 停止 Gateway...\"\nopenclaw gateway stop 2>&1 | tee -a \"$LOG_FILE\" || {\n  log \"❌ 停止失败\"\n  exit 1\n}\n\nsleep 3\n\nlog \"3. 等待进程完全退出...\"\nfor i in {1..10}; do\n  if ! ps -p $GATEWAY_PID > /dev/null 2>&1; then\n    log \"✅ Gateway 已停止\"\n    break\n  fi\n  sleep 1\ndone\n\nlog \"4. 启动 Gateway...\"\nopenclaw gateway start 2>&1 | tee -a \"$LOG_FILE\" || {\n  log \"❌ 启动失败\"\n  exit 1\n}\n\nsleep 5\n\n# 验证重启\nlog \"5. 验证重启结果...\"\nNEW_PID=$(ps aux | grep \"openclaw-gateway\" | grep -v grep | awk '{print $2}')\n\nif [[ -z \"$NEW_PID\" ]]; then\n  log \"❌ Gateway 启动失败\"\n  exit 1\nfi\n\nNEW_MEM=$(ps -p $NEW_PID -o rss --no-headers 2>/dev/null | awk '{print int($1/1024)}')\n\nlog \"\"\nlog \"✅ 重启成功！\"\nlog \"   旧 PID: $GATEWAY_PID → 新 PID: $NEW_PID\"\nlog \"   旧内存: ${GATEWAY_MEM}MB → 新内存: ${NEW_MEM}MB\"\nlog \"   释放内存: $((GATEWAY_MEM - NEW_MEM))MB\"\nlog \"\"\n\n# 记录到进化历史\necho \"$(date '+%Y-%m-%d %H:%M:%S') - Gateway restarted: ${GATEWAY_MEM}MB -> ${NEW_MEM}MB (freed $((GATEWAY_MEM - NEW_MEM))MB)\" >> /root/.openclaw/workspace/memory/gateway-restart-history.log\n\necho \"\"\necho \"=========================================\"\n"}},{"type":"toolCall","id":"call_99489d6b69474e8a8a512deb","name":"exec","arguments":{"command":"chmod +x /root/.openclaw/workspace/evolver/fixes/safe-gateway-restart.sh"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":1961,"output":1476,"cacheRead":109056,"cacheWrite":0,"totalTokens":112493,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772195493766}}
