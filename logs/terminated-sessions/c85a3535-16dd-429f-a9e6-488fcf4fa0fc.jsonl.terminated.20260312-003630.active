{"type":"message","id":"b401ef76","parentId":"b99cef0c","timestamp":"2026-02-27T00:32:12.532Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好，创建了系统日志清理脚本。现在创建 Swap 配置脚本：","thinkingSignature":"reasoning_content"},{"type":"text","text":"### C. 创建 Swap 配置脚本"},{"type":"toolCall","id":"call_29aa236b37c84c5584454470","name":"write","arguments":{"path":"/root/.openclaw/workspace/evolver/fixes/configure-swap.sh","content":"#!/bin/bash\n# configure-swap.sh - Swap 分区配置脚本\n# 创建时间: 2026-02-27 08:30 (Round 247)\n# 用途: 配置 Swap 分区缓解内存压力\n\nset -euo pipefail\n\n# 颜色定义\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nNC='\\033[0m'\n\n# 日志函数\nlog() {\n  echo -e \"${BLUE}[$(date '+%H:%M:%S')]${NC} $1\"\n}\n\nlog_success() {\n  echo -e \"${GREEN}✅ $1${NC}\"\n}\n\nlog_warning() {\n  echo -e \"${YELLOW}⚠️  $1${NC}\"\n}\n\nlog_error() {\n  echo -e \"${RED}❌ $1${NC}\"\n}\n\necho \"=========================================\"\necho \"💾 Swap 分区配置工具\"\necho \"时间: $(date '+%Y-%m-%d %H:%M:%S')\"\necho \"=========================================\"\necho \"\"\n\n# 检查当前 Swap 状态\nCURRENT_SWAP=$(free -m | awk '/Swap:/ {print $2}')\nCURRENT_MEM=$(free -m | awk '/Mem:/ {print $2}')\nAVAILABLE_MEM=$(free -m | awk '/Mem:/ {print $7}')\n\nlog \"系统内存信息:\"\nlog \"  总内存: ${CURRENT_MEM}MB\"\nlog \"  可用内存: ${AVAILABLE_MEM}MB\"\nlog \"  当前 Swap: ${CURRENT_SWAP}MB\"\necho \"\"\n\nif [[ $CURRENT_SWAP -gt 0 ]]; then\n  log_success \"Swap 已配置 (${CURRENT_SWAP}MB)\"\n  log \"如需重新配置，请先运行: swapoff -a && rm -f /swapfile\"\n  exit 0\nfi\n\n# 检查是否为 root\nif [[ $EUID -ne 0 ]]; then\n  log_error \"此脚本需要 root 权限\"\n  log \"请使用: sudo $0\"\n  exit 1\nfi\n\n# 检查磁盘空间\nDISK_AVAILABLE=$(df -BG / | awk 'NR==2 {print $4}' | tr -d 'G')\n\nif [[ $DISK_AVAILABLE -lt 3 ]]; then\n  log_error \"磁盘空间不足 (需要至少 3G，当前 ${DISK_AVAILABLE}G)\"\n  log \"请先运行 system-log-cleanup.sh 释放空间\"\n  exit 1\nfi\n\nlog \"磁盘可用空间: ${DISK_AVAILABLE}G ✓\"\necho \"\"\n\n# 配置参数\nSWAP_SIZE=\"2G\"\nSWAP_FILE=\"/swapfile\"\n\nlog \"配置计划:\"\nlog \"  Swap 大小: ${SWAP_SIZE}\"\nlog \"  Swap 文件: ${SWAP_FILE}\"\necho \"\"\n\nread -p \"确认配置 Swap? (y/n): \" -n 1 -r\necho \"\"\n\nif [[ ! $REPLY =~ ^[Yy]$ ]]; then\n  log \"已取消\"\n  exit 0\nfi\n\necho \"\"\nlog \"开始配置 Swap...\"\necho \"\"\n\n### 步骤 1: 创建 Swap 文件\nlog \"步骤 1/5: 创建 Swap 文件...\"\n\nif [[ -f \"$SWAP_FILE\" ]]; then\n  log_warning \"Swap 文件已存在，跳过创建\"\nelse\n  fallocate -l $SWAP_SIZE $SWAP_FILE || {\n    log_error \"创建 Swap 文件失败\"\n    exit 1\n  }\n  log_success \"Swap 文件已创建 ($SWAP_SIZE)\"\nfi\n\n### 步骤 2: 设置权限\nlog \"步骤 2/5: 设置文件权限...\"\n\nchmod 600 $SWAP_FILE\nlog_success \"权限已设置为 600\"\n\n### 步骤 3: 格式化为 Swap\nlog \"步骤 3/5: 格式化为 Swap...\"\n\nmkswap $SWAP_FILE >/dev/null 2>&1 || {\n  log_error \"格式化失败\"\n  exit 1\n}\nlog_success \"Swap 格式化完成\"\n\n### 步骤 4: 启用 Swap\nlog \"步骤 4/5: 启用 Swap...\"\n\nswapon $SWAP_FILE || {\n  log_error \"启用 Swap 失败\"\n  exit 1\n}\nlog_success \"Swap 已启用\"\n\n### 步骤 5: 配置开机自动挂载\nlog \"步骤 5/5: 配置开机自动挂载...\"\n\nif grep -q \"$SWAP_FILE\" /etc/fstab; then\n  log_warning \"fstab 已配置，跳过\"\nelse\n  echo \"$SWAP_FILE none swap sw 0 0\" >> /etc/fstab\n  log_success \"已添加到 /etc/fstab\"\nfi\n\necho \"\"\n\n### 验证配置\nNEW_SWAP=$(free -m | awk '/Swap:/ {print $2}')\nNEW_AVAILABLE=$(free -m | awk '/Mem:/ {print $7}')\n\necho \"=========================================\"\necho \"📊 配置结果\"\necho \"=========================================\"\necho \"\"\necho \"Swap 大小: ${NEW_SWAP}MB\"\necho \"可用内存: ${AVAILABLE_MEM}MB → ${NEW_AVAILABLE}MB (含 Swap)\"\necho \"\"\n\nif [[ $NEW_SWAP -ge 1900 ]]; then\n  log_success \"Swap 配置成功!\"\n  log_success \"系统可用内存增加 ~2GB\"\nelse\n  log_warning \"Swap 大小异常，请检查\"\nfi\n\necho \"\"\n\n# Swappiness 配置建议\nlog \"优化建议:\"\nlog \"  当前 swappiness: $(cat /proc/sys/vm/swappiness)\"\nlog \"  建议值: 10 (减少 Swap 使用频率)\"\nlog \"\"\nlog \"  临时设置: sysctl vm.swappiness=10\"\nlog \"  永久设置: echo 'vm.swappiness=10' >> /etc/sysctl.conf\"\necho \"\"\n\necho \"=========================================\"\n"}},{"type":"toolCall","id":"call_9fcf18cb9dba4c08a33fa3aa","name":"exec","arguments":{"command":"chmod +x /root/.openclaw/workspace/evolver/fixes/configure-swap.sh"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":1940,"output":1345,"cacheRead":50496,"cacheWrite":0,"totalTokens":53781,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772152298665}}
