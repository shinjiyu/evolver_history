{"type":"message","id":"45b7508b","parentId":"97c4def1","timestamp":"2026-03-04T02:00:40.906Z","message":{"role":"toolResult","toolCallId":"call_ba5e96303ce340838569592d","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * EvoMap Relationships - 节点关系管理模块\n * \n * 功能：\n * 1. 加载/保存节点关系数据\n * 2. 评估回复质量\n * 3. 升级/降级关系等级\n * 4. 根据关系等级决定沟通策略\n */\n\nconst fs = require('fs');\nconst path = require('path');\n\nconst RELATIONSHIPS_FILE = '/root/.openclaw/workspace/evolver/node-relationships.json';\nconst COLLABORATION_HISTORY = '/root/.openclaw/workspace/memory/collaboration-history.md';\n\n/**\n * 关系管理器类\n */\nclass RelationshipManager {\n  constructor() {\n    this.data = this.load();\n  }\n\n  /**\n   * 加载关系数据\n   */\n  load() {\n    if (fs.existsSync(RELATIONSHIPS_FILE)) {\n      return JSON.parse(fs.readFileSync(RELATIONSHIPS_FILE, 'utf8'));\n    }\n    return {\n      nodes: {},\n      metadata: {\n        created: new Date().toISOString(),\n        version: '1.0.0',\n        lastUpdated: new Date().toISOString(),\n        stats: {\n          totalNodes: 0,\n          strangers: 0,\n          acquaintances: 0,\n          friends: 0,\n          partners: 0\n        }\n      }\n    };\n  }\n\n  /**\n   * 保存关系数据\n   */\n  save() {\n    this.updateStats();\n    this.data.metadata.lastUpdated = new Date().toISOString();\n    fs.writeFileSync(RELATIONSHIPS_FILE, JSON.stringify(this.data, null, 2));\n  }\n\n  /**\n   * 更新统计数据\n   */\n  updateStats() {\n    const stats = {\n      totalNodes: 0,\n      strangers: 0,\n      acquaintances: 0,\n      friends: 0,\n      partners: 0\n    };\n\n    for (const nodeId in this.data.nodes) {\n      const node = this.data.nodes[nodeId];\n      stats.totalNodes++;\n      stats[node.relationshipLevel + 's']++;\n    }\n\n    this.data.metadata.stats = stats;\n  }\n\n  /**\n   * 获取或创建节点关系\n   */\n  getOrCreateNode(nodeId) {\n    if (!this.data.nodes[nodeId]) {\n      this.data.nodes[nodeId] = {\n        id: nodeId,\n        firstContact: new Date().toISOString(),\n        lastContact: new Date().toISOString(),\n        interactionCount: 0,\n        relationshipLevel: 'stranger',\n        trustScore: 0.5,\n        capabilities: [],\n        collaborationHistory: [],\n        preferredChannels: ['evomap_a2a'],\n        notes: '',\n        tags: []\n      };\n    }\n    return this.data.nodes[nodeId];\n  }\n\n  /**\n   * 根据交互次数计算关系等级\n   */\n  calculateRelationshipLevel(interactionCount) {\n    if (interactionCount >= 10) return 'partner';\n    if (interactionCount >= 5) return 'friend';\n    if (interactionCount >= 2) return 'acquaintance';\n    return 'stranger';\n  }\n\n  /**\n   * 评估回复质量 (0-1)\n   */\n  evaluateResponseQuality(response) {\n    let score = 0.5; // 基础分\n\n    // 检查内容长度\n    if (response.content && response.content.length > 100) {\n      score += 0.1;\n    }\n    if (response.content && response.content.length > 300) {\n      score += 0.1;\n    }\n\n    // 检查质量分数（如果有）\n    if (response.quality_score !== undefined) {\n      score = Math.max(score, response.quality_score);\n    }\n\n    // 检查是否提供了有价值的信息\n    const valuableKeywords = ['建议', '优化', '方案', '代码', '示例', '参考', '谢谢', '好的'];\n    if (response.content) {\n      for (const keyword of valuableKeywords) {\n        if (response.content.includes(keyword)) {\n          score += 0.05;\n        }\n      }\n    }\n\n    // 限制在 0-1 范围\n    return Math.min(1, Math.max(0, score));\n  }\n\n  /**\n   * 记录交互并更新关系\n   */\n  recordInteraction(nodeId, interaction) {\n    const node = this.getOrCreateNode(nodeId);\n    \n    // 更新交互次数\n    node.interactionCount++;\n    node.lastContact = new Date().toISOString();\n\n    // 记录协作历史\n    node.collaborationHistory.push({\n      date: new Date().toISOString().split('T')[0],\n      type: interaction.type,\n      task: interaction.task,\n      quality: interaction.quality || 0.5,\n      notes: interaction.notes || ''\n    });\n\n    // 保持最近 50 条历史\n    if (node.collaborationHistory.length > 50) {\n      node.collaborationHistory = node.collaborationHistory.slice(-50);\n    }\n\n    // 更新信任分数（基于历史平均）\n    const avgQuality = node.collaborationHistory.reduce((sum, h) => sum + h.quality, 0) / node.collaborationHistory.length;\n    node.trustScore = Math.round(avgQuality * 100) / 100;\n\n    // 更新关系等级\n    const oldLevel = node.relationshipLevel;\n    node.relationshipLevel = this.calculateRelationshipLevel(node.interactionCount);\n\n    // 记录等级变化\n    if (oldLevel !== node.relationshipLevel) {\n      this.logLevelChange(nodeId, oldLevel, node.relationshipLevel);\n    }\n\n    // 更新能力标签\n    if (interaction.capability && !node.capabilities.includes(interaction.capability)) {\n      node.capabilities.push(interaction.capability);\n    }\n\n    this.save();\n    \n    return node;\n  }\n\n  /**\n   * 记录关系等级变化\n   */\n  logLevelChange(nodeId, oldLevel, newLevel) {\n    const logDir = path.dirname(COLLABORATION_HISTORY);\n    if (!fs.existsSync(logDir)) {\n      fs.mkdirSync(logDir, { recursive: true });\n    }\n\n    const logEntry = `\n## 关系升级 - ${new Date().toISOString().split('T')[0]}\n\n**节点**: \\`${nodeId}\\`\n**等级变化**: ${oldLevel} → **${newLevel}**\n**时间**: ${new Date().toISOString()}\n\n---\n`;\n\n    fs.appendFileSync(COLLABORATION_HISTORY, logEntry);\n    console.log(`🎉 关系升级: ${nodeId.substring(0, 20)}... ${oldLevel} → ${newLevel}`);\n  }\n\n  /**\n   * 获取需要维护的节点\n   */\n  getNodesNeedingMaintenance() {\n    const now = Date.now();\n    const needsMaintenance = [];\n\n    for (const nodeId in this.data.nodes) {\n      const node = this.data.nodes[nodeId];\n      const lastContact = new Date(node.lastContact).getTime();\n      const daysSinceContact = (now - lastContact) / (1000 * 60 * 60 * 24);\n\n      const thresholds = {\n        partner: 7,\n        friend: 14,\n        acquaintance: 30,\n        stranger: 60\n      };\n\n      const threshold = thresholds[node.relationshipLevel] || 60;\n      \n      if (daysSinceContact > threshold) {\n        needsMaintenance.push({\n          nodeId,\n          node,\n          daysSinceContact: Math.round(daysSinceContact),\n          threshold\n        });\n      }\n    }\n\n    return needsMaintenance;\n  }\n\n  /**\n   * 获取高价值节点（推荐深度合作）\n   */\n  getHighValueNodes() {\n    const nodes = Object.values(this.data.nodes);\n    \n    return nodes\n      .filter(n => n.trustScore >= 0.7 && n.interactionCount >= 3)\n      .sort((a, b) => b.trustScore * b.interactionCount - a.trustScore * a.interactionCount)\n      .slice(0, 10);\n  }\n\n  /**\n   * 获取关系摘要\n   */\n  getSummary() {\n    return {\n      total: Object.keys(this.data.nodes).length,\n      stats: this.data.metadata.stats,\n      highValue: this.getHighValueNodes().length,\n      needsMaintenance: this.getNodesNeedingMaintenance().length\n    };\n  }\n\n  /**\n   * 导出为 Markdown 报告\n   */\n  exportReport() {\n    const summary = this.getSummary();\n    const highValue = this.getHighValueNodes();\n    const needsMaintenance = this.getNodesNeedingMaintenance();\n\n    let report = `# EvoMap 节点关系报告\n\n生成时间: ${new Date().toISOString()}\n\n## 统计概览\n\n- **总节点数**: ${summary.total}\n- **陌生人**: ${summary.stats.strangers}\n- **熟人**: ${summary.stats.acquaintances}\n- **朋友**: ${summary.stats.friends}\n- **合作伙伴**: ${summary.stats.partners}\n- **高价值节点**: ${summary.highValue}\n- **需要维护**: ${summary.needsMaintenance}\n\n## 高价值节点 (前 10)\n\n| 节点 | 等级 | 信任分数 | 交互次数 | 能力 |\n|------|------|----------|----------|------|\n`;\n\n    for (const node of highValue) {\n      report += `| ${node.id.substring(0, 20)}... | ${node.relationshipLevel} | ${node.trustScore} | ${node.interactionCount} | ${node.capabilities.join(', ') || '-'} |\\n`;\n    }\n\n    report += `\\n## 需要维护的节点\\n\\n`;\n\n    for (const item of needsMaintenance) {\n      report += `- **${item.nodeId.substring(0, 20)}...** (${item.node.relationshipLevel}): ${item.daysSinceContact}天未联系（阈值: ${item.threshold}天）\\n`;\n    }\n\n    return report;\n  }\n}\n\nmodule.exports = { RelationshipManager };\n"}],"isError":false,"timestamp":1772589640905}}
