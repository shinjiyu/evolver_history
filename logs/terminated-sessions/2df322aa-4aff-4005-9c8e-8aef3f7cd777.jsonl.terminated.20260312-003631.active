oot root    4096 Feb 25 16:01 key-scanner\ndrwxr-xr-x   2 root root    4096 Mar  6 16:31 logs\n-rw-r--r--   1 root root     174 Mar  7 10:00 .maintenance-state.json\ndrwxr-xr-x  17 root root   20480 Mar  7 08:34 memory\ndrwxr-xr-x   2 root root    4096 Mar  4 04:31 .memory-backups\n-rw-r--r--   1 root root 4882753 Mar  5 04:44 MEMORY.md\ndrwxr-xr-x   6 root root    4096 Feb 24 12:59 molecular-prompt-experiments\ndrwxr-xr-x   2 root root    4096 Feb 25 16:01 multi-agent\ndrwxr-xr-x 100 root root    4096 Feb 25 16:01 node_modules\n-rw-r--r--   1 root root   11622 Feb 25 16:01 NOVEL_AUTO_PUBLISH_GUIDE.md\ndrwxr-xr-x   6 root root    4096 Feb 28 11:54 novel-project\ndrwxr-xr-x   2 root root    4096 Feb 25 16:01 .openclaw\n-rw-r--r--   1 root root      40 Feb 25 16:01 .openclaw-last-check\n-rw-r--r--   1 root root    5169 Feb 27 20:19 .outreach-state.json\n-rw-r--r--   1 root root   24646 Feb 25 15:24 p2p-network-design.md\n-rw-r--r--   1 root root      56 Feb 25 16:01 package.json\n-rw-r--r--   1 root root   41021 Feb 25 16:01 package-lock.json\n-rw-r--r--   1 root root    3283 Mar  7 00:02 pattern-registry.md\ndrwxr-xr-x   2 root root    4096 Feb 25 16:01 pet-devices\ndrwxr-xr-x   2 root root    4096 Mar  7 10:30 .pi\ndrwxr-xr-x   4 root root    4096 Feb 25 16:01 projects\ndrwxr-xr-x   3 root root    4096 Feb 25 16:01 prompt-templates\n-rw-r--r--   1 root root     107 Feb 25 16:01 README.md\ndrwxr-xr-x   8 root root    4096 Feb 24 09:52 reproduction-molecular-cot\ndrwxr-xr-x   2 root root    4096 Feb 25 16:01 research\ndrwxr-xr-x   2 root root    4096 Feb 25 16:01 scripts\ndrwxr-xr-x   2 root root    4096 Feb 25 16:01 services\ndrwxr-xr-x   2 root root    4096 Feb 25 16:01 shared\ndrwxr-xr-x  47 root root    4096 Mar  7 04:33 skills\n-rw-r--r--   1 root root    3434 Mar  5 10:22 SOUL.md\ndrwxr-xr-x   6 root root    4096 Mar  5 00:35 Structured-Cognitive-Loop-Skills\ndrwxr-xr-x   6 root root    4096 Feb 25 16:01 subagents\ndrwxr-xr-x  11 root root   12288 Mar  7 08:45 s