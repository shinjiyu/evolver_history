# 创建方式: evolver-self-evolution (Round 269)\n\nset -euo pipefail\n\nWORKSPACE=\"/root/.openclaw/workspace\"\nLOG_DIR=\"$WORKSPACE/logs\"\nRATE_LIMIT_LOG=\"$LOG_DIR/rate-limit.log\"\nSTATE_FILE=\"$LOG_DIR/api-rate-state.json\"\nNGINX_LOG=\"/var/log/nginx/access.log\"\n\n# 日志函数\nlog() {\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $1\" | tee -a \"$RATE_LIMIT_LOG\"\n}\n\n# 获取当前小时\nget_current_hour() {\n    date +%H\n}\n\n# 判断是否为高峰期\nis_peak_hour() {\n    local hour=$(get_current_hour)\n    \n    # 高峰期定义\n    case \"$hour\" in\n        07|08|09|10|11|16|17|18)\n            return 0  # 是高峰期\n            ;;\n        *)\n            return 1  # 不是高峰期\n            ;;\n    esac\n}\n\n# 监控 429 错误\nmonitor_429_errors() {\n    local time_range=${1:-1h}\n    \n    log \"🔍 监控 429 错误（最近 $time_range）...\"\n    \n    # 从 session logs 中统计 429 错误\n    local count_429=$(find \"$WORKSPACE\" -name \"*.log\" -type f -mmin 60 2>/dev/null | \\\n        xargs grep -l \"429\\|Rate Limit\\|速率限制\" 2>/dev/null | wc -l)\n    \n    log \"📊 429 错误统计:\"\n    log \"  - 最近 1 小时: $count_429 次\"\n    \n    if [ \"$count_429\" -gt 10 ]; then\n        log \"⚠️  429 错误率过高，建议启用高峰模式\"\n        return 2\n    elif [ \"$count_429\" -gt 5 ]; then\n        log \"🟡 429 错误率偏高，注意监控\"\n        return 1\n    else\n        log \"✅ 429 错误率正常\"\n        return 0\n    fi\n}\n\n# 获取当前状态\nget_status() {\n    log \"📊 API Rate Limit 状态:\"\n    \n    if [ -f \"$STATE_FILE\" ]; then\n        cat \"$STATE_FILE\" | jq .\n    else\n        log \"  - 状态: 未初始化\"\n        log \"  - 模式: normal\"\n        log \"  - 间隔: 1s\"\n    fi\n    \n    # 检查是否为高峰期\n    if is_peak_hour; then\n        log \"  - 当前时段: 🟡 高峰期\"\n    else\n        log \"  - 当前时段: 🟢 正常\"\n    fi\n    \n    # 显示最近的 429 错误\n    monitor_429_errors 1h\n}\n\n# 更新状态文件\nupdate_state() {\n    local mode=$1\n    local interval=$2\n    \n    mkdir -p \"$(dirname \"$STATE_FILE\")\"\n    \n    cat > \"$STATE_FILE\" <<EOF\n{\n  \"mode\": \"$mode\",\n  \"interval\": $interval,\n  \"updated_at\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\n  \"peak_hour\": $(is_peak_hour && echo \"true\" || echo \"false\")\n}\nEOF\n    \n    log \"✅ 状态已更新: $mode, 间隔 ${interval}s\"\n}\n\n# 设置模式\nset_mode() {\n    local mode=${1:-normal}\n    \n    log \"🔄 设置模式: $mode\"\n    \n    case \"$mode\" in\n        normal)\n            update_state \"normal\" 1\n            log \"✅ 正常模式: 所有任务正常执行，间隔 1s\"\n            ;;\n        peak)\n            update_state \"peak\" 2\n            log \"✅ 高峰模式: 非紧急任务延迟，间隔 2s\"\n            ;;\n        emergency)\n            update_state \"emergency\" 5\n            log \"✅ 紧急模式: 仅执行关键任务，间隔 5s\"\n            ;;\n        *)\n            log \"❌ 未知模式: $mode\"\n            return 1\n            ;;\n    esac\n}\n\n# 自动调整\nauto_adjust() {\n    log \"🤖 自动调整请求频率...\"\n    \n    # 检查 429 错误率\n    local count_429=$(find \"$WORKSPACE\" -name \"*.log\" -type f -mmin 60 2>/dev/null | \\\n        xargs grep -l \"429\\|Rate Limit\\|速率限制\" 2>/dev/null | wc -l)\n    \n    # 检查是否为高峰期\n    if is_peak_hour; then\n        log \"🟡 当前为高峰期\"\n        \n        if [ \"$count_429\" -gt 10 ]; then\n            log \"🔴 429 错误率过高，启用紧急模式\"\n            set_mode emergency\n        elif [ \"$count_429\" -gt 5 ]; then\n            log \"🟡 429 错误率偏高，保持高峰模式\"\n            set_mode peak\n        else\n            log \"✅ 高峰期状态良好，使用高峰模式\"\n            set_mode peak\n        fi\n    else\n        log \"🟢 当前为正常时段\"\n        \n        if [ \"$count_429\" -gt 10 ]; then\n            log \"🟡 429 错误率偏高，启用高峰模式\"\n            set_mode peak\n        else\n            log \"✅ 正常状态\"\n            set_mode normal\n        fi\n    fi\n}\n\n# 生成报告\ngenerate_report() {\n    local report_file=\"$WORKSPACE/memory/rate-limit-report-$(date +%Y%m%d-%H%M).md\"\n    \n    log \"📊 生成 Rate Limit 报告: $report_file\"\n    \n    cat > \"$report_file\" <<EOF\n# API Rate Limit 管理报告\n\n**生成时间**: $(date '+%Y-%m-%d %H:%M:%S')\n\n## 当前状态\n\nEOF\n    \n    if [ -f \"$STATE_FILE\" ]; then\n        cat \"$STATE_FILE\" | jq -r 'to_entries | .[] | \"- **\\(.key)**: \\(.value)\"' >> \"$report_file\"\n    fi\n    \n    cat >> \"$report_file\" <<EOF\n\n## 高峰期定义\n\n- 早晨高峰: 07:00-09:00\n- 上午高峰: 10:00-12:00\n- 下午高峰: 16:00-18:00 (**最严重**)\n\n## 三级降级机制\n\n1. **正常模式**: 所有任务正常执行，间隔 1s\n2. **高峰模式**: 非紧急任务延迟，间隔 2s\n3. **紧急模式**: 仅执行关键任务，间隔 5s\n\n## 建议\n\n- 高峰期避免执行非紧急任务\n- 429 错误率 > 10 次/小时时启用紧急模式\n- 定期监控并调整策略\n\n---\n\n**报告生成者**: OpenClaw API Rate Limiter\n**下次检查**: $(date -d '+1 hour' '+%Y-%m-%d %H:%M:%S')\nEOF\n    \n    log \"✅ 报告生成完成\"\n}\n\n# 主函数\nmain() {\n    local action=${1:---status}\n    local param=${2:-}\n    \n    mkdir -p \"$LOG_DIR\"\n    \n    log \"🚀 API Rate Limiter 启动\"\n    log \"  - 动作: $action\"\n    \n    case \"$action\" in\n        --status)\n            get_status\n            ;;\n        --monitor)\n            monitor_429_errors \"${param:-1h}\"\n            ;;\n        --mode)\n            set_mode \"$param\"\n            ;;\n        --auto-adjust)\n            auto_adjust\n            ;;\n        --report)\n            generate_report\n            ;;\n        *)\n            echo \"用法: $0 {--status|--monitor [time]|--mode <mode>|--auto-adjust|--report}\"\n            echo \"  --status       查看当前状态\"\n            echo \"  --monitor      监控 429 错误\"\n            echo \"  --mode         设置模式 (normal/peak/emergency)\"\n            echo \"  --auto-adjust  自动调整\"\n            echo \"  --report       生成报告\"\n            exit 1\n            ;;\n    esac\n    \n    log \"✅ 完成\"\n}\n\n# 执行\nmain \"$@\"\n"}},{"type":"toolCall","id":"call_05ef8ff610284e8d84b47105","name":"exec","arguments":{"command":"chmod +x /root/.openclaw/workspace/evolver/fixes/api-rate-limiter.sh"}},{"type":"toolCall","id":"call_15718b5ef1a84587838d1eb9","name":"exec","arguments":{"command":"cd /root/.openclaw/workspace && bash evolver/fixes/api-rate-limiter.sh --status 2>&1 | head -30"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":2966,"output":3577,"cacheRead":55744