n    log \"✅ 检测完成: 发现 $threats_found 种扫描模式\"\n    \n    return $threats_found\n}\n\n# 检测高频请求\ndetect_high_frequency_requests() {\n    log \"🔍 检测高频请求...\"\n    \n    # 统计最近 1 小时的请求频率\n    local threshold=100\n    \n    awk -v threshold=\"$threshold\" '\n    {\n        ip = $1\n        count[ip]++\n    }\n    END {\n        for (ip in count) {\n            if (count[ip] > threshold) {\n                print ip, count[ip]\n            }\n        }\n    }\n    ' \"$NGINX_ACCESS_LOG\" 2>/dev/null | while read ip count; do\n        log \"⚠️  高频请求 IP: $ip ($count 次)\"\n        echo \"$ip\" >> \"$WORKSPACE/logs/suspicious-ips.txt\"\n    done\n    \n    log \"✅ 高频请求检测完成\"\n}\n\n# 检测 SQL 注入尝试\ndetect_sql_injection() {\n    log \"🔍 检测 SQL 注入尝试...\"\n    \n    local sql_patterns=(\n        \"SELECT.*FROM\"\n        \"UNION.*SELECT\"\n        \"DROP.*TABLE\"\n        \"INSERT.*INTO\"\n        \"UPDATE.*SET\"\n        \"DELETE.*FROM\"\n        \"OR.*1=1\"\n        \"AND.*1=1\"\n    )\n    \n    local injection_found=0\n    \n    for pattern in \"${sql_patterns[@]}\"; do\n        local count=$(grep -ci \"$pattern\" \"$NGINX_ACCESS_LOG\" 2>/dev/null || echo 0)\n        \n        if [ \"$count\" -gt 0 ]; then\n            log \"⚠️  发现 SQL 注入尝试: $count 次\"\n            ((injection_found++))\n        fi\n    done\n    \n    if [ \"$injection_found\" -eq 0 ]; then\n        log \"✅ 未发现 SQL 注入尝试\"\n    fi\n}\n\n# 检测路径遍历攻击\ndetect_path_traversal() {\n    log \"🔍 检测路径遍历攻击...\"\n    \n    local count=$(grep -c \"\\.\\./\" \"$NGINX_ACCESS_LOG\" 2>/dev/null || echo 0)\n    \n    if [ \"$count\" -gt 0 ]; then\n        log \"⚠️  发现路径遍历攻击: $count 次\"\n        \n        # 提取攻击 IP\n        grep \"\\.\\./\" \"$NGINX_ACCESS_LOG\" | \\\n            awk '{print $1}' | \\\n            sort | \\\n            uniq -c | \\\n            sort -rn | \\\n            head -5 | \\\n            while read count ip; do\n                log \"  🔴 攻击 IP: $ip ($count 次)\"\n                echo \"$ip\" >> \"$WORKSPACE/logs/suspicious-ips.txt\"\n            done\n    else\n        log \"✅ 未发现路径遍历攻击\"\n    fi\n}\n\n# 生成威胁报告\ngenerate_report() {\n    mkdir -p \"$REPORT_DIR\"\n    \n    local report_file=\"$REPORT_DIR/threat-report-$(date +%Y%m%d-%H%M).md\"\n    \n    log \"📊 生成威胁报告: $report_file\"\n    \n    cat > \"$report_file\" <<EOF\n# 威胁检测报告\n\n**生成时间**: $(date '+%Y-%m-%d %H:%M:%S')\n\n## 检测摘要\n\nEOF\n    \n    # 添加检测到的威胁\n    if [ -f \"$THREAT_LOG\" ]; then\n        echo \"### 最近检测到的威胁\" >> \"$report_file\"\n        echo \"\" >> \"$report_file\"\n        tail -50 \"$THREAT_LOG\" | grep \"⚠️\\|🔴\" >> \"$report_file\"\n    fi\n    \n    # 添加可疑 IP 列表\n    if [ -f \"$WORKSPACE/logs/suspicious-ips.txt\" ]; then\n        echo \"\" >> \"$report_file\"\n        echo \"### 可疑 IP 列表\" >> \"$report_file\"\n        echo \"\" >> \"$report_file\"\n        sort \"$WORKSPACE/logs/suspicious-ips.txt\" | uniq -c | sort -rn >> \"$report_file\"\n    fi\n    \n    log \"✅ 报告生成完成\"\n}\n\n# 主函数\nmain() {\n    local action=${1:---check}\n    local time_range=${2:-1h}\n    \n    mkdir -p \"$(dirname \"$THREAT_LOG\")\"\n    mkdir -p \"$REPORT_DIR\"\n    \n    log \"🚀 Threat Detector 启动\"\n    log \"  - 动作: $action\"\n    log \"  - 时间范围: $time_range\"\n    \n    case \"$action\" in\n        --check)\n            detect_sensitive_file_scans \"$time_range\"\n            detect_high_frequency_requests\n            detect_sql_injection\n            detect_path_traversal\n            ;;\n        --analyze)\n            detect_sensitive_file_scans \"$time_range\"\n            ;;\n        --report)\n            detect_sensitive_file_scans \"$time_range\"\n            detect_high_frequency_requests\n            detect_sql_injection\n            detect_path_traversal\n            generate_report\n            ;;\n        *)\n            echo \"用法: $0 {--check|--analyze [time]|--report}\"\n            echo \"  --check    执行所有检测\"\n            echo \"  --analyze  分析指定时间范围（默认 1h）\"\n            echo \"  --report  