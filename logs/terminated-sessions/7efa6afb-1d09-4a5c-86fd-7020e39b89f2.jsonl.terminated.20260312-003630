函数\nlog() {\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $1\" | tee -a \"$INTEGRATION_LOG\"\n}\n\n# 扫描未集成的工具\nscan_tools() {\n    log \"🔍 扫描 evolver/fixes/ 目录...\"\n    \n    local tools=(\n        \"api-health-checker.sh\"\n        \"api-rate-limiter.sh\"\n        \"memory-archiver.sh\"\n        \"threat-detector.sh\"\n        \"ip-blocker.sh\"\n        \"nginx-security-enhance.sh\"\n    )\n    \n    local found=0\n    local integrated=0\n    \n    for tool in \"${tools[@]}\"; do\n        local tool_path=\"$FIXES_DIR/$tool\"\n        \n        if [ -f \"$tool_path\" ]; then\n            ((found++))\n            \n            # 检查是否已集成到 cron\n            if crontab -l 2>/dev/null | grep -q \"$tool\"; then\n                log \"  ✅ $tool - 已集成\"\n                ((integrated++))\n            else\n                log \"  ⚠️  $tool - 未集成\"\n            fi\n        fi\n    done\n    \n    log \"📊 扫描结果: 发现 $found 个工具，已集成 $integrated 个\"\n    \n    return $((found - integrated))\n}\n\n# 集成工具到 cron\nintegrate_tools() {\n    log \"🔧 开始集成工具到 cron...\"\n    \n    # 定义要添加的 cron 任务\n    local cron_tasks=(\n        \"# API 健康检查（每小时）\"\n        \"0 * * * * $FIXES_DIR/api-health-checker.sh --check >> $WORKSPACE/logs/api-health.log 2>&1\"\n        \"\"\n        \"# API Rate Limit 自动调整（每小时）\"\n        \"0 * * * * $FIXES_DIR/api-rate-limiter.sh --auto-adjust >> $WORKSPACE/logs/rate-limit.log 2>&1\"\n        \"\"\n        \"# 威胁检测（每小时）\"\n        \"0 * * * * $FIXES_DIR/threat-detector.sh --check >> $WORKSPACE/logs/threats.log 2>&1\"\n        \"\"\n        \"# Memory 归档（每周日凌晨 2 点）\"\n        \"0 2 * * 0 $FIXES_DIR/memory-archiver.sh --archive 30 --force >> $WORKSPACE/logs/memory-archiver.log 2>&1\"\n    )\n    \n    # 备份当前 crontab\n    local backup_file=\"/tmp/crontab.backup.$(date +%Y%m%d-%H%M%S)\"\n    crontab -l > \"$backup_file\" 2>/dev/null || true\n    log \"💾 Crontab 备份: $backup_file\"\n    \n    # 添加新任务\n    local added=0\n    for task in \"${cron_tasks[@]}\"; do\n        if [ -n \"$task\" ]; then\n            # 跳过注释行，只检查实际任务\n            if [[ \"$task\" != \\#* ]]; then\n                # 检查是否已存在\n                if ! crontab -l 2>/dev/null | grep -F \"$task\" > /dev/null; then\n                    echo \"$task\" | crontab -\n                    ((added++))\n                fi\n            fi\n        fi\n    done\n    \n    log \"✅ 添加了 $added 个新的 cron 任务\"\n    \n    # 显示当前 crontab\n    log \"📋 当前 crontab:\"\n    crontab -l | grep -v \"^$\" | while read line; do\n        log \"  $line\"\n    done\n}\n\n# 验证集成状态\nverify_integration() {\n    log \"🔍 验证集成状态...\"\n    \n    local tools=(\n        \"api-health-checker.sh\"\n        \"api-rate-limiter.sh\"\n        \"memory-archiver.sh\"\n        \"threat-detector.sh\"\n    )\n    \n    local all_integrated=true\n    \n    for tool in \"${tools[@]}\"; do\n        if crontab -l 2>/dev/null | grep -q \"$tool\"; then\n            log \"  ✅ $tool - 已集成\"\n        else\n            log \"  ❌ $tool - 未集成\"\n            all_integrated=false\n        fi\n    done\n    \n    if [ \"$all_integrated\" = true ]; then\n        log \"✅ 所有工具已成功集成\"\n        return 0\n    else\n        log \"⚠️  部分工具未集成，请运行 --integrate\"\n        return 1\n    fi\n}\n\n# 查看工具状态\nshow_status() {\n    log \"📊 工具集成状态:\"\n    \n    local tools=(\n        \"api-health-checker.sh:API 健康检查\"\n        \"api-rate-limiter.sh:API Rate Limit 管理\"\n        \"memory-archiver.sh:Memory 自动归档\"\n        \"threat-detector.sh:威胁检测\"\n        \"ip-blocker.sh:IP 封禁\"\n        \"nginx-security-enhance.sh:Nginx 安全增强\"\n    )\n    \n    for tool_info in \"${tools[@]}\"; do\n        IFS=':' read -r tool name <<< \"$tool_info\"\n        local tool_path=\"$FIXES_DIR/$tool\"\n        \n        if [ -f \"$tool_path\" ]; then\n            if [ -x \"$tool_path\" ]; then\n                local cron_status=\"未集成\"\n                if crontab -l 2>/dev/null | grep -q \"$tool\"; then\n                    cron_status=\"✅ 已集成\"\n                else\n                    cron_status=\"⚠️  未集成\"\n                fi\n                log \"  $name: $cron_status\"\n            else\n                log \"  $name: ❌ 不可执行\"\n            fi\n        else\n            log \"  $name: ❌ 不存在\"\n        fi\n    done\n}\n\n# 更新状态文件\nupdate_state() {\n    mkdir -p \"$(dirname \"$INTEGRATION_STATE\")\"\n    \n    local integrated_count=$(crontab -l 2>/dev/null | grep -c \"evolver/fixes\" || echo 0)\n    \n    cat > \"$INTEGRATION_STATE\" <<EOF\n{\n  \"last_scan\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\n  \"integrated_tools\": $integrated_count,\n  \"status\": \"$([ \"$integrated_count\" -gt 0 ] && echo \"active\" || echo \"inactive\")\"\n}\nEOF\n    \n    log \"✅ 状态已更新: $INTEGRATION_STATE\"\n}\n\n# 主函数\nmain() {\n    local action=${1:---status}\n    \n    mkdir -p \"$(dirname \"$INTEGRATION_LOG\")\"\n    \n    log \"🚀 Cron Integration Manager 启动\"\n    log \"  - 动作: $action\"\n    \n    case \"$action\" in\n        --scan)\n            scan_tools\n            ;;\n        --integrate)\n            integrate_tools\n            verify_integration\n            update_state\n            ;;\n        --verify)\n            verify_integration\n            ;;\n        --status)\n            show_status\n            ;;\n        *)\n            echo \"用法: $0 {--scan|--integrate|--verify|--status}\"\n            echo \"  --scan      扫描未集成的工具\"\n            echo \"  --integrate 集成所有工具到 cron\"\n            echo \"  --verify    验证集成状态\"\n            echo \"  --status    查看工具状态\"\n            exit 1\n            ;;\n    esac\n    \n    log \"✅ 完成\"\n}\n\n# 执行\nmain \"$@\"\n"}},{"type":"toolCall","id":"call_b615f3075ab34d9a97c778d6","name":"exec","arguments":{"command":"chmod +x /root/.openclaw/workspace/evolver/fixes/cron-integration.sh"}},{"type":"toolCall","id":"call_26a2c592e67e43ee8a3425fb","name":"exec","arguments":{"command":"cd /root/.openclaw/workspace && bash evolver/fixes/cron-integration.sh --status 2>&1 | head -30"}}],"api":"openai-completions