rotection \"1; mode=block\" always;\nadd_header Referrer-Policy \"strict-origin-when-cross-origin\" always;\nadd_header Content-Security-Policy \"default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';\" always;\n\n# 限制请求体大小\nclient_max_body_size 10M;\n\n# 限制请求频率（需要在 http 块中定义 limit_req_zone）\n# limit_req zone=one burst=10 nodelay;\n\n# 隐藏 Nginx 版本\nserver_tokens off;\nEOF\n    \n    log \"✅ 安全配置已创建: $SECURITY_CONF\"\n}\n\n# 验证配置\nverify_config() {\n    log \"🔍 验证 Nginx 配置...\"\n    \n    if sudo nginx -t 2>&1; then\n        log \"✅ 配置验证通过\"\n        return 0\n    else\n        log \"❌ 配置验证失败\"\n        return 1\n    fi\n}\n\n# 重启 Nginx\nrestart_nginx() {\n    log \"🔄 重启 Nginx...\"\n    \n    if sudo systemctl reload nginx 2>&1; then\n        log \"✅ Nginx 已重启\"\n        return 0\n    else\n        log \"❌ Nginx 重启失败\"\n        return 1\n    fi\n}\n\n# 回滚配置\nrollback_config() {\n    log \"⏪ 回滚配置...\"\n    \n    local latest_backup=$(ls -t \"$BACKUP_DIR\"/nginx.conf.*.bak 2>/dev/null | head -1)\n    \n    if [ -z \"$latest_backup\" ]; then\n        log \"⚠️  未找到备份文件\"\n        return 1\n    fi\n    \n    log \"📂 使用备份: $latest_backup\"\n    \n    cp \"$latest_backup\" \"$NGINX_CONF\"\n    \n    if verify_config; then\n        restart_nginx\n        log \"✅ 回滚完成\"\n    else\n        log \"❌ 回滚失败\"\n        return 1\n    fi\n}\n\n# 主函数\nmain() {\n    local action=${1:---apply}\n    \n    log \"🚀 Nginx Security Enhancer 启动\"\n    log \"  - 动作: $action\"\n    \n    case \"$action\" in\n        --apply)\n            backup_config\n            apply_security_config\n            if verify_config; then\n                restart_nginx\n                log \"✅ 安全配置已应用\"\n            else\n                log \"❌ 配置验证失败，请检查配置\"\n                exit 1\n            fi\n            ;;\n        --verify)\n            verify_config\n            ;;\n        --rollback)\n            rollback_config\n            ;;\n        --backup)\n     