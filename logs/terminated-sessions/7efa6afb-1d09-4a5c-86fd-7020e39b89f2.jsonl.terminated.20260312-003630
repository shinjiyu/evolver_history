onsecutive_failures() {\n    if [ -f \"$STATE_FILE\" ]; then\n        jq -r '.consecutive_failures // 0' \"$STATE_FILE\" 2>/dev/null || echo \"0\"\n    else\n        echo \"0\"\n    fi\n}\n\n# 检查是否需要紧急行动\ncheck_emergency() {\n    local failures=$(get_consecutive_failures)\n    \n    if [ \"$failures\" -ge 3 ]; then\n        alert \"CRITICAL\" \"API 连续失败 $failures 次，需要立即检查\"\n        return 1\n    fi\n    \n    return 0\n}\n\n# 生成健康报告\ngenerate_report() {\n    local report_file=\"$WORKSPACE/memory/api-health-report-$(date +%Y%m%d-%H%M).md\"\n    \n    cat > \"$report_file\" <<EOF\n# API 健康检查报告\n\n**生成时间**: $(date '+%Y-%m-%d %H:%M:%S')\n\n## 检查结果\n\nEOF\n    \n    if [ -f \"$STATE_FILE\" ]; then\n        cat \"$STATE_FILE\" | jq -r 'to_entries | .[] | \"- **\\(.key)**: \\(.value)\"' >> \"$report_file\"\n    else\n        echo \"- 状态: 未检查\" >> \"$report_file\"\n    fi\n    \n    if [ -f \"$ALERT_FILE\" ]; then\n        echo \"\" >> \"$report_file\"\n        echo \"## 最近告警\" >> \"$report_file\"\n        echo \"\" >> \"$report_file\"\n        tail -10 \"$ALERT_FILE\" >> \"$report_file\"\n    fi\n    \n    log \"📊 健康报告已生成: $report_file\"\n}\n\n# 主函数\nmain() {\n    local action=${1:---check}\n    \n    mkdir -p \"$(dirname \"$LOG_FILE\")\"\n    \n    log \"🚀 API Health Checker 启动\"\n    \n    case \"$action\" in\n        --check)\n            test_api\n            check_emergency\n            ;;\n        --report)\n            test_api\n            generate_report\n            ;;\n        --status)\n            if [ -f \"$STATE_FILE\" ]; then\n                cat \"$STATE_FILE\" | jq .\n            else\n                echo '{\"status\": \"unknown\", \"message\": \"No health check performed yet\"}'\n            fi\n            ;;\n        *)\n            echo \"用法: $0 {--check|--report|--status}\"\n            exit 1\n            ;;\n    esac\n}\n\n# 执行\nmain \"$@\"\n"}},{"type":"toolCall","id":"call_a17732c8f08845238d3eb628","name":"exec","arguments":{"command":"chmod +x