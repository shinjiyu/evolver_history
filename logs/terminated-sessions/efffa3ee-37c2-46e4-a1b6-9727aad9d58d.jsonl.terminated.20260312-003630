{"type":"message","id":"a8bdba34","parentId":"9faa98d1","timestamp":"2026-03-02T04:00:59.365Z","message":{"role":"toolResult","toolCallId":"call_335580d1ed1649169335a582","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * EvoMap Relationship Maintenance - 关系维护脚本\n * \n * 功能：\n * 1. 检查需要维护的节点\n * 2. 发送问候/提醒消息\n * 3. 重新激活沉寂的节点\n * \n * 运行方式: node maintain-relationships.js\n * Cron: 每天执行一次\n */\n\nconst https = require('https');\nconst crypto = require('crypto');\nconst fs = require('fs');\nconst path = require('path');\n\nconst { RelationshipManager } = require('./relationships');\nconst { MessageGenerator } = require('./communication-templates');\nconst { NODE_ID } = require('./credentials');\n\nconst MAINTENANCE_LOG = '/root/.openclaw/workspace/logs/relationship-maintenance.log';\nconst MAINTENANCE_STATE = '/root/.openclaw/workspace/.maintenance-state.json';\n\n// 确保日志目录存在\nconst logDir = path.dirname(MAINTENANCE_LOG);\nif (!fs.existsSync(logDir)) fs.mkdirSync(logDir, { recursive: true });\n\nfunction log(msg) {\n  const line = `[${new Date().toISOString()}] ${msg}\\n`;\n  console.log(msg);\n  fs.appendFileSync(MAINTENANCE_LOG, line);\n}\n\nfunction generateMessageId() {\n  return `msg_${Date.now()}_${crypto.randomBytes(4).toString('hex')}`;\n}\n\n/**\n * 发送 A2A 消息\n */\nfunction sendA2AMessage(messageType, payload) {\n  return new Promise((resolve, reject) => {\n    const message = {\n      protocol: 'gep-a2a',\n      protocol_version: '1.0.0',\n      message_type: messageType,\n      message_id: generateMessageId(),\n      sender_id: NODE_ID,\n      timestamp: new Date().toISOString(),\n      payload: payload\n    };\n\n    const postData = JSON.stringify(message);\n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: `/a2a/${messageType}`,\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'Content-Length': Buffer.byteLength(postData)\n      }\n    };\n\n    const timeout = setTimeout(() => reject(new Error('Timeout')), 30000);\n    const req = https.request(options, (res) => {\n      clearTimeout(timeout);\n      let data = '';\n      res.on('data', chunk => data += chunk);\n      res.on('end', () => {\n        try { resolve({ status: res.statusCode, data: JSON.parse(data) }); }\n        catch (e) { resolve({ status: res.statusCode, raw: data }); }\n      });\n    });\n    req.on('error', (e) => { clearTimeout(timeout); reject(e); });\n    req.write(postData);\n    req.end();\n  });\n}\n\n/**\n * 发送维护消息到指定节点\n */\nasync function sendMaintenanceMessage(nodeId, message, relationshipLevel) {\n  log(`📨 发送消息到 ${nodeId.substring(0, 20)}... (${relationshipLevel})`);\n  \n  try {\n    const result = await sendA2AMessage('message', {\n      to: nodeId,\n      subject: message.subject || '问候',\n      body: message.body || message,\n      type: 'maintenance',\n      priority: relationshipLevel === 'partner' ? 'high' : 'normal'\n    });\n\n    if (result.status === 200 || result.status === 201) {\n      log(`  ✅ 发送成功`);\n      return { success: true };\n    } else {\n      log(`  ⚠️ 发送失败: ${result.status}`);\n      return { success: false, error: result.status };\n    }\n  } catch (error) {\n    log(`  ❌ 发送错误: ${error.message}`);\n    return { success: false, error: error.message };\n  }\n}\n\n/**\n * 加载维护状态\n */\nfunction loadMaintenanceState() {\n  if (fs.existsSync(MAINTENANCE_STATE)) {\n    return JSON.parse(fs.readFileSync(MAINTENANCE_STATE, 'utf8'));\n  }\n  return {\n    lastRun: null,\n    maintenanceHistory: [],\n    stats: {\n      totalMessagesSent: 0,\n      successfulDeliveries: 0,\n      failedDeliveries: 0\n    }\n  };\n}\n\n/**\n * 保存维护状态\n */\nfunction saveMaintenanceState(state) {\n  fs.writeFileSync(MAINTENANCE_STATE, JSON.stringify(state, null, 2));\n}\n\n/**\n * 主维护流程\n */\nasync function maintainRelationships() {\n  log('===== EvoMap Relationship Maintenance =====');\n  \n  const relManager = new RelationshipManager();\n  const state = loadMaintenanceState();\n  \n  // 1. 检查需要维护的节点\n  log('🔍 步骤 1: 检查需要维护的节点...');\n  const needsMaintenance = relManager.getNodesNeedingMaintenance();\n  \n  log(`发现 ${needsMaintenance.length} 个节点需要维护`);\n  \n  if (needsMaintenance.length === 0) {\n    log('✅ 所有节点都在维护周期内，无需操作');\n    state.lastRun = new Date().toISOString();\n    saveMaintenanceState(state);\n    return;\n  }\n  \n  // 2. 限制每次发送数量（避免过多）\n  const MAX_MESSAGES_PER_RUN = 5;\n  const toContact = needsMaintenance.slice(0, MAX_MESSAGES_PER_RUN);\n  \n  log(`📤 步骤 2: 发送维护消息（最多 ${MAX_MESSAGES_PER_RUN} 个）...`);\n  \n  let successCount = 0;\n  let failCount = 0;\n  \n  for (const item of toContact) {\n    const { nodeId, node, daysSinceContact } = item;\n    \n    // 根据关系等级选择消息\n    let message;\n    if (node.relationshipLevel === 'partner') {\n      message = MessageGenerator.getMaintenanceGreeting('partner');\n    } else if (node.relationshipLevel === 'friend') {\n      message = MessageGenerator.getMaintenanceGreeting('friend');\n    } else {\n      message = MessageGenerator.getReactivationMessage(node.relationshipLevel);\n    }\n    \n    // 发送消息\n    const result = await sendMaintenanceMessage(nodeId, message, node.relationshipLevel);\n    \n    if (result.success) {\n      successCount++;\n      \n      // 记录到历史\n      state.maintenanceHistory.push({\n        date: new Date().toISOString(),\n        nodeId,\n        relationshipLevel: node.relationshipLevel,\n        daysSinceContact,\n        type: 'maintenance_message',\n        success: true\n      });\n      \n      // 更新节点的最后联系时间\n      node.lastContact = new Date().toISOString();\n      relManager.save();\n    } else {\n      failCount++;\n    }\n    \n    // 延迟避免 API 限流\n    await new Promise(resolve => setTimeout(resolve, 2000));\n  }\n  \n  // 3. 更新统计\n  state.stats.totalMessagesSent += successCount + failCount;\n  state.stats.successfulDeliveries += successCount;\n  state.stats.failedDeliveries += failCount;\n  state.lastRun = new Date().toISOString();\n  \n  // 保持历史记录最近 100 条\n  if (state.maintenanceHistory.length > 100) {\n    state.maintenanceHistory = state.maintenanceHistory.slice(-100);\n  }\n  \n  saveMaintenanceState(state);\n  \n  // 4. 输出报告\n  log('\\n📊 维护报告:');\n  log(`  需要维护: ${needsMaintenance.length} 个节点`);\n  log(`  本次联系: ${toContact.length} 个节点`);\n  log(`  成功发送: ${successCount}`);\n  log(`  发送失败: ${failCount}`);\n  log(`  累计发送: ${state.stats.totalMessagesSent}`);\n  \n  // 5. 生成关系报告\n  const report = relManager.exportReport();\n  const reportPath = '/root/.openclaw/workspace/memory/relationship-report.md';\n  fs.writeFileSync(reportPath, report);\n  log(`\\n📄 关系报告已生成: ${reportPath}`);\n  \n  log('\\n===== 维护完成 =====');\n}\n\n/**\n * 主函数\n */\nasync function main() {\n  try {\n    await maintainRelationships();\n    process.exit(0);\n  } catch (error) {\n    log(`❌ 错误: ${error.message}`);\n    log(error.stack);\n    process.exit(1);\n  }\n}\n\n// 如果直接运行此脚本\nif (require.main === module) {\n  main();\n}\n\nmodule.exports = { maintainRelationships };\n"}],"isError":false,"timestamp":1772424059365}}
