Emitter } = require('events');\\n\\nclass Gossip extends EventEmitter {\\n  constructor(options = {}) {\\n    super();\\n    this.nodeId = options.nodeId;\\n    this.fanout = options.fanout || 3; // 每次传播给几个节点\\n    this.maxHops = options.maxHops || 10; // 最大跳数\\n    this.messageCache = new Map(); // 消息缓存，防止重复\\n    this.cacheSize = options.cacheSize || 1000;\\n    this.cacheTTL = options.cacheTTL || 300000; // 5分钟\\n  }\\n\\n  /**\\n   * 广播消息\\n   */\\n  broadcast(message, excludePeers = []) {\\n    const messageId = message.id || this._generateId();\\n    \\n    // 检查是否已处理过\\n    if (this.messageCache.has(messageId)) {\\n      return messageId;\\n    }\\n    \\n    // 缓存消息\\n    this._cacheMessage(messageId, message);\\n    \\n    // 设置消息元数据\\n    message.id = messageId;\\n    message.hops = (message.hops || 0) + 1;\\n    message.origin = message.origin || this.nodeId;\\n    message.timestamp = message.timestamp || Date.now();\\n    \\n    // 检查跳数\\n    if (message.hops > this.maxHops) {\\n      return messageId;\\n    }\\n    \\n    // 选择传播目标\\n    const targets = this._selectTargets(excludePeers);\\n    \\n    // 发送给选中的节点\\n    for (const peer of targets) {\\n      this.emit('gossip:send', peer, message);\\n    }\\n    \\n    // 触发本地接收事件\\n    this.emit('gossip:received', message);\\n    \\n    return messageId;\\n  }\\n\\n  /**\\n   * 接收并转发消息\\n   */\\n  receive(message, fromPeer) {\\n    const messageId = message.id;\\n    \\n    // 检查是否已处理\\n    if (this.messageCache.has(messageId)) {\\n      return false;\\n    }\\n    \\n    // 缓存消息\\n    this._cacheMessage(messageId, message);\\n    \\n    // 触发接收事件\\n    this.emit('gossip:received', message);\\n    \\n    // 增加跳数并转发\\n    message.hops = (message.hops || 0) + 1;\\n    \\n    if (message.hops <= this.maxHops) {\\n      const targets = this._selectTargets([fromPeer]);\\n      for (const peer of targets) {\\n        this.emit('gossip:send', peer, message);\\n      }\\n      this.emit('gossip:propagated', message);\\n    }\\n    \\n    return true;\\n  }\\n\\n  /**\\n   * 选择传播目标\\n   */\\n  _selectTargets(excludePeers = []) {\\n    // 由外部提供 peer 列表\\n    this.emit('gossip:selectTargets', excludePeers);\\n    return []; // 返回选中的节点\\n  }\\n\\n  /**\\n   * 缓存消息\\n   */\\n  _cacheMessage(id, message) {\\n    // 清理过期缓存\\n    if (this.messageCache.size >= this.cacheSize) {\\n      this._cleanupCache();\\n    }\\n    \\n    this.messageCache.set(id, {\\n      message,\\n      timestamp: Date.now()\\n    });\\n  }\\n\\n  /**\\n   * 清理过期缓存\\n   */\\n  _cleanupCache() {\\n    const now = Date.now();\\n    for (const [id, entry] of this.messageCache) {\\n      if (now - entry.timestamp > this.cacheTTL) {\\n        this.messageCache.delete(id);\\n      }\\n    }\\n  }\\n\\n  /**\\n   * 生成消息ID\\n   */\\n  _generateId() {\\n    return `${this.nodeId}-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;\\n  }\\n\\n  /**\\n   * 获取统计信息\\n   */\\n  getStats() {\\n    return {\\n      cacheSize: this.messageCache.size,\\n      fanout: this.fanout,\\n      maxHops: this.maxHops\\n    };\\n  }\\n}\\n\\nmodule.exports = Gossip;\\n\"}},{\"type\":\"toolCall\",\"id\":\"call_0e474c560769495c9ce8cb89\",\"name\":\"write\",\"arguments\":{\"path\":\"/root/.openclaw/workspace/agent-network-protocol/src/routing/DHT.js\",\"content\":\"/**\\n * DHT - 分布式哈希表\\n * \\n * 基于 Kademlia 协议实现\\n */\\n\\nconst { EventEmitter } = require('events');\\n\\nclass DHT extends EventEmitter {\\n  constructor(options = {}) {\\n    super();\\n    this.nodeId = options.nodeId || this._generateId();\\n    this.kbuckets = new Array(160); // 160 个 k-bucket (SHA-1)\\n    this.k = options.k || 20; // 每个 bucket 最多 k 个节点\\n    this.data = new Map(); // 本地存储的数据\\n    this.replication = options.replication || 3;\\n  }\\n\\n  /**\\n   * 存储 key-value\\n   */\\n  async put(key, value, ttl = 3600000) {\\n    const keyHash = this._hash(key);\\n    const closest = this._findClosestNodes(keyHash);\\n    \\n    // 存储到本地\\n    this.data.set(keyHash, {\\n      value,\\n      ttl,\\n      timestamp: Date.now()\\n    });\\n    \\n    // 存储到最近的节点\\n    for (const node of closest.slice(0, this.replication)) {\\n      this.emit('dht:store', node, keyHash, value, ttl);\\n    }\\n    \\n    this.emit('dht:put', key, value);\\n    return keyHash;\\n  }\\n\\n  /**\\n   * 获取 value\\n   */\\n  async get(key) {\\n    const keyHash = this._hash(key);\\n    \\n    // 先查本地\\n    const local = this.data.get(keyHash);\\n    if (local && Date.now() - local.timestamp < local.ttl) {\\n      this.emit('dht:get', key, local.value, true);\\n      return local.value;\\n    }\\n    \\n    // 查询最近的节点\\n    const closest = this._findClosestNodes(keyHash);\\n    this.emit('dht:lookup', closest, keyHash);\\n    \\n    this.emit('dht:get', key, null, false);\\n    return null;\\n  }\\n\\n  /**\\n   * 添加节点到路由表\\n   */\\n  addNode(nodeInfo) {\\n    const distance = this._distance(this.nodeId, nodeInfo.id);\\n    const bucketIndex = this._getBucketIndex(distance);\\n    \\n    if (!this.kbuckets[bucketIndex]) {\\n      this.kbuckets[bucketIndex] = [];\\n    }\\n    \\n    const bucket = this.kbuckets[bucketIndex];\\n    \\n    // 检查是否已存在\\n    const existingIndex = bucket.findIndex(n => n.id === nodeInfo.id);\\n    if (existingIndex >= 0) {\\n      // 移到末尾 (最近使用)\\n      bucket.splice(existingIndex, 1);\\n      bucket.push(nodeInfo);\\n    } else if (bucket.length < this.k) {\\n      bucket.push(nodeInfo);\\n      this.emit('dht:node:added', nodeInfo);\\n    } else {\\n      // bucket 已满，需要检查最久未使用的节点\\n      this.emit('dht:bucket:full', bucketIndex, nodeInfo);\\n    }\\n  }\\n\\n  /**\\n   * 移除节点\\n   */\\n  removeNode(nodeId) {\\n    const distance = this._distance(this.nodeId, nodeId);\\n    const bucketIndex = this._getBucketIndex(distance);\\n    const bucket = this.kbuckets[bucketIndex];\\n    \\n    if (bucket) {\\n      const index = bucket.findIndex(n => n.id === nodeId);\\n      if (index >= 0) {\\n        const removed = bucket.splice(index, 1)[0];\\n        this.emit('dht:node:removed', removed);\\n      }\\n    }\\n  }\\n\\n  /**\\n   * 查找最近的节点\\n   */\\n  _findClosestNodes(targetId, count = this.k) {\\n    const allNodes = [];\\n    \\n    for (const bucket of this.kbuckets) {\\n      if (bucket) {\\n        allNodes.push(...bucket);\\n      }\\n    }\\n    \\n    // 按距离排序\\n    allNodes.sort((a, b) => {\\n      const distA = this._distance(a.id, targetId);\\n      const distB = this._distance(b.id, targetId);\\n      return distA < distB ? -1 : 1;\\n    });\\n    \\n    return allNodes.slice(0, count);\\n  }\\n\\n  /**\\n   * 计算异或距离\\n   */\\n  _distance(id1, id2) {\\n    let result = BigInt(0);\\n    for (let i = 0; i < Math.min(id1.length, id2.length); i++) {\\n      result = (result << BigInt(8)) | BigInt(id1.charCodeAt(i) ^ id2.charCodeAt(i));\\n    }\\n    return result;\\n  }\\n\\n  /**\\n   * 获取 bucket 索引\\n   */\\n  _getBucketIndex(distance) {\\n    let index = 0;\\n    while (distance > BigInt(0)) {\\n      distance = distance >> BigInt(1);\\n      index++;\\n    }\\n    return Math.min(index, 159);\\n  }\\n\\n  /**\\n   * 哈希函数\\n   */\\n  _hash(key) {\\n    // 简化版哈希，实际应使用 SHA-1\\n    let hash = 0;\\n    for (let i = 0; i < key.length; i++) {\\n      const char = key.charCodeAt(i);\\n      hash = ((hash << 5) - hash) + char;\\n      hash = hash & hash;\\n    }\\n    return Math.abs(hash).toString(16).padStart(40, '0');\\n  }\\n\\n  /**\\n   * 生成节点 ID\\n   */\\n  _generateId() {\\n    return Math.random().toString(16).slice(2) + Date.now().toString(16);\\n  }\\n\\n  /**\\n   * 获取路由表统计\\n   */\\n  getStats() {\\n    let totalNodes = 0;\\n    let usedBuckets = 0;\\n    \\n    for (const bucket of this.kbuckets) {\\n      if (bucket && bucket.length > 0) {\\n        totalNodes += bucket.length;\\n        usedBuckets++;\\n      }\\n    }\\n    \\n    return {\\n      nodeId: this.nodeId,\\n      totalNodes,\\n      usedBuckets,\\n      storedKeys: this.data.size\\n    };\\n  }\\n}\\n\\nmodule.exports = DHT;\\n\"}},{\"type\":\"toolCall\",\"id\":\"call_feae37d4a0b347f3b48b5216\",\"name\":\"write\",\"arguments\":{\"path\":\"/root/.openclaw/workspace/agent-network-protocol/src/routing/KBucket.js\",\"content\":\"/**\\n * KBucket - K-Bucket 数据结构\\n * \\n * 用于 Kademlia DHT 的路由表存储\\n */\\n\\nclass KBucket {\\n  constructor(options = {}) {\\n    this.localNodeId = options.localNodeId;\\n    this.k = options.k || 20; // 每个 bucket 最大节点数\\n    this.root = this._createNode();\\n  }\\n\\n  /**\\n   * 创建内部节点\\n   */\\n  _createNode() {\\n    return {\\n      contacts: [],\\n      donotSplit: false,\\n      left: null,\\n      right: null\\n    };\\n  }\\n\\n  /**\\n   * 添加联系人\\n   */\\n  add(contact) {\\n    const bitIndex = 0;\\n    return this._add(contact, this.root, bitIndex);\\n  }\\n\\n  /**\\n   * 内部添加逻辑\\n   */\\n  _add(contact, node, bitIndex) {\\n    // 叶子节点\\n    if (this._isLeaf(node)) {\\n      // 检查是否已存在\\n      const index = node.contacts.findIndex(c => c.id === contact.id);\\n      if (index >= 0) {\\n        // 移到末尾\\n        node.contacts.splice(index, 1);\\n        node.contacts.push(contact);\\n        return { added: false, updated: true };\\n      }\\n      \\n      if (node.contacts.length < this.k) {\\n        node.contacts.push(contact);\\n        return { added: true };\\n      }\\n      \\n      // bucket 已满\\n      if (node.donotSplit) {\\n        return { added: false, full: true };\\n      }\\n      \\n      // 分裂 bucket\\n      this._split(node, bitIndex);\\n      return this._add(contact, this.root, bitIndex);\\n    }\\n    \\n    // 内部节点，递归\\n    const bit = this._getBit(contact.id, bitIndex);\\n    if (bit === 0) {\\n      return this._add(contact, node.left, bitIndex + 1);\\n    } else {\\n      return this._add(contact, node.right, bitIndex + 1);\\n    }\\n  }\\n\\n  /**\\n   * 移除联系人\\n   */\\n  remove(id) {\\n    return this._remove(id, this.root, 0);\\n  }\\n\\n  _remove(id, node, bitIndex) {\\n    if (this._isLeaf(node)) {\\n      const index = node.contacts.findIndex(c => c.id === id);\\n      if (index >= 0) {\\n        node.contacts.splice(index, 1);\\n        return true;\\n      }\\n      return false;\\n    }\\n    \\n    const bit = this._getBit(id, bitIndex);\\n    if (bit === 0) {\\n      return this._remove(id, node.left, bitIndex + 1);\\n    } else {\\n      return this._remove(id, node.right, bitIndex + 1);\\n    }\\n  }\\n\\n  /**\\n   * 获取联系人\\n   */\\n  get(id) {\\n    return this._get(id, this.root, 0);\\n  }\\n\\n  _get(id, node, bitIndex) {\\n    if (this._isLeaf(node)) {\\n      return node.contacts.find(c => c.id === id) || null;\\n    }\\n    \\n    const bit = this._getBit(id, bitIndex);\\n    if (bit === 0) {\\n      return this._get(id, node.left, bitIndex + 1);\\n    } else {\\n      return this._get(id, node.right, bitIndex + 1);\\n    }\\n  }\\n\\n  /**\\n   * 查找最近的节点\\n   */\\n  closest(id, n = this.k) {\\n    const contacts = [];\\n    this._closest(id, this.root, 0, contacts, n);\\n    return contacts;\\n  }\\n\\n  _closest(id, node, bitIndex, contacts, n) {\\n    if (this._isLeaf(node)) {\\n      const sorted = node.contacts\\n        .map(c => ({ contact: c, distance: this._distance(id, c.id) }))\\n        .sort((a, b) => a.distance < b.distance ? -1 : 1);\\n      \\n      for (const item of sorted) {\\n        if (contacts.length >= n) break;\\n        contacts.push(item.contact);\\n      }\\n      return;\\n    }\\n    \\n    const bit = this._getBit(id, bitIndex);\\n    const first = bit === 0 ? node.left : node.right;\\n    const second = bit === 0 ? node.right : node.left;\\n    \\n    this._closest(id, first, bitIndex + 1, contacts, n);\\n    if (contacts.length < n) {\\n      this._closest(id, second, bitIndex + 1, contacts, n);\\n    }\\n  }\\n\\n  /**\\n   * 分裂节点\\n   */\\n  _split(node, bitIndex) {\\n    node.left = this._createNode();\\n    node.right = this._createNode();\\n    \\n    // 重新分配联系人\\n    for (const contact of node.contacts) {\\n      const bit = this._getBit(contact.id, bitIndex);\\n      if (bit === 0) {\\n        node.left.contacts.push(contact);\\n      } else {\\n        node.right.contacts.push(contact);\\n      }\\n    }\\n    \\n    node.contacts = [];\\n  }\\n\\n  /**\\n   * 检查是否为叶子节点\\n   */\\n  _isLeaf(node) {\\n    return node.left === null && node.right === null;\\n  }\\n\\n  /**\\n   * 获取 ID 的特定位\\n   */\\n  _getBit(id, bitIndex) {\\n    const byteIndex = Math.floor(bitIndex / 8);\\n    const bitOffset = 7 - (bitIndex % 8);\\n    \\n    if (byteIndex >= id.length) return 0;\\n    \\n    return (id.charCodeAt(byteIndex) >> bitOffset) & 1;\\n  }\\n\\n  /**\\n   * 计算异或距离\\n   */\\n  _distance(id1, id2) {\\n    let result = 0n;\\n    const len = Math.min(id1.length, id2.length);\\n    for (let i = 0; i < len; i++) {\\n      result = (result << 8n) | BigInt(id1.charCodeAt(i) ^ id2.charCodeAt(i));\\n    }\\n    return result;\\n  }\\n\\n  /**\\n   * 获取所有联系人\\n   */\\n  toArray() {\\n    const contacts = [];\\n    this._collect(this.root, contacts);\\n    return contacts;\\n  }\\n\\n  _collect(node, contacts) {\\n    if (this._isLeaf(node)) {\\n      contacts.push(...node.contacts);\\n      return;\\n    }\\n    this._collect(node.left, contacts);\\n    this._collect(node.right, contacts);\\n  }\\n\\n  /**\\n   * 获取统计信息\\n   */\\n  getStats() {\\n    const contacts = this.toArray();\\n    return {\\n      totalContacts: contacts.length,\\n      k: this.k\\n    };\\n  }\\n}\\n\\nmodule.exports = KBucket;\\n\"}},{\"type\":\"toolCall\",\"id\":\"call_ee9842e624e344928ec56939\",\"name\":\"write\",\"arguments\":{\"path\":\"/root/.openclaw/workspace/agent-network-protocol/src/security/Crypto.js\",\"content\":\"/**\\n * Crypto - 加密模块\\n * \\n * 提供加密、解密、签名和验证功能\\n */\\n\\nconst crypto = require('crypto');\\n\\nclass Crypto {\\n  constructor(options = {}) {\\n    this.algorithm = options.algorithm || 'aes-256-gcm';\\n    this.hashAlgorithm = options.hashAlgorithm || 'sha256';\\n    this.keyLength = options.keyLength || 32; // 256 bits\\n    this.ivLength = options.ivLength || 16; // 128 bits\\n  }\\n\\n  /**\\n   * 生成密钥对\\n   */\\n  generateKeyPair() {\\n    const { publicKey, privateKey } = crypto.generateKeyPairSync('rsa', {\\n      modulusLength: 2048,\\n      publicKeyEncoding: {\\n        type: 'spki',\\n        format: 'pem'\\n      },\\n      privateKeyEncoding: {\\n        type: 'pkcs8',\\n        format: 'pem'\\n      }\\n    });\\n    \\n    return { publicKey, privateKey };\\n  }\\n\\n  /**\\n   * 生成对称密钥\\n   */\\n  generateSymmetricKey() {\\n    return crypto.randomBytes(this.keyLength).toString('hex');\\n  }\\n\\n  /**\\n   * 加密数据\\n   */\\n  encrypt(data, key) {\\n    const iv = crypto.randomBytes(this.ivLength);\\n    const keyBuffer = Buffer.from(key, 'hex').slice(0, this.keyLength);\\n    \\n    const cipher = crypto.createCipheriv(this.algorithm, keyBuffer, iv);\\n    \\n    let encrypted = cipher.update(data, 'utf8', 'hex');\\n    encrypted += cipher.final('hex');\\n    \\n    const authTag = cipher.getAuthTag();\\n    \\n    return {\\n      iv: iv.toString('hex'),\\n      data: encrypted,\\n      authTag: authTag.toString('hex')\\n    };\\n  }\\n\\n  /**\\n   * 解密数据\\n   */\\n  decrypt(encrypted, key) {\\n    const keyBuffer = Buffer.from(key, 'hex').slice(0, this.keyLength);\\n    const iv = Buffer.from(encrypted.iv, 'hex');\\n    const authTag = Buffer.from(encrypted.authTag, 'hex');\\n    \\n    const decipher = crypto.createDecipheriv(this.algorithm, keyBuffer, iv);\\n    decipher.setAuthTag(authTag);\\n    \\n    let decrypted = decipher.update(encrypted.data, 'hex', 'utf8');\\n    decrypted += decipher.final('utf8');\\n    \\n    return decrypted;\\n  }\\n\\n  /**\\n   * 使用公钥加密\\n   */\\n  encryptWithPublicKey(data, publicKey) {\\n    const buffer = Buffer.from(data, 'utf8');\\n    const encrypted = crypto.publicEncrypt({\\n      key: publicKey,\\n      padding: crypto.constants.RSA_PKCS1_OAEP_PADDING,\\n      oaepHash: this.hashAlgorithm\\n    }, buffer);\\n    \\n    return encrypted.toString('base64');\\n  }\\n\\n  /**\\n   * 使用私钥解密\\n   */\\n  decryptWithPrivateKey(encrypted, privateKey) {\\n    const buffer = Buffer.from(encrypted, 'base64');\\n    const decrypted = crypto.privateDecrypt({\\n      key: privateKey,\\n      padding: crypto.constants.RSA_PKCS1_OAEP_PADDING,\\n      oaepHash: this.hashAlgorithm\\n    }, buffer);\\n    \\n    return decrypted.toString('utf8');\\n  }\\n\\n  /**\\n   * 签名数据\\n   */\\n  sign(data, privateKey) {\\n    const sign = crypto.createSign(this.hashAlgorithm);\\n    sign.update(data);\\n    sign.end();\\n    \\n    return sign.sign(privateKey, 'hex');\\n  }\\n\\n  /**\\n   * 验证签名\\n   */\\n  verify(data, signature, publicKey) {\\n    const verify = crypto.createVerify(this.hashAlgorithm);\\n    verify.update(data);\\n    verify.end();\\n    \\n    return verify.verify(publicKey, signature, 'hex');\\n  }\\n\\n  /**\\n   * 哈希数据\\n   */\\n  hash(data) {\\n    return crypto.createHash(this.hashAlgorithm)\\n      .update(data)\\n      .digest('hex');\\n  }\\n\\n  /**\\n   * HMAC\\n   */\\n  hmac(data, key) {\\n    return crypto.createHmac(this.hashAlgorithm, key)\\n      .update(data)\\n      .digest('hex');\\n  }\\n\\n  /**\\n   * 生成随机 ID\\n   */\\n  randomId(length = 32) {\\n    return crypto.randomBytes(length).toString('hex');\\n  }\\n\\n  /**\\n   * 派生密钥\\n   */\\n  deriveKey(password, salt, iterations = 100000) {\\n    return crypto.pbkdf2Sync(\\n      password,\\n      salt,\\n      iterations,\\n      this.keyLength,\\n      this.hashAlgorithm\\n    ).toString('hex');\\n  }\\n}\\n\\nmodule.exports = Crypto;\\n\"}},{\"type\":\"toolCall\",\"id\":\"call_24b3c8c054594d6484f69aa5\",\"name\":\"write\",\"arguments\":{\"path\":\"/root/.openclaw/workspace/agent-network-protocol/src/protocol/Messaging.js\",\"content\":\"/**\\n * Messaging - 消息传递模块\\n * \\n * 实现可靠的消息传递：\\n * - 消息确认\\n * - 重试机制\\n * - 消息队列\\n */\\n\\nconst { EventEmitter } = require('events');\\n\\nclass Messaging extends EventEmitter {\\n  constructor(options = {}) {\\n    super();\\n    this.nodeId = options.nodeId;\\n    this.maxRetries = options.maxRetries || 3;\\n    this.retryDelay = options.retryDelay || 1000;\\n    this.ackTimeout = options.ackTimeout || 5000;\\n    this.pendingMessages = new Map(); // 等待确认的消息\\n    this.messageQueue = new Map(); // 每个节点的消息队列\\n    this.sequenceNumber = 0;\\n  }\\n\\n  /**\\n   * 发送消息\\n   */\\n  async send(toPeer, message) {\\n    const msgId = this._generateMessageId();\\n    const seqNum = ++this.sequenceNumber;\\n    \\n    const envelope = {\\n      id: msgId,\\n      seq: seqNum,\\n      from: this.nodeId,\\n      to: toPeer,\\n      payload: message,\\n      timestamp: Date.now(),\\n      requiresAck: message.requiresAck !== false\\n    };\\n    \\n    if (envelope.requiresAck) {\\n      return this._sendWithAck(toPeer, envelope);\\n    } else {\\n      this._emitSend(toPeer, envelope);\\n      return msgId;\\n    }\\n  }\\n\\n  /**\\n   * 发送并等待确认\\n   */\\n  async _sendWithAck(toPeer, envelope) {\\n    return new Promise((resolve, reject) => {\\n      const timeoutId = setTimeout(() => {\\n        this._handleAckTimeout(envelope);\\n      }, this.ackTimeout);\\n      \\n      this.pendingMessages.set(envelope.id, {\\n        envelope,\\n        timeoutId,\\n        retries: 0,\\n        resolve,\\n        reject\\n      });\\n      \\n      this._emitSend(toPeer, envelope);\\n    });\\n  }\\n\\n  /**\\n   * 处理确认超时\\n   */\\n  _handleAckTimeout(envelope) {\\n    const pending = this.pendingMessages.get(envelope.id);\\n    if (!pending) return;\\n    \\n    pending.retries++;\\n    \\n    if (pending.retries >= this.maxRetries) {\\n      this.pendingMessages.delete(envelope.id);\\n      pending.reject(new Error('Max retries exceeded'));\\n      this.emit('message:failed', envelope);\\n      return;\\n    }\\n    \\n    // 重试\\n    pending.timeoutId = setTimeout(() => {\\n      this._handleAckTimeout(envelope);\\n    }, this.retryDelay * pending.retries);\\n    \\n    this._emitSend(envelope.to, envelope);\\n    this.emit('message:retry', envelope, pending.retries);\\n  }\\n\\n  /**\\n   * 接收消息\\n   */\\n  receive(envelope) {\\n    // 发送确认\\n    if (envelope.requiresAck) {\\n      this._sendAck(envelope);\\n    }\\n    \\n    // 触发接收事件\\n    this.emit('message:received', envelope);\\n    \\n    return envelope;\\n  }\\n\\n  /**\\n   * 发送确认\\n   */\\n  _sendAck(envelope) {\\n    const ack = {\\n      type: 'ack',\\n      messageId: envelope.id,\\n      from: this.nodeId,\\n      to: envelope.from,\\n      timestamp: Date.now()\\n    };\\n    \\n    this.emit('ack:send', ack);\\n  }\\n\\n  /**\\n   * 处理确认\\n   */\\n  handleAck(ack) {\\n    const pending = this.pendingMessages.get(ack.messageId);\\n    if (!pending) return;\\n    \\n    clearTimeout(pending.timeoutId);\\n    this.pendingMessages.delete(ack.messageId);\\n    \\n    pending.resolve(ack.messageId);\\n    this.emit('message:ack', ack);\\n  }\\n\\n  /**\\n   * 广播消息\\n   */\\n  broadcast(message, peers) {\\n    const results = [];\\n    for (const peer of peers) {\\n      results.push(this.send(peer, message));\\n    }\\n    return results;\\n  }\\n\\n  /**\\n   * 入队消息 (用于离线节点)\\n   */\\n  enqueue(peerId, message) {\\n    if (!this.messageQueue.has(peerId)) {\\n      this.messageQueue.set(peerId, []);\\n    }\\n    \\n    this.messageQueue.get(peerId).push({\\n      message,\\n      timestamp: Date.now()\\n    });\\n  }\\n\\n  /**\\n   * 获取队列中的消息\\n   */\\n  getQueuedMessages(peerId) {\\n    return this.messageQueue.get(peerId) || [];\\n  }\\n\\n  /**\\n   * 清空队列\\n   */\\n  clearQueue(peerId) {\\n    this.messageQueue.delete(peerId);\\n  }\\n\\n  /**\\n   * 发送事件\\n   */\\n  _emitSend(toPeer, envelope) {\\n    this.emit('message:send', toPeer, envelope);\\n  }\\n\\n  /**\\n   * 生成消息 ID\\n   */\\n  _generateMessageId() {\\n    return `${this.nodeId}-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;\\n  }\\n\\n  /**\\n   * 获取统计信息\\n   */\\n  getStats() {\\n    return {\\n      pendingMessages: this.pendingMessages.size,\\n      queuedPeers: this.messageQueue.size,\\n      totalQueued: Array.from(this.messageQueue.values())\\n        .reduce((sum, q) => sum + q.length, 0)\\n    };\\n  }\\n}\\n\\nmodule.exports = Messaging;\\n\"}},{\"type\":\"toolCall\",\"id\":\"call_b2c3ed36597247849d8b617c\",\"name\":\"write\",\"arguments\":{\"path\":\"/root/.openclaw/workspace/agent-network-protocol/src/Network.js\",\"content\":\"/**\\n * Network - 网络集成模块\\n * \\n * 整合所有协议组件，提供统一的网络接口\\n */\\n\\nconst { EventEmitter } = require('events');\\nconst Node = require('./core/Node');\\nconst { EventManager, EventTypes } = require('./core/Events');\\nconst Message = require('./core/Message');\\nconst Discovery = require('./protocol/Discovery');\\nconst Gossip = require('./protocol/Gossip');\\nconst Messaging = require('./protocol/Messaging');\\nconst DHT = require('./routing/DHT');\\nconst KBucket = require('./routing/KBucket');\\nconst Crypto = require('./security/Crypto');\\nconst KeyManager = require('./security/KeyManager');\\n\\nclass Network extends EventEmitter {\\n  constructor(options = {}) {\\n    super();\\n    \\n    this.nodeId = options.nodeId || this._generateId();\\n    this.options = options;\\n    \\n    // 核心组件\\n    this.events = new EventManager();\\n    this.node = new Node({ id: this.nodeId, ...options.node });\\n    this.crypto = new Crypto(options.crypto);\\n    \\n    // 协议组件\\n    this.discovery = new Discovery({\\n      nodeId: this.nodeId,\\n      bootstrapNodes: options.bootstrapNodes || [],\\n      ...options.discovery\\n    });\\n    \\n    this.gossip = new Gossip({\\n      nodeId: this.nodeId,\\n      ...options.gossip\\n    });\\n    \\n    this.messaging = new Messaging({\\n      nodeId: this.nodeId,\\n      ...options.messaging\\n    });\\n    \\n    // 路由组件\\n    this.dht = new DHT({\\n      nodeId: this.nodeId,\\n      ...options.dht\\n    });\\n    \\n    this.kbucket = new KBucket({\\n      localNodeId: this.nodeId,\\n      ...options.kbucket\\n    });\\n    \\n    // 安全组件\\n    this.keyManager = new KeyManager(options.keyManager);\\n    \\n    // 状态\\n    this.started = false;\\n    this.peers = new Map();\\n    \\n    this._setupEventForwarding();\\n    this._setupProtocolHandlers();\\n  }\\n\\n  /**\\n   * 启动网络\\n   */\\n  async start() {\\n    if (this.started) return;\\n    \\n    // 初始化密钥\\n    await this.keyManager.init();\\n    \\n    // 启动发现服务\\n    await this.discovery.start();\\n    \\n    // 启动节点\\n    await this.node.start();\\n    \\n    this.started = true;\\n    this.emit('network:started');\\n    this.events.emit(EventTypes.NODE_STARTED, this.nodeId);\\n    \\n    return this;\\n  }\\n\\n  /**\\n   * 停止网络\\n   */\\n  async stop() {\\n    if (!this.started) return;\\n    \\n    await this.discovery.stop();\\n    await this.node.stop();\\n    \\n    this.started = false;\\n    this.emit('network:stopped');\\n    this.events.emit(EventTypes.NODE_STOPPED, this.nodeId);\\n  }\\n\\n  /**\\n   * 连接到节点\\n   */\\n  async connect(peerInfo) {\\n    const peerId = peerInfo.id;\\n    \\n    // 添加到路由表\\n    this.dht.addNode(peerInfo);\\n    \\n    // 添加到已知节点\\n    this.peers.set(peerId, peerInfo);\\n    \\n    this.emit('peer:connected', peerInfo);\\n    this.events.emit(EventTypes.PEER_CONNECTED, peerInfo);\\n    \\n    return peerId;\\n  }\\n\\n  /**\\n   * 断开节点\\n   */\\n  async disconnect(peerId) {\\n    const peer = this.peers.get(peerId);\\n    \\n    this.dht.removeNode(peerId);\\n    this.peers.delete(peerId);\\n    \\n    this.emit('peer:disconnected', peerId, peer);\\n    this.events.emit(EventTypes.PEER_DISCONNECTED, peerId);\\n  }\\n\\n  /**\\n   * 广播消息\\n   */\\n  broadcast(message) {\\n    const msg = new Message({\\n      type: 'broadcast',\\n      payload: message,\\n      from: this.nodeId\\n    });\\n    \\n    return this.gossip.broadcast(msg.toJSON());\\n  }\\n\\n  /**\\n   * 发送消息到指定节点\\n   */\\n  async send(peerId, message) {\\n    const msg = new Message({\\n      type: 'direct',\\n      to: peerId,\\n      payload: message,\\n      from: this.nodeId\\n    });\\n    \\n    return this.messaging.send(peerId, msg.toJSON());\\n  }\\n\\n  /**\\n   * 存储数据到 DHT\\n   */\\n  async put(key, value) {\\n    return this.dht.put(key, value);\\n  }\\n\\n  /**\\n   * 从 DHT 获取数据\\n   */\\n  async get(key) {\\n    return this.dht.get(key);\\n  }\\n\\n  /**\\n   * 获取已知节点\\n   */\\n  getPeers() {\\n    return Array.from(this.peers.values());\\n  }\\n\\n  /**\\n   * 获取节点信息\\n   */\\n  getNodeInfo() {\\n    return {\\n      id: this.nodeId,\\n      started: this.started,\\n      peerCount: this.peers.size,\\n      stats: {\\n        dht: this.dht.getStats(),\\n        messaging: this.messaging.getStats(),\\n        gossip: this.gossip.getStats()\\n      }\\n    };\\n  }\\n\\n  /**\\n   * 设置事件转发\\n   */\\n  _setupEventForwarding() {\\n    // 转发协议事件\\n    this.discovery.on('peer:discovered', (peer) => {\\n      this.emit('peer:discovered', peer);\\n    });\\n    \\n    this.gossip.on('gossip:received', (msg) => {\\n      this.emit('message:broadcast', msg);\\n    });\\n    \\n    this.messaging.on('message:received', (envelope) => {\\n      this.emit('message:received', envelope);\\n    });\\n  }\\n\\n  /**\\n   * 设置协议处理器\\n   */\\n  _setupProtocolHandlers() {\\n    // Gossip 目标选择\\n    this.gossip.on('gossip:selectTargets', (excludePeers) => {\\n      const peers = Array.from(this.peers.values())\\n        .filter(p => !excludePeers.includes(p.id));\\n      \\n      // 随机选择 fanout 个节点\\n      const selected = this._randomSelect(peers, this.gossip.fanout);\\n      \\n      // 通知 gossip 发送\\n      selected.forEach(peer => {\\n        this.gossip.emit('gossip:send', peer);\\n      });\\n    });\\n    \\n    // 消息发送处理\\n    this.messaging.on('message:send', (toPeer, envelope) => {\\n      this.emit('transport:send', toPeer, envelope);\\n    });\\n    \\n  