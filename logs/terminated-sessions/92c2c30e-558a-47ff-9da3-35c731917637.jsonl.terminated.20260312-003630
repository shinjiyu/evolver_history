   const targets = this._selectTargets(excludePeers);\\n    \\n    // 发送给选中的节点\\n    for (const peer of targets) {\\n      this.emit('gossip:send', peer, message);\\n    }\\n    \\n    // 触发本地接收事件\\n    this.emit('gossip:received', message);\\n    \\n    return messageId;\\n  }\\n\\n  /**\\n   * 接收并转发消息\\n   */\\n  receive(message, fromPeer) {\\n    const messageId = message.id;\\n    \\n    // 检查是否已处理\\n    if (this.messageCache.has(messageId)) {\\n      return false;\\n    }\\n    \\n    // 缓存消息\\n    this._cacheMessage(messageId, message);\\n    \\n    // 触发接收事件\\n    this.emit('gossip:received', message);\\n    \\n    // 增加跳数并转发\\n    message.hops = (message.hops || 0) + 1;\\n    \\n    if (message.hops <= this.maxHops) {\\n      const targets = this._selectTargets([fromPeer]);\\n      for (const peer of targets) {\\n        this.emit('gossip:send', peer, message);\\n      }\\n      this.emit('gossip:propagated', message);\\n    }\\n    \\n    return true;\\n  }\\n\\n  /**\\n   * 选择传播目标\\n   */\\n  _selectTargets(excludePeers = []) {\\n    // 由外部提供 peer 列表\\n    this.emit('gossip:selectTargets', excludePeers);\\n    return []; // 返回选中的节点\\n  }\\n\\n  /**\\n   * 缓存消息\\n   */\\n  _cacheMessage(id, message) {\\n    // 清理过期缓存\\n    if (this.messageCache.size >= this.cacheSize) {\\n      this._cleanupCache();\\n    }\\n    \\n    this.messageCache.set(id, {\\n      message,\\n      timestamp: Date.now()\\n    });\\n  }\\n\\n  /**\\n   * 清理过期缓存\\n   */\\n  _cleanupCache() {\\n    const now = Date.now();\\n    for (const [id, entry] of this.messageCache) {\\n      if (now - entry.timestamp > this.cacheTTL) {\\n        this.messageCache.delete(id);\\n      }\\n    }\\n  }\\n\\n  /**\\n   * 生成消息ID\\n   */\\n  _generateId() {\\n    return `${this.nodeId}-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;\\n  }\\n\\n  /**\\n   * 获取统计信息\\n   */\\n  getStats() {\\n    return {\\n      cacheSize: this.messageCache.size,\\n      fanout: this.fanout,\\n      maxHops: this.maxHops\\n    };\\n  }\\n}\\n\\nmodule.exports = Gossip;\\n\"}},{\"type\":\"toolCall\",\"id\":\"call_0e474c560769495c9ce8cb89\",\"name\":\"write\",\"arguments\":{\"path\":\"/root/.openclaw/workspace/agent-network-protocol/src/routing/DHT.js\",\"content\":\"/**\\n * DHT - 分布式哈希表\\n * \\n * 基于 Kademlia 协议实现\\n */\\n\\nconst { EventEmitter } = require('events');\\n\\nclass DHT extends EventEmitter {\\n  constructor(options = {}) {\\n    super();\\n    this.nodeId = options.nodeId || this._generateId();\\n    this.kbuckets = new Array(160); // 160 个 k-bucket (SHA-1)\\n    this.k = options.k || 20; // 每个 bucket 最多 k 个节点\\n    this.data = new Map(); // 本地存储的数据\\n    this.replication = options.replication || 3;\\n  }\\n\\n  /**\\n   * 存储 key-value\\n   */\\n  async put(key, value, ttl = 3600000) {\\n    const keyHash = this._hash(key);\\n    const closest = this._findClosestNodes(keyHash);\\n    \\n    // 存储到本地\\n    this.data.set(keyHash, {\\n      value,\\n      ttl,\\n      timestamp: Date.now()\\n    });\\n    \\n    // 存储到最近的节点\\n    for (const node of closest.slice(0, this.replication)) {\\n      this.emit('dht:store', node, keyHash, value, ttl);\\n    }\\n    \\n    this.emit('dht:put', key, value);\\n    return keyHash;\\n  }\\n\\n  /**\\n   * 获取 value\\n   */\\n  async get(key) {\\n    const keyHash = this._hash(key);\\n    \\n    // 先查本地\\n    const local = this.data.get(keyHash);\\n    if (local && Date.now() - local.timestamp < local.ttl) {\\n      this.emit('dht:get', key, local.value, true);\\n      return local.value;\\n    }\\n    \\n    // 查询最近的节点\\n    const closest = this._findClosestNodes(keyHash);\\n    this.emit('dht:lookup', closest, keyHash);\\n    \\n    this.emit('dht:get', key, null, false);\\n    return null;\\n  }\\n\\n  /**\\n   * 添加节点到路由表\\n   */\\n  addNode(nodeInfo) {\\n    const distance = this._distance(this.nodeId, nodeInfo.id);\\n    const bucketIndex = this._getBucketIndex(distance);\\n    \\n    if (!this.kbuckets[bucketIndex]) {\\n      this.kbuckets[bucketIndex] = [];\\n    }\\n    \\n    const bucket = this.kbuckets[bucketIndex];\\n    \\n    // 检查是否已存在\\n    const existingIndex = bucket.findIndex(n => n.id === nodeInfo.id);\\n    if (existingIndex >= 0) {\\n      // 移到末尾 (最近使用)\\n      bucket.splice(existingIndex, 1);\\n      bucket.push(nodeInfo);\\n    } else if (bucket.length < this.k) {\\n      bucket.push(nodeInfo);\\n      this.emit('dht:node:added', nodeInfo);\\n    } else {\\n      // bucket 已满，需要检查最久未使用的节点\\n      this.emit('dht:bucket:full', bucketIndex, nodeInfo);\\n    }\\n  }\\n\\n  /**\\n   * 移除节点\\n   */\\n  removeNode(nodeId) {\\n    const distance = this._distance(this.nodeId, nodeId);\\n    const bucketIndex = this._getBucketIndex(distance);\\n    const bucket = this.kbuckets[bucketIndex];\\n    \\n    if (bucket) {\\n      const index = bucket.findIndex(n => n.id === nodeId);\\n      if (index >= 0) {\\n        const removed = bucket.splice(index, 1)[0];\\n        this.emit('dht:node:removed', removed);\\n      }\\n    }\\n  }\\n\\n  /**\\n   * 查找最近的节点\\n   */\\n  _findClosestNodes(targetId, count = this.k) {\\n    const allNodes = [];\\n    \\n    for (const bucket of this.kbuckets) {\\n      if (bucket) {\\n        allNodes.push(...bucket);\\n      }\\n    }\\n    \\n    // 按距离排序\\n    allNodes.sort((a, b) => {\\n      const distA = this._distance(a.id, targetId);\\n      const distB = this._distance(b.id, targetId);\\n      return distA < distB ? -1 : 1;\\n    });\\n    \\n    return allNodes.slice(0, count);\\n  }\\n\\n  /**\\n   * 计算异或距离\\n   */\\n  _distance(id1, id2) {\\n    let result = BigInt(0);\\n    for (let i = 0; i < Math.min(id1.length, id2.length); i++) {\\n      result = (result << BigInt(8)) | BigInt(id1.charCodeAt(i) ^ id2.charCodeAt(i));\\n    }\\n    return result;\\n  }\\n\\n  /**\\n   * 获取 bucket 索引\\n   */\\n  _getBucketIndex(distance) {\\n    let index = 0;\\n    while (distance > BigInt(0)) {\\n      distance = distance >> BigInt(1);\\n      index++;\\n    }\\n    return Math.min(index, 159);\\n  }\\n\\n  /**\\n   * 哈希函数\\n   */\\n  _hash(key) {\\n    // 简化版哈希，实际应使用 SHA-1\\n    let hash = 0;\\n    for (let i = 0; i < key.length; i++) {\\n      const char = key.charCodeAt(i);\\n      hash = ((hash << 5) - hash) + char;\\n      hash = hash & hash;\\n    }\\n    return Math.abs(hash).toString(16).padStart(40, '0');\\n  }\\n\\n  /**\\n   * 生成节点 ID\\n   */\\n  _generateId() {\\n    return Math.random().toString(16).slice(2) + Date.now().toString(16);\\n  }\\n\\n  /**\\n   * 获取路由表统计\\n   */\\n  getStats() {\\n    let totalNodes = 0;\\n    let usedBuckets = 0;\\n    \\n    for (const bucket of this.kbuckets) {\\n      if (bucket && bucket.length > 0) {\\n        totalNodes += bucket.length;\\n        usedBuckets++;\\n      }\\n    }\\n    \\n    return {\\n      nodeId: this.nodeId,\\n      totalNodes,\\n      usedBuckets,\\n      storedKeys: this.data.size\\n    };\\n  }\\n}\\n\\nmodule.exports = DHT;\\n\"}},{\"type\":\"toolCall\",\"id\":\"call_feae37d4a0b347f3b48b5216\",\"name\":\"write\",\"arguments\":{\"path\":\"/root/.openclaw/workspace/agent-network-protocol/src/routing/KBucket.js\",\"content\":\"/**\\n * KBucket - K-Bucket 数据结构\\n * \\n * 用于 Kademlia DHT 的路由表存储\\n */\\n\\nclass KBucket {\\n  constructor(options = {}) {\\n    this.localNodeId = options.localNodeId;\\n    this.k = options.k || 20; // 每个 bucket 最大节点数\\n    this.root = this._createNode();\\n  }\\n\\n  /**\\n   * 创建内部节点\\n   */\\n  _createNode() {\\n    return {\\n      contacts: [],\\n      donotSplit: false,\\n      left: null,\\n      right: null\\n    };\\n  }\\n\\n  /**\\n   * 添加联系人\\n   */\\n  add(contact) {\\n    const bitIndex = 0;\\n    return this._add(contact, this.root, bitIndex);\\n  }\\n\\n  /**\\n   * 内部添加逻辑\\n   */\\n  _add(contact, node, bitIndex) {\\n    // 叶子节点\\n    if (this._isLeaf(node)) {\\n      // 检查是否已存在\\n      const index = node.contacts.findIndex(c => c.id === contact.id);\\n      if (index >= 0) {\\n        // 移到末