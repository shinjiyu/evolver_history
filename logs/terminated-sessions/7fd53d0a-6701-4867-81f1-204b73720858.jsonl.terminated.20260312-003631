AL_429 次\"\n\n# 生成报告\ncat > \"$REPORT_FILE\" <<EOF\n# 429 错误热点分析报告\n\n**分析时间**: $(date '+%Y-%m-%d %H:%M:%S')\n**分析范围**: 最近 1 小时\n**总错误数**: $TOTAL_429 次\n\n---\n\n## 📊 Session 错误分布\n\n| 排名 | Session 文件 | 错误数 | 占比 |\n|------|-------------|--------|------|\nEOF\n\n# 添加每个 session 的数据\nrank=1\necho \"$HOTSPOT_DATA\" | while read count file; do\n    if [ -n \"$count\" ] && [ \"$count\" -gt 0 ]; then\n        percentage=$(awk \"BEGIN {printf \\\"%.1f\\\", ($count / $TOTAL_429) * 100}\")\n        filename=$(basename \"$file\")\n        echo \"| $rank | $filename | $count | ${percentage}% |\" >> \"$REPORT_FILE\"\n        rank=$((rank + 1))\n    fi\ndone\n\ncat >> \"$REPORT_FILE\" <<EOF\n\n---\n\n## 🔍 Session 详情\n\nEOF\n\n# 分析每个 session 的特征\necho \"$HOTSPOT_DATA\" | head -5 | while read count file; do\n    if [ -n \"$count\" ] && [ \"$count\" -gt 0 ]; then\n        filename=$(basename \"$file\")\n        echo \"### $filename ($count 次)\" >> \"$REPORT_FILE\"\n        echo \"\" >> \"$REPORT_FILE\"\n        \n        # 提取 session 创建时间\n        created=$(head -1 \"$file\" 2>/dev/null | grep -o '\"timestamp\":\"[^\"]*\"' | cut -d'\"' -f4 || echo \"未知\")\n        echo \"- **创建时间**: $created\" >> \"$REPORT_FILE\"\n        \n        # 统计 session 中的消息数量\n        msg_count=$(wc -l < \"$file\" 2>/dev/null || echo \"0\")\n        echo \"- **消息数量**: $msg_count\" >> \"$REPORT_FILE\"\n        \n        # 统计错误密度（每 100 条消息的错误数）\n        if [ \"$msg_count\" -gt 0 ]; then\n            density=$(awk \"BEGIN {printf \\\"%.2f\\\", ($count / $msg_count) * 100}\")\n            echo \"- **错误密度**: ${density} 次/100条消息\" >> \"$REPORT_FILE\"\n        fi\n        \n        echo \"\" >> \"$REPORT_FILE\"\n    fi\ndone\n\ncat >> \"$REPORT_FILE\" <<EOF\n\n---\n\n## 💡 分析建议\n\nEOF\n\n# 生成建议\ntop_session=$(echo \"$HOTSPOT_DATA\" | head -1 | awk '{print $1}')\ntop_count=$(echo \"$HOTSPOT_DATA\" | head -1 | awk '{print $2}')\ntop_percentage=$(awk \"BEGIN {printf \\\"%.1f\\\", ($top_count / $TOTAL_429) * 100}\")\n\nif [ $(awk \"BEGIN {print ($top_percentage > 50)}\") -eq 1 ]; then\n    cat >> \"$REPORT_FILE\" <<EOF\n### 🚨 高度集中\n\n**发现**: Top 1 session 占了 **${top_percentage}%** 的 429 错误\n\n**建议**:\n1. 检查该 session 的任务类型\n2. 考虑降低该 session 的请求频率\n3. 如果是长时间运行的 session，考虑拆分任务\n4. 如果是关键任务，考虑使用专用的 API 配额\n\nEOF\nelif [ $(awk \"BEGIN {print ($top_percentage > 30)}\") -eq 1 ]; then\n    cat >> \"$REPORT_FILE\" <<EOF\n### 🟡 中度集中\n\n**发现**: Top 1 session 占了 **${top_percentage}%** 的 429 错误\n\n**建议**:\n1. 监控该 session 的请求频率\n2. 考虑优化该 session 的任务执行策略\n\nEOF\nelse\n    cat >> \"$REPORT_FILE\" <<EOF\n### 🟢 分散分布\n\n**发现**: 429 错误分布相对分散（Top 1 占 ${top_percentage}%）\n\n**建议**:\n1. 继续监控整体趋势\n2. 检查是否有共同的触发因素\n\nEOF\nfi\n\ncat >> \"$REPORT_FILE\" <<EOF\n\n---\n\n## 📋 下次分析\n\n**时间**: $(date -d '+1 hour' '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date '+%Y-%m-%d %H:%M:%S')\n**命令**: \\`bash /root/.openclaw/workspace/evolver/fixes/analyze-429-hotspots.sh\\`\n\n---\n\n**生成时间**: $(date '+%Y-%m-%d %H:%M:%S')\n**分析者**: OpenClaw Evolver System\nEOF\n\nlog \"✅ 分析报告已生成: $REPORT_FILE\"\n\n# 输出摘要\necho \"\"\necho \"=== 429 错误热点分析摘要 ===\"\necho \"总错误数: $TOTAL_429 次\"\necho \"\"\necho \"Top 5 Session:\"\necho \"$HOTSPOT_DATA\" | head -5 | while read count file; do\n    if [ -n \"$count\" ] && [ \"$count\" -gt 0 ]; then\n        filename=$(basename \"$file\")\n        percentage=$(awk \"BEGIN {printf \\\"%.1f\\\", ($count / $TOTAL_429) * 100}\")\n        echo \"  - $filename: $count 次 (${percentage}%)\"\n    fi\ndone\necho \"\"\necho \"详细报告: $REPORT_FILE\"\n\nexit 0\n"}},{"type":"toolCall","id":"call_739aec5e885e47a5b134df49","name":"write","arguments":{"path":"/root/.openclaw/workspace/evolver/fixes/gateway-memory-watch.sh","content":"#!/bin/bash\n# Gateway Memory Watch - 监控 Gateway 内存使用\n\nLOG_FILE=\"/root/.openclaw/workspace/logs/gateway-memory.log\"\nALERT_THRESHOLD=80  # 内存使用告警阈值（%）\nRESTART_THRESHOLD=90  # 内存使用重启阈值（%）\n\n# 创建日志目录\nmkdir -p \"$(dirname \"$LOG_FILE\")\"\n\n# 日志函数\nlog() {\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $1\" | tee -a \"$LOG_FILE\"\n}\n\n# 获取 Gateway 内存使用\nget_gateway_memory() {\n    # 查找 openclaw-gateway 进程\n    local gateway_pid=$(ps aux | grep \"openclaw-gateway\" | grep -v grep | awk '{print $2}' | head -1)\n    \n    if [ -z \"$gateway_pid\" ]; then\n        echo \"NOT_RUNNING\"\n        return 1\n    fi\n    \n    # 获取内存使用（MB）\n    local mem_kb=$(ps -p \"$gateway_pid\" -o rss= 2>/dev/null | tr -d ' ')\n    local mem_mb=$((mem_kb / 1024))\n    \n    echo \"$mem_mb\"\n}\n\n# 获取系统内存使用百分比\nget_system_memory_percent() {\n    local mem_info=$(free | grep \"Mem:\")\n    local total=$(echo \"$mem_info\" | awk '{print $2}')\n    local used=$(echo \"$mem_info\" | awk '{print $3}')\n    local percent=$(awk \"BEGIN {printf \\\"%.1f\\\", ($used / $total) * 100}\")\n    echo \"$percent\"\n}\n\n# 检查一次\ncheck_once() {\n    log \"=== Gateway 内存检查 ===\"\n    \n    # Gateway 内存\n    local gateway_mem=$(get_gateway_memory)\n    \n    if [ \"$gateway_mem\" = \"NOT_RUNNING\" ]; then\n        log \"❌ Gateway 未运行\"\n        echo \"❌ Gateway 未运行\"\n        return 1\n    fi\n    \n    # 系统内存\n    local sys_mem=$(get_system_memory_percent)\n    \n    log \"Gateway 内存: ${gateway_mem}MB\"\n    log \"系统内存: ${sys_mem}%\"\n    \n    # 判断状态\n    if [ $(awk \"BEGIN {print ($sys_mem >= $RESTART_THRESHOLD)}\") -eq 1 ]; then\n        log \"🔴 严重: 系统内存 ${sys_mem}% >= ${RESTART_THRESHOLD}%，建议立即重启 Gateway\"\n        echo \"🔴 严重: 系统内存 ${sys_mem}% >= ${RESTART_THRESHOLD}%，建议立即重启 Gateway\"\n        return 2\n    elif [ $(awk \"BEGIN {print ($sys_mem >= $ALERT_THRESHOLD)}\") -eq 1 ]; then\n        log \"🟡 警告: 系统内存 ${sys_mem}% >= ${ALERT_THRESHOLD}%，建议关注\"\n        echo \"🟡 警告: 系统内存 ${sys_mem}% >= ${ALERT_THRESHOLD}%，建议关注\"\n        return 1\n    else\n        log \"✅ 正常: 系统内存 ${sys_mem}% < ${ALERT_THRESHOLD}%\"\n        echo \"✅ 正常: 系统内存 ${sys_mem}% < ${ALERT_THRESHOLD}%\"\n        return 0\n    fi\n}\n\n# 持续监控\nmonitor() {\n    local interval=\"${1:-300}\"  # 默认 5 分钟\n    local count=0\n    local prev_gateway_mem=\"\"\n    \n    log \"=== 开始持续监控（间隔 ${interval}s）===\"\n    \n    while true; do\n        count=$((count + 1))\n        log \"\"\n        log \"--- 检查 #$count ---\"\n        \n        # Gateway 内存\n        local gateway_mem=$(get_gateway_memory)\n        \n        if [ \"$gateway_mem\" = \"NOT_RUNNING\" ]; then\n            log \"❌ Gateway 未运行\"\n        else\n            # 计算增长\n            if [ -n \"$prev_gateway_mem\" ]; then\n                local growth=$((gateway_mem - prev_gateway_mem))\n                if [ $growth -gt 0 ]; then\n                    log \"Gateway 内存: ${gateway_mem}MB (↑${growth}MB)\"\n                elif [ $growth -lt 0 ]; then\n                    log \"Gateway 内存: ${gateway_mem}MB (↓${growth#-}MB)\"\n                else\n                    log \"Gateway 内存: ${gateway_mem}MB (稳定)\"\n                fi\n            else\n                log \"Gateway 内存: ${gateway_mem}MB\"\n            fi\n            prev_gateway_mem=\"$gateway_mem\"\n        fi\n        \n        # 系统内存\n        local sys_mem=$(get_system_memory_percent)\n        log \"系统内存: ${sys_mem}%\"\n        \n        # 判断状态\n        if [ $(awk \"BEGIN {print ($sys_mem >= $RESTART_THRESHOLD)}\") -eq 1 ]; then\n            log \"🔴 严重: 系统内存 ${sys_mem}% >= ${RESTART_THRESHOLD}%\"\n            log \"⚠️ 建议立即重启 Gateway\"\n        elif [ $(awk \"BEGIN {print ($sys_mem >= $ALERT_THRESHOLD)}\") -eq 1 ]; then\n            log \"🟡 警告: 系统内存 ${sys_mem}% >= ${ALERT_THRESHOLD}%\"\n        else\n            log \"✅ 正常\"\n        fi\n        \n        sleep \"$interval\"\n    done\n}\n\n# 主逻辑\ncase \"${1:-check}\" in\n    check)\n        check_once\n        exit $?\n        ;;\n    \n    monitor)\n        monitor \"${2:-300}\"\n        ;;\n    \n    status)\n        gateway_mem=$(get_gateway_memory)\n        sys_mem=$(get_system_memory_percent)\n        \n        echo \"Gateway 内存: ${gateway_mem}MB\"\n        echo \"系统内存: ${sys_mem}%\"\n        \n        if [ \"$gateway_mem