\necho \"## 1. API 429 错误趋势分析\"\necho \"\"\n\n# 统计最近 6 小时的 429 错误\nRECENT_429=$(grep -c \"429.*速率限制\\|429.*rate limit\" \"$LOG_DIR\"/*.log 2>/dev/null || echo \"0\")\n\n# 读取上次的 429 错误数（如果存在）\nLAST_429_FILE=\"$REPORT_DIR/last-429-count.txt\"\nif [ -f \"$LAST_429_FILE\" ]; then\n    LAST_429=$(cat \"$LAST_429_FILE\")\n    REDUCTION_PERCENT=$(echo \"scale=1; (($LAST_429 - $RECENT_429) / $LAST_429 * 100)\" | bc 2>/dev/null || echo \"0\")\n    echo \"   上次统计: $LAST_429 次\"\n    echo \"   本次统计: $RECENT_429 次\"\n    echo \"   减少幅度: $REDUCTION_PERCENT%\"\n    \n    if (( $(echo \"$REDUCTION_PERCENT >= $EXPECTED_429_REDUCTION\" | bc -l) )); then\n        echo \"   ✅ 达到预期目标（≥${EXPECTED_429_REDUCTION}%）\"\n        STATUS_429=\"✅ 达标\"\n    else\n        echo \"   🟡 未达预期目标（<${EXPECTED_429_REDUCTION}%）\"\n        STATUS_429=\"🟡 未达标\"\n    fi\nelse\n    echo \"   本次统计: $RECENT_429 次（首次统计）\"\n    echo \"   状态: 📊 基准数据已记录\"\n    STATUS_429=\"📊 基准\"\nfi\n\n# 保存本次统计\necho \"$RECENT_429\" > \"$LAST_429_FILE\"\n\necho \"\"\n\n# 2. 统计子代理成功率\necho \"## 2. 子代理成功率分析\"\necho \"\"\n\n# 统计最近 6 小时的子代理任务\nSUBAGENT_SUCCESS=$(grep -c \"子代理.*成功\\|subagent.*success\" \"$LOG_DIR\"/*.log 2>/dev/null || echo \"0\")\nSUBAGENT_FAILED=$(grep -c \"子代理.*失败\\|subagent.*fail\\|subagent.*error\" \"$LOG_DIR\"/*.log 2>/dev/null || echo \"0\")\nSUBAGENT_TOTAL=$((SUBAGENT_SUCCESS + SUBAGENT_FAILED))\n\nif [ \"$SUBAGENT_TOTAL\" -gt 0 ]; then\n    SUCCESS_RATE=$(echo \"scale=1; ($SUBAGENT_SUCCESS / $SUBAGENT_TOTAL * 100)\" | bc 2>/dev/null || echo \"0\")\n    echo \"   成功: $SUBAGENT_SUCCESS 次\"\n    echo \"   失败: $SUBAGENT_FAILED 次\"\n    echo \"   成功率: $SUCCESS_RATE%\"\n    \n    if (( $(echo \"$SUCCESS_RATE >= $EXPECTED_SUCCESS_RATE\" | bc -l) )); then\n        echo \"   ✅ 达到预期目标（≥${EXPECTED_SUCCESS_RATE}%）\"\n        STATUS_SUBAGENT=\"✅ 达标\"\n    else\n        echo \"   🟡 未达预期目标（<${EXPECTED_SUCCESS_RATE}%）\"\n        STATUS_SUBAGENT=\"🟡 未达标\"\n    fi\nelse\n    echo \"   📊 无子代理任务数据\"\n    SUCCESS_RATE=0\n    STATUS_SUBAGENT=\"📊 无数据\"\nfi\n\necho \"\"\n\n# 3. 系统健康评分\necho \"## 3. 系统健康评分\"\necho \"\"\n\n# 内存状态\nMEMORY_AVAILABLE=$(free -m | grep \"Mem\" | awk '{print $7}')\nMEMORY_PERCENT=$(echo \"scale=1; ($MEMORY_AVAILABLE / 3670 * 100)\" | bc)\necho \"   可用内存: $MEMORY_AVAILABLE MB ($MEMORY_PERCENT%)\"\n\n# CPU 负载\nCPU_LOAD=$(uptime | awk -F'load average:' '{print $2}' | awk '{print $1}' | tr -d ',')\necho \"   CPU 负载: $CPU_LOAD\"\n\n# 磁盘使用\nDISK_USAGE=$(df -h / | tail -1 | awk '{print $5}' | tr -d '%')\necho \"   磁盘使用: $DISK_USAGE%\"\n\n# 计算健康评分\nHEALTH_SCORE=8.0\nif (( $(echo \"$MEMORY_AVAILABLE < 500\" | bc -l) )); then\n    HEALTH_SCORE=$(echo \"$HEALTH_SCORE - 1.0\" | bc)\nfi\nif (( $(echo \"$CPU_LOAD > 1.0\" | bc -l) )); then\n    HEALTH_SCORE=$(echo \"$HEALTH_SCORE - 0.5\" | bc)\nfi\nif [ \"$DISK_USAGE\" -gt 85 ]; then\n    HEALTH_SCORE=$(echo \"$HEALTH_SCORE - 0.5\" | bc)\nfi\n\necho \"   健康评分: $HEALTH_SCORE/10\"\n\nif (( $(echo \"$HEALTH_SCORE >= 8.0\" | bc -l) )); then\n    echo \"   ✅ 系统状态良好\"\n    STATUS_HEALTH=\"✅ 良好\"\nelif (( $(echo \"$HEALTH_SCORE >= 7.0\" | bc -l) )); then\n    echo \"   🟡 系统状态一般\"\n    STATUS_HEALTH=\"🟡 一般\"\nelse\n    echo \"   🔴 系统状态较差\"\n    STATUS_HEALTH=\"🔴 较差\"\nfi\n\necho \"\"\n\n# 4. Cron 任务执行情况\necho \"## 4. Cron 任务执行情况\"\necho \"\"\n\n# 统计最近 6 小时的 Cron 任务\nCRON_SUCCESS=$(grep -c \"cron.*完成\\|cron.*success\" \"$LOG_DIR\"/*.log 2>/dev/null || echo \"0\")\nCRON_FAILED=$(grep -c \"cron.*失败\\|cron.*error\" \"$LOG_DIR\"/*.log 2>/dev/null || echo \"0\")\nCRON_TOTAL=$((CRON_SUCCESS + CRON_FAILED))\n\nif [ \"$CRON_TOTAL\" -gt 0 ]; then\n    CRON_SUCCESS_RATE=$(echo \"scale=1; ($CRON_SUCCESS / $CRON_TOTAL * 100)\" | bc 2>/dev/null || echo \"0\")\n    echo \"   成功: $CRON_SUCCESS 次\"\n    echo \"   失败: $CRON_FAILED 次\"\n    echo \"   成功率: $CRON_SUCCESS_RATE%\"\n    \n    if [ \"$CRON_SUCCESS_RATE\" = \"100.0\" ]; then\n        echo \"   ✅ 所有任务正常执行\"\n        STATUS_CRON=\"✅ 完美\"\n    else\n        echo \"   🟡 部分任务失败\"\n        STATUS_CRON=\"🟡 