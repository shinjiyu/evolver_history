n    return this.nodeId;\n  }\n\n  /**\n   * 停止网络\n   */\n  async stop() {\n    if (!this.running) return;\n    \n    // 停止所有组件\n    await this.discovery.stop();\n    await this.gossip.stop();\n    await this.messaging.stop();\n    await this.dht.stop();\n    await this.node.stop();\n    \n    this.running = false;\n    this.events.emit(EventTypes.NODE_STOPPED, { nodeId: this.nodeId });\n  }\n\n  /**\n   * 发现节点\n   */\n  async discoverPeers(timeout) {\n    return this.discovery.discover(timeout);\n  }\n\n  /**\n   * 获取已知节点\n   */\n  getPeers() {\n    return this.discovery.getKnownPeers();\n  }\n\n  /**\n   * 广播消息\n   */\n  broadcast(topic, data) {\n    return this.gossip.broadcast(topic, data);\n  }\n\n  /**\n   * 订阅主题\n   */\n  subscribe(topic, handler) {\n    return this.gossip.subscribe(topic, handler);\n  }\n\n  /**\n   * 发送消息到指定节点\n   */\n  async send(peerId, type, payload) {\n    return this.messaging.send(peerId, type, payload);\n  }\n\n  /**\n   * 注册消息处理器\n   */\n  onMessage(type, handler) {\n    return this.messaging.onMessage(type, handler);\n  }\n\n  /**\n   * 存储数据到 DHT\n   */\n  async put(key, value, ttl) {\n    return this.dht.put(key, value, ttl);\n  }\n\n  /**\n   * 从 DHT 获取数据\n   */\n  async get(key) {\n    return this.dht.get(key);\n  }\n\n  /**\n   * 获取节点信息\n   */\n  getNodeInfo() {\n    return {\n      id: this.nodeId,\n      running: this.running,\n      peers: this.getPeers().length,\n      dhtNodes: this.dht.size(),\n      uptime: this.node.getUptime ? this.node.getUptime() : 0\n    };\n  }\n\n  /**\n   * 加密数据\n   */\n  encrypt(data, key) {\n    return this.crypto.encrypt(data, key);\n  }\n\n  /**\n   * 解密数据\n   */\n  decrypt(encrypted, key) {\n    return this.crypto.decrypt(encrypted, key);\n  }\n\n  /**\n   * 签名数据\n   */\n  sign(data, privateKey) {\n    return this.crypto.sign(data, privateKey);\n  }\n\n  /**\n   * 验证签名\n   */\n  verify(data, signature, publicKey) {\n    return this.crypto.verify(data, signature, publicKey);\n  }\n\n  /**\n   * 设置事件监听\n   */\n  on(event, handler) {\n    return this.events.on(event, handler);\n  }\n\n  /**\n   * 移除事件监听\n   */\n  off(event, handler) {\n    return this.events.off(event, handler);\n  }\n\n  /**\n   * 设置组件间事件转发\n   */\n  _setupEventForwarding() {\n    // 转发 discovery 事件\n    this.discovery.on('peer:discovered', (peer) => {\n      this.events.emit(EventTypes.PEER_CONNECTED, peer);\n      \n      // 添加到其他组件\n      this.gossip.addPeer(peer.nodeId, (msg) => {\n        this.messaging.send(peer.nodeId, 'gossip', msg);\n      });\n      this.messaging.connect(peer.nodeId, peer.send);\n      this.dht.addNode({ id: peer.nodeId, address: peer.address, port: peer.port });\n    });\n    \n    // 转发 messaging 事件\n    this.messaging.on('message', (msg) => {\n      if (msg.type === 'gossip') {\n        this.gossip.receive(msg.payload);\n      } else {\n        this.events.emit(EventTypes.MESSAGE_RECEIVED, msg);\n      }\n    });\n    \n    // 转发 gossip 事件\n    this.gossip.on('message', (msg) => {\n      this.events.emit(EventTypes.GOSSIP_RECEIVED, msg);\n    });\n    \n    // 转发错误事件\n    this.discovery.on('error', (err) => this.events.emit(EventTypes.NODE_ERROR, err));\n    this.messaging.on('error', (err) => this.events.emit(EventTypes.NODE_ERROR, err));\n    this.gossip.on('error', (err) => this.events.emit(EventTypes.NODE_ERROR, err));\n  }\n}\n\nmodule.exports = Network;\n","file_path":"/root/.openclaw/workspace/agent-network-protocol/src/Network.js"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":1482,"output":1358,"cacheRead":27136,"cacheWrite":0,"totalTokens":29976,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772021715729}}
