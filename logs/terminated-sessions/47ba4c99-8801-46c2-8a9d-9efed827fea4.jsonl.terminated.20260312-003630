  \n    if [ ! -f \"$OPENCLAW_CONFIG\" ]; then\n        log_warn \"配置文件不存在: $OPENCLAW_CONFIG\"\n        log_info \"将创建新的配置文件\"\n        return 1\n    fi\n    \n    log_info \"配置文件存在: $OPENCLAW_CONFIG\"\n    return 0\n}\n\n# 备份当前配置\nbackup_config() {\n    log_step \"备份当前配置...\"\n    \n    mkdir -p \"$BACKUP_DIR\"\n    \n    if [ -f \"$OPENCLAW_CONFIG\" ]; then\n        local backup_file=\"$BACKUP_DIR/openclaw.json.backup.$(date +%Y%m%d_%H%M%S)\"\n        cp \"$OPENCLAW_CONFIG\" \"$backup_file\"\n        log_info \"配置已备份到: $backup_file\"\n    else\n        log_info \"无需备份（配置文件不存在）\"\n    fi\n}\n\n# 读取当前超时配置\nget_current_timeout() {\n    log_step \"读取当前 Gateway 超时配置...\"\n    \n    if [ -f \"$OPENCLAW_CONFIG\" ]; then\n        local timeout=$(jq -r '.gateway.timeout // empty' \"$OPENCLAW_CONFIG\" 2>/dev/null)\n        if [ -n \"$timeout\" ]; then\n            CURRENT_TIMEOUT=$timeout\n            log_info \"当前 Gateway 超时: ${CURRENT_TIMEOUT}ms ($(($CURRENT_TIMEOUT / 1000))秒)\"\n        else\n            log_info \"未找到 Gateway 超时配置，使用默认值: ${CURRENT_TIMEOUT}ms\"\n        fi\n    else\n        log_info \"配置文件不存在，使用默认值: ${CURRENT_TIMEOUT}ms\"\n    fi\n}\n\n# 更新超时配置\nupdate_timeout() {\n    local new_timeout=$1\n    \n    log_step \"更新 Gateway 超时配置到 ${new_timeout}ms ($(($new_timeout / 1000))秒)...\"\n    \n    # 创建或更新配置\n    if [ -f \"$OPENCLAW_CONFIG\" ]; then\n        # 更新现有配置\n        local temp_file=$(mktemp)\n        jq \".gateway.timeout = $new_timeout\" \"$OPENCLAW_CONFIG\" > \"$temp_file\"\n        mv \"$temp_file\" \"$OPENCLAW_CONFIG\"\n    else\n        # 创建新配置\n        mkdir -p \"$(dirname \"$OPENCLAW_CONFIG\")\"\n        cat > \"$OPENCLAW_CONFIG\" << EOF\n{\n  \"gateway\": {\n    \"timeout\": $new_timeout\n  }\n}\nEOF\n    fi\n    \n    log_info \"✅ 配置已更新\"\n}\n\n# 验证配置\nverify_config() {\n    log_step \"验证配置...\"\n    \n    if [ -f \"$OPENCLAW_CONFIG\" ]; then\n        local timeout=$(jq -r '.gateway.timeout // empty' \"$OPENCLAW_CONFIG\" 2>/dev/null)\n        if