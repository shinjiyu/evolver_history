ho \"[$(date '+%Y-%m-%d %H:%M:%S')] $1\" | tee -a \"$LOG_FILE\"\n}\n\nlog \"========== Gateway 定期重启 ==========\"\n\n# 检查 Gateway 状态\nGATEWAY_PID=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $2}')\nGATEWAY_MEM=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $6}')\nGATEWAY_MEM_MB=$((GATEWAY_MEM / 1024))\n\nlog \"Gateway PID: $GATEWAY_PID\"\nlog \"Gateway 内存: ${GATEWAY_MEM_MB} MB\"\n\n# 重启 Gateway\nlog \"停止 Gateway...\"\nkill $GATEWAY_PID\nsleep 3\n\nlog \"启动 Gateway...\"\nopenclaw gateway start > /dev/null 2>&1 &\nsleep 5\n\n# 验证\nNEW_PID=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $2}')\nNEW_MEM=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $6}')\nNEW_MEM_MB=$((NEW_MEM / 1024))\n\nlog \"新 Gateway PID: $NEW_PID\"\nlog \"新 Gateway 内存: ${NEW_MEM_MB} MB\"\nlog \"内存释放: $((GATEWAY_MEM_MB - NEW_MEM_MB)) MB\"\nlog \"✅ Gateway 定期重启完成\"\nlog \"========================================\"\n```\n\n### 策略 2: 阈值触发重启\n\n**触发条件**: Gateway 内存 > 1.0 GB\n\n**优点**:\n- 按需重启，避免不必要的中断\n- 快速响应内存泄漏\n\n**缺点**:\n- 重启时间不可预测\n- 需要频繁监控\n\n**实现**:\n```bash\n# 添加到 crontab（每 30 分钟检查一次）\n*/30 * * * * /root/.openclaw/workspace/evolver/fixes/gateway-emergency-restart.sh\n```\n\n### 策略 3: 混合策略（推荐）\n\n**结合定期重启和阈值触发**:\n- 每 12 小时定期重启（基础保障）\n- 内存 > 1.5 GB 时紧急重启（快速响应）\n- 每 30 分钟监控一次\n\n**配置**:\n```bash\n# crontab\n# 定期重启（每天 6:00 和 18:00）\n0 6,18 * * * /root/.openclaw/workspace/evolver/fixes/gateway-scheduled-restart.sh\n\n# 监控（每 30 分钟）\n*/30 * * * * /root/.openclaw/workspace/evolver/fixes/gateway-monitor.sh\n```\n\n**gateway-monitor.sh**:\n```bash\n#!/bin/bash\n# Gateway 监控脚本\n\nLOG_FILE=\"/root/.openclaw/workspace/logs/gateway-monitor.log\"\nALERT_THRESHOLD=1500  # MB\n\nlog() {\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $1\" >> \"$LOG_FILE\"\n}\n\n# 获取 Gateway 内存\nGATEWAY_MEM=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $6}')\nGATEWAY_MEM_MB=$((GATEWAY_MEM / 1024))\n\nlog \"Gateway 内存: ${GATEWAY_MEM_MB} MB\"\n\n# 检查阈值\nif [ $GATEWAY_MEM_MB -gt $ALERT_THRESHOLD ]; then\n    log \"⚠️ Gateway 内存超过阈值 (${ALERT_THRESHOLD} MB)，触发紧急重启\"\n    /root/.openclaw/workspace/evolver/fixes/gateway-emergency-restart.sh >> \"$LOG_FILE\" 2>&1\nelse\n    log \"✅ Gateway 内存正常\"\nfi\n```\n\n## 监控指标\n\n### 关键指标\n\n| 指标 | 正常范围 | 警告阈值 | 危险阈值 |\n|------|----------|----------|----------|\n| Gateway 内存 | < 800 MB | 800-1000 MB | > 1000 MB |\n| Gateway CPU | < 10% | 10-20% | > 20% |\n| 运行时间 | < 12 小时 | 12-18 小时 | > 18 小时 |\n| 健康评分 | > 8.0 | 6.0-8.0 | < 6.0 |\n\n### 监控脚本\n\n```bash\n#!/bin/bash\n# Gateway 状态监控\n\n# 获取 Gateway 信息\nGATEWAY_PID=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $2}')\nGATEWAY_MEM=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $6}')\nGATEWAY_CPU=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $3}')\nGATEWAY_UPTIME=$(ps -p $GATEWAY_PID -o etime= | tr -d ' ')\n\nGATEWAY_MEM_MB=$((GATEWAY_MEM / 1024))\n\n# 输出状态\necho \"Gateway 状态:\"\necho \"  PID: $GATEWAY_PID\"\necho \"  内存: ${GATEWAY_MEM_MB} MB\"\necho \"  CPU: ${GATEWAY_CPU}%\"\necho \"  运行时间: $GATEWAY_UPTIME\"\n\n# 评估健康度\nif [ $GATEWAY_MEM_MB -lt 800 ] && [ $(echo \"$GATEWAY_CPU < 10\" | bc) -eq 1 ]; then\n    echo \"  状态: ✅ 优秀\"\nelif [ $GATEWAY_MEM_MB -lt 1000 ] && [ $(echo \"$GATEWAY_CPU < 20\" | bc) -eq 1 ]; then\n    echo \"  状态: 🟢 良好\"\nelif [ $GATEWAY_MEM_MB -lt 1500 ]; then\n    echo \"  状态: 🟡 一般 - 建议重启\"\nelse\n    echo \"  状态: 🔴 危险 - 需要立即重启\"\nfi\n```\n\n## 重启时间规划\n\n### 最佳重启时间\n\n**推荐时间**（低峰期）:\n- 凌晨 6:00（用户活动最少）\n- 下午 18:00（午休后）\n\n**避免时间**:\n- 9:00-11:00（工作高峰）\n- 14:00-17:00（工作高峰）\n- 20:00-22:00（晚间高峰）\n\n### 重启时间表\n\n| 时间 | 频率 | 说明 |\n|------|------|------|\n| 06:00 | 每天 | 主重启（清理内存） |\n| 18:00 | 每天 | 次重启（预防积累） |\n| 其他 | 按需 | 内存 > 1.5 GB 时 |\n\n## 故障恢复\n\n### 重启失败处理\n\n```bash\n#!/bin/bash\n# Gateway 重启失败恢复\n\n# 尝试重启 Gateway\nif ! openclaw gateway start; then\n    echo \"⚠️ Gateway 启动失败，尝试强制重启\"\n    \n    # 杀死所有相关进程\n    pkill -9 -f openclaw-gateway\n    sleep 2\n    \n    # 重新启动\n    if openclaw gateway start; then\n        echo \"✅ Gateway 强制重启成功\"\n    else\n        echo \"❌ Gateway 强制重启失败，需要人工介入\"\n        # 发送告警\n        echo \"Gateway 启动失败\" | logger -t openclaw-critical\n    fi\nfi\n```\n\n### 连接恢复\n\n重启后需要等待客户端重新连接：\n\n```bash\n# 等待 Gateway 完全启动\nsleep 10\n\n# 检查 Gateway 是否正常响应\nif curl -s http://127.0.0.1:18789/health > /dev/null; then\n    echo \"✅ Gateway 已就绪\"\nelse\n    echo \"⚠️ Gateway 未就绪，继续等待...\"\n    sleep 10\nfi\n```\n\n## 性能优化\n\n### 内存优化\n\n**配置优化**:\n```json\n{\n  \"gateway\": {\n    \"maxConnections\": 100,\n    \"connectionTimeout\": 30000,\n    \"keepAlive\": true,\n    \"gc\": {\n      \"enabled\": true,\n      \"interval\": 300000\n    }\n  }\n}\n```\n\n**代码层面**（如果可控）:\n- 定期执行垃圾回收\n- 限制缓存大小\n- 及时释放未使用的资源\n\n### 连接池管理\n\n```bash\n# 检查 Gateway 连接数\nnetstat -an | grep 18789 | grep ESTABLISHED | wc -l\n\n# 如果连接数过多，考虑重启\nCONNECTIONS=$(netstat -an | grep 18789 | grep ESTABLISHED | wc -l)\nif [ $CONNECTIONS -gt 50 ]; then\n    echo \"⚠️ Gateway 连接数过多 ($CONNECTIONS)，建议重启\"\nfi\n```\n\n## 日志管理\n\n### 日志轮转\n\n```bash\n# /etc/logrotate.d/openclaw-gateway\n/root/.openclaw/workspace/logs/gateway-*.log {\n    daily\n    rotate 7\n    compress\n    delaycompress\n    missingok\n    notifempty\n    create 0644 root root\n}\n```\n\n### 日志分析\n\n```bash\n# 分析最近的重启记录\ngrep \"Gateway 定期重启\" /root/.openclaw/workspace/logs/gateway-maintenance.log | tail -10\n\n# 分析内存趋势\ngrep \"Gateway 内存\" /root/.openclaw/workspace/logs/gateway-monitor.log | tail -20\n```\n\n## 最佳实践\n\n### ✅ 推荐做法\n\n1. **定期重启**\n   - 每 12 小时重启一次\n   - 选择低峰期时间\n   - 自动化执行\n\n2. **监控告警**\n   - 每 30 分钟检查一次\n   - 内存 > 1.5 GB 告警\n   - 自动触发重启\n\n3. **日志记录**\n   - 记录所有重启操作\n   - 跟踪内存趋势\n   - 生成维护报告\n\n### ❌ 避免做法\n\n1. **不要频繁重启**\n   - 避免每小时重启\n   - 最短间隔 6 小时\n\n2. **不要在高峰期重启**\n   - 避免工作时间重启\n   - 除非紧急情况\n\n3. **不要忽略监控**\n   - 定期检查日志\n   - 关注内存趋势\n\n## 相关 Skills\n\n- `emergency-response` - 紧急响应\n- `system-health-orchestrator` - 系统健康编排\n- `peak-hours-monitoring` - 高峰期监控\n\n## 相关 Patterns\n\n- **PAT-036**: Gateway 内存泄漏（本 Skill 解决）\n- **PAT-049**: Gateway 超时（部分解决）\n- **PAT-038**: Gateway 内存泄漏（历史）\n\n---\n\n**创建日期**: 2026-02-28\n**来源**: Round 257 - Gateway 内存持续高企（1,211 MB）\n**解决问题**: Gateway 内存泄漏，定期维护\n**维护频率**: 每 12 小时\n","path":"/root/.openclaw/workspace/skills/gateway-maintenance/SKILL.md"}},{"type":"toolCall","id":"call_dea847a39459445f846d0866","name":"write","arguments":{"content":"#!/bin/bash\n\n# Gateway 定期重启脚本\n# 用途：预防性维护，防止内存泄漏积累\n# 创建日期：2026-02-28\n# 调度：每天 6:00 和 18:00\n\nset -e\n\n# 颜色和日志\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nNC='\\033[0m'\n\nLOG_FILE=\"/root/.openclaw/workspace/logs/gateway-maintenance.log\"\nREPORT_FILE=\"/root/.openclaw/workspace/memory/gateway-scheduled-restart-$(date +%Y%m%d-%H%M%S).md\"\n\nlog() {\n    local message=\"[$(date '+%Y-%m-%d %H:%M:%S')] $1\"\n    echo -e \"${GREEN}$message${NC}\"\n    echo \"$message\" >> \"$LOG_FILE\"\n}\n\nlog_warn() {\n    local message=\"[$(date '+%Y-%m-%d %H:%M:%S')] ⚠️ $1\"\n    echo -e \"${YELLOW}$message${NC}\"\n    echo \"$message\" >> \"$LOG_FILE\"\n}\n\n# 获取 Gateway 信息\nget_gateway_info() {\n    GATEWAY_PID=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $2}')\n    if [ -n \"$GATEWAY_PID\" ]; then\n        GATEWAY_MEM=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $6}')\n        GATEWAY_MEM_MB=$((GATEWAY_MEM / 1024))\n        GATEWAY_CPU=$(ps aux | grep openclaw-gateway | grep -v grep | awk '{print $3}')\n        return 0\n    else\n        return 1\n    fi\n}\n\n# 生成报告\ngenerate_report() {\n    local old_pid=$1\n    local old_mem=$2\n    local new_pid=$3\n    local new_mem=$4\n    \n    cat > \"$REPORT_FILE\" << EOF\n# Gateway 定期重启报告\n\n**时间**: $(date)\n**类型**: 预防性维护\n\n---\n\n## 重启前状态\n\n- PID: $old_pid\n- 内存: ${old_mem} MB\n- CPU: ${GATEWAY_CPU}%\n\n## 重启后状态\n\n- PID: $new_pid\n- 内存: ${new_mem} MB\n- 内存释放: $((old_mem - new_mem)) MB\n\n---\n\n## 效果评估\n\n- 内存下降: $(( (old_mem - new_mem) * 100 / old_mem ))%\n- 状态: $(if [ $new_mem -lt 500 ]; then echo \"✅ 优秀\"; elif [ $new_mem -lt 800 ]; then echo \"🟢 良好\"; else echo \"🟡 一般\"; fi)\n\n## 下次维护\n\n- 预定时间: $(date -d '+12 hours' '+%Y-%m-%d %H:%M:%S')\n\n---\n\n**报告生成时间**: $(date)\nEOF\n}\n\n# 主流程\nmain() {\n    log \"========== Gateway 定期重启 ==========\"\n    \n    # 获取当前状态\n    if ! get_gateway_info; then\n        log_warn \"Gateway 未运行，跳过重启\"\n        exit 0\n    fi\n    \n    local old_pid=$GATEWAY_PID\n    local old_mem=$GATEWAY_MEM_MB\n    \n    log \"重启前: PID=$old_pid, 内存=${old_mem}MB, CPU=${GATEWAY_CPU}%\"\n    \n    # 停止 Gateway\n    log \"停止 Gateway...\"\n    kill $old_pid\n    sleep 3\n    \n    # 确认停止\n    if ps -p $old_pid > /dev/null 2>&1; then\n        log_warn \"进程未响应，强制终止\"\n        kill -9 $old_pid\n        sleep 2\n    fi\n    \n    # 启动 Gateway\n    log \"启动 Gateway...\"\n    openclaw gateway start > /dev/null 2>&1 &\n    sleep 5\n    \n    # 验证启动\n    if get_gateway_info; then\n        local new_pid=$GATEWAY_PID\n        local new_mem=$GATEWAY_MEM_MB\n        \n        log \"重启后: PID=$new_pid, 内存=${new_mem}MB\"\n        log \"内存释放: $((old_mem - new_mem)) MB\"\n        log \"✅ Gateway 定期重启完成\"\n        \n        # 生成报告\n        generate_report \"$old_pid\" \"$old_mem\" \"$new_pid\" \"$new_mem\"\n        log \"报告已生成: $REPORT_FILE\"\n    else\n        log_warn \"❌ Gateway 启动失败\"\n        exit 1\n    fi\n    \n    log \"========================================\"\n}\n\n# 运行\nmain \"$@\"\n","path":"/root/.openclaw/workspace/evolver/fixes/gateway-scheduled-restart.sh"}},{"type":"toolCall","id":"call_ef1d0df579fd4dd9b2f6328c","name":"exec","arguments":{"command":"chmod +x /root/.openclaw/workspace/evolver/fixes/gateway-scheduled-restart.sh","workdir":"/root/.openclaw/workspace"}}],"api":"openai-completions","provider":"zai","model":"glm-5","usage":{"input":2493,"output":4278,"cacheRead":124800,"cacheWrite":0,"totalTokens":131571,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772281820760