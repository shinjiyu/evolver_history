{"type":"message","id":"393a1636","parentId":"bc5581ae","timestamp":"2026-02-25T09:07:31.910Z","message":{"role":"toolResult","toolCallId":"call_cf05ed264e654243be28f037","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * EvoMap Bounty зҢҺеҸ–д»»еҠЎ\n * йў‘зҺҮ: жҜҸ 4 е°Ҹж—¶\n * еҠҹиғҪ: жү«жҸҸгҖҒиҜ„дј°е№¶е®ҢжҲҗ Bounty д»»еҠЎ\n */\n\nconst https = require('https');\nconst fs = require('fs');\n\nconst LOG_FILE = '/root/.openclaw/workspace/logs/evomap-bounty.log';\nconst CREDENTIALS_FILE = '/root/.openclaw/workspace/memory/evomap-operation-plan/node-credentials.json';\nconst BOUNTY_DB = '/root/.openclaw/workspace/memory/evomap-bounty-db.json';\n\n// ж—Ҙеҝ—еҮҪж•°\nfunction log(message) {\n  const timestamp = new Date().toISOString();\n  const logLine = `[${timestamp}] ${message}\\n`;\n  console.log(message);\n  fs.appendFileSync(LOG_FILE, logLine);\n}\n\n// иҜ»еҸ–иҠӮзӮ№еҮӯиҜҒ\nfunction getCredentials() {\n  if (!fs.existsSync(CREDENTIALS_FILE)) {\n    return null;\n  }\n  return JSON.parse(fs.readFileSync(CREDENTIALS_FILE, 'utf8'));\n}\n\n// иҜ»еҸ– Bounty ж•°жҚ®еә“\nfunction getBountyDB() {\n  if (!fs.existsSync(BOUNTY_DB)) {\n    return { completed: [], claimed: [] };\n  }\n  return JSON.parse(fs.readFileSync(BOUNTY_DB, 'utf8'));\n}\n\n// дҝқеӯҳ Bounty ж•°жҚ®еә“\nfunction saveBountyDB(db) {\n  fs.writeFileSync(BOUNTY_DB, JSON.stringify(db, null, 2));\n}\n\n// иҺ·еҸ– Bounty еҲ—иЎЁ\nfunction fetchBounties(credentials) {\n  return new Promise((resolve, reject) => {\n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: '/a2a/bounties',\n      method: 'GET',\n      headers: {\n        'X-Node-ID': credentials.node_id\n      }\n    };\n    \n    const req = https.request(options, (res) => {\n      let body = '';\n      res.on('data', (chunk) => { body += chunk; });\n      res.on('end', () => {\n        if (res.statusCode === 200) {\n          try {\n            const result = JSON.parse(body);\n            resolve(result.bounties || []);\n          } catch (e) {\n            reject(new Error('Invalid response: ' + body));\n          }\n        } else {\n          reject(new Error(`HTTP ${res.statusCode}: ${body}`));\n        }\n      });\n    });\n    \n    req.on('error', reject);\n    req.setTimeout(30000, () => {\n      req.destroy();\n      reject(new Error('Request timeout'));\n    });\n    \n    req.end();\n  });\n}\n\n// иҜ„дј° Bounty д»»еҠЎ\nfunction evaluateBounty(bounty, credentials, db) {\n  // и·іиҝҮе·Іе®ҢжҲҗзҡ„д»»еҠЎ\n  if (db.completed.includes(bounty.id)) {\n    return { eligible: false, reason: 'Already completed' };\n  }\n  \n  // и·іиҝҮе·Іи®ӨйўҶзҡ„д»»еҠЎ\n  if (db.claimed.includes(bounty.id)) {\n    return { eligible: false, reason: 'Already claimed' };\n  }\n  \n  // жЈҖжҹҘдҝЎиӘүиҰҒжұӮ\n  if (bounty.min_reputation && bounty.min_reputation > 50) {\n    return { eligible: false, reason: `Reputation too low (required: ${bounty.min_reputation})` };\n  }\n  \n  // жЈҖжҹҘйўҶеҹҹеҢ№й…Қ\n  const supportedDomains = ['architecture', 'devops', 'automation', 'optimization'];\n  const bountyDomains = bounty.domains || [];\n  const hasMatch = bountyDomains.some(d => supportedDomains.includes(d));\n  \n  if (!hasMatch && bountyDomains.length > 0) {\n    return { eligible: false, reason: 'Domain mismatch' };\n  }\n  \n  // иҜ„дј°еҲҶж•°\n  let score = 0;\n  score += (bounty.reward || 10); // еҹәзЎҖеҘ–еҠұ\n  score += bounty.priority === 'high' ? 20 : 0; // й«ҳдјҳе…Ҳзә§\n  score += bountyDomains.includes('automation') ? 10 : 0; // иҮӘеҠЁеҢ–йўҶеҹҹеҠ еҲҶ\n  \n  return {\n    eligible: true,\n    score: score,\n    reason: 'Eligible'\n  };\n}\n\n// Claim Bounty\nfunction claimBounty(credentials, bountyId) {\n  return new Promise((resolve, reject) => {\n    const payload = {\n      node_id: credentials.node_id,\n      bounty_id: bountyId,\n      timestamp: new Date().toISOString()\n    };\n    \n    const data = JSON.stringify(payload);\n    \n    const options = {\n      hostname: 'evomap.ai',\n      port: 443,\n      path: `/a2a/bounties/${bountyId}/claim`,\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'Content-Length': Buffer.byteLength(data)\n      }\n    };\n    \n    const req = https.request(options, (res) => {\n      let body = '';\n      res.on('data', (chunk) => { body += chunk; });\n      res.on('end', () => {\n        if (res.statusCode === 200) {\n          try {\n            resolve(JSON.parse(body));\n          } catch (e) {\n            reject(new Error('Invalid response: ' + body));\n          }\n        } else {\n          reject(new Error(`HTTP ${res.statusCode}: ${body}`));\n        }\n      });\n    });\n    \n    req.on('error', reject);\n    req.setTimeout(30000, () => {\n      req.destroy();\n      reject(new Error('Request timeout'));\n    });\n    \n    req.write(data);\n    req.end();\n  });\n}\n\n// дё»еҮҪж•°\nasync function main() {\n  log('в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ');\n  log('  EvoMap Bounty зҢҺеҸ–д»»еҠЎ');\n  log('в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ');\n  \n  // жЈҖжҹҘеҮӯиҜҒ\n  const credentials = getCredentials();\n  if (!credentials) {\n    log('вқҢ жңӘжүҫеҲ°иҠӮзӮ№еҮӯиҜҒпјҢиҜ·е…ҲжіЁеҶҢиҠӮзӮ№');\n    process.exit(1);\n  }\n  \n  log(`иҠӮзӮ№: ${credentials.node_id}`);\n  \n  // иҜ»еҸ–ж•°жҚ®еә“\n  const db = getBountyDB();\n  \n  // иҺ·еҸ– Bounty еҲ—иЎЁ\n  log('\\nжӯЈеңЁжү«жҸҸ Bounty д»»еҠЎ...\\n');\n  \n  try {\n    const bounties = await fetchBounties(credentials);\n    log(`еҸ‘зҺ° ${bounties.length} дёӘ Bounty д»»еҠЎ`);\n    \n    // иҜ„дј°жҜҸдёӘд»»еҠЎ\n    const eligibleTasks = [];\n    for (const bounty of bounties) {\n      const eval = evaluateBounty(bounty, credentials, db);\n      log(`  - ${bounty.id}: ${eval.eligible ? 'вң…' : 'вқҢ'} ${eval.reason}`);\n      \n      if (eval.eligible) {\n        eligibleTasks.push({ bounty, score: eval.score });\n      }\n    }\n    \n    // жҢүеҲҶж•°жҺ’еәҸ\n    eligibleTasks.sort((a, b) => b.score - a.score);\n    \n    // Claim жңҖеӨҡ 1 дёӘд»»еҠЎ\n    if (eligibleTasks.length > 0) {\n      const { bounty } = eligibleTasks[0];\n      log(`\\nйҖүжӢ©д»»еҠЎ: ${bounty.id}`);\n      log(`  жҸҸиҝ°: ${bounty.description || 'N/A'}`);\n      log(`  еҘ–еҠұ: ${bounty.reward} credits`);\n      \n      try {\n        const result = await claimBounty(credentials, bounty.id);\n        log(`  вң… и®ӨйўҶжҲҗеҠҹ`);\n        \n        // и®°еҪ•еҲ°ж•°жҚ®еә“\n        db.claimed.push(bounty.id);\n        saveBountyDB(db);\n        \n      } catch (error) {\n        log(`  вқҢ и®ӨйўҶеӨұиҙҘ: ${error.message}`);\n      }\n      \n    } else {\n      log('\\nжІЎжңүз¬ҰеҗҲжқЎд»¶зҡ„д»»еҠЎ');\n    }\n    \n  } catch (error) {\n    log(`вқҢ иҺ·еҸ– Bounty еҲ—иЎЁеӨұиҙҘ: ${error.message}`);\n  }\n  \n  log('\\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ');\n  log('  Bounty зҢҺеҸ–д»»еҠЎе®ҢжҲҗ');\n  log('в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\\n');\n}\n\nmain().catch(error => {\n  log(`вқҢ д»»еҠЎжү§иЎҢеӨұиҙҘ: ${error.message}`);\n  process.exit(1);\n});\n"}],"isError":false,"timestamp":1772010451909}}
