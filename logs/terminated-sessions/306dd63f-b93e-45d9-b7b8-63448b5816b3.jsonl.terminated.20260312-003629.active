eouts: [],\\n    toolFailures: [],\\n    processErrors: [],\\n    configErrors: []\\n  },\\n  warnings: [],\\n  patterns: {}\\n};\\n\\n// 获取文件\\nconst files = fs.readdirSync(sessionsDir)\\n  .filter(f => f.endsWith('.jsonl'))\\n  .map(f => ({\\n    name: f,\\n    path: path.join(sessionsDir, f),\\n    mtime: fs.statSync(path.join(sessionsDir, f)).mtime.getTime(),\\n    size: fs.statSync(path.join(sessionsDir, f)).size\\n  }))\\n  .filter(f => f.mtime >= sixHoursAgo)\\n  .sort((a, b) => b.mtime - a.mtime);\\n\\nanalysis.totalFiles = files.length;\\n\\nconsole.log(`=== Deep Log Analysis ===`);\\nconsole.log(`Time: ${analysis.scanTime}`);\\nconsole.log(`Files to analyze: ${files.length}\\\\n`);\\n\\n// 分析每个文件\\nfiles.forEach(file => {\\n  try {\\n    const content = fs.readFileSync(file.path, 'utf8');\\n    const lines = content.split('\\\\n').filter(l => l.trim());\\n    analysis.totalLines += lines.length;\\n    \\n    lines.forEach(line => {\\n      try {\\n        const data = JSON.parse(line);\\n        const lineStr = JSON.stringify(data);\\n        const lineLower = lineStr.toLowerCase();\\n        \\n        // Rate Limit (429)\\n        if (lineLower.includes('429') || lineLower.includes('rate limit')) {\\n          analysis.errors.rateLimits.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n        // Server Errors (5xx)\\n        if (lineLower.includes('500') || lineLower.includes('502') || lineLower.includes('503')) {\\n          analysis.errors.serverErrors.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n        // Auth Errors (401/403)\\n        if (lineLower.includes('401') || lineLower.includes('403') || \\n            (lineLower.includes('unauthorized') || lineLower.includes('forbidden'))) {\\n          analysis.errors.authErrors.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n        // Connection Errors\\n        if (lineLower.includes('etimedout') || lineLower.includes('econnrefused') || \\n            lineLower.includes('enotfound')) {\\n          analysis.errors.connectionErrors.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n        // Timeouts\\n        if (lineLower.includes('timeout') && !lineLower.includes('etimedout')) {\\n          analysis.errors.timeouts.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n        // Process Errors\\n        if (lineLower.includes('killed') || lineLower.includes('sigterm') || \\n            lineLower.includes('exited with code')) {\\n          analysis.errors.processErrors.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n      } catch (e) {}\\n    });\\n  } catch (e) {}\\n});\\n\\n// 统计\\nconsole.log('=== Analysis Summary ===\\\\n');\\nconsole.log(`Total Files: ${analysis.totalFiles}`);\\nconsole.log(`Total Lines: ${analysis.totalLines}\\\\n`);\\n\\nconsole.log('=== Errors by Type ===');\\nconsole.log(`Rate Limits (429): ${analysis.errors.rateLimits.length}`);\\nconsole.log(`Server Errors (5xx): ${analysis.errors.serverErrors.length}`);\\nconsole.log(`Auth Errors (401/403): ${analysis.errors.authErrors.length}`);\\nconsole.log(`Connection Errors: ${analysis.errors.connectionErrors.length}`);\\nconsole.log(`Timeouts: ${analysis.errors.timeouts.length}`);\\nconsole.log(`Process Errors: ${analysis.errors.processErrors.length}\\\\n`);\\n\\n// 分析受影响的任务\\nconsole.log(