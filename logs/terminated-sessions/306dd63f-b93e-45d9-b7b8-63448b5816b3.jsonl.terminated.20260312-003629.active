a = JSON.parse(line);\\n      \\n      // 统计任务\\n      if (data.type === 'message' && data.message && data.message.role === 'user') {\\n        const text = JSON.stringify(data.message.content);\\n        const cronMatch = text.match(/\\\\[cron:[^\\\\s]+\\\\s+([^\\\\]]+)\\\\]/);\\n        if (cronMatch) {\\n          const task = cronMatch[1];\\n          results.tasks[task] = results.tasks[task] || { total: 0, hourly: {} };\\n          results.tasks[task].total++;\\n          \\n          // 按小时统计\\n          const hour = data.timestamp ? data.timestamp.substring(11, 13) : 'unknown';\\n          results.tasks[task].hourly[hour] = (results.tasks[task].hourly[hour] || 0) + 1;\\n        }\\n      }\\n      \\n      // 检查错误\\n      if (data.type === 'message' && data.message && data.message.role === 'toolResult') {\\n        const result = JSON.stringify(data.message.content);\\n        \\n        // 429\\n        if (result.includes('429') && result.includes('error')) {\\n          results.errors.api429.push({\\n            time: data.timestamp,\\n            tool: data.message.toolName,\\n            file: file.name\\n          });\\n        }\\n        \\n        // 5xx\\n        if ((result.includes('500') || result.includes('502') || result.includes('503')) && result.includes('error')) {\\n          results.errors.api5xx.push({\\n            time: data.timestamp,\\n            tool: data.message.toolName,\\n            file: file.name\\n          });\\n        }\\n        \\n        // Connection\\n        if (result.includes('ETIMEDOUT') || result.includes('ECONNREFUSED') || result.includes('ENOTFOUND')) {\\n          results.errors.connectionErrors.push({\\n            time: data.timestamp,\\n            tool: data.message.toolName\\n          });\\n        }\\n      }\\n    } catch (e) {}\\n  });\\n});\\n\\n// 计算统计\\nconsole.log('=== Summary ===\\\\n');\\nconsole.log(`Total files: ${results.files}`);\\nconsole.log(`Total lines: ${results.lines}\\\\n`);\\n\\nconsole.log('=== Errors ===');\\nconsole.log(`API 429 (Rate Limit): ${results.errors.api429.length}`);\\nconsole.log(`API 5xx (Server Error): ${results.errors.api5xx.length}`);\\nconsole.log(`Connection Errors: ${results.errors.connectionErrors.length}\\\\n`);\\n\\n// 计算错误率（按小时）\\nconst hourlyErrors = {};\\nresults.errors.api429.forEach(e => {\\n  if (e.time) {\\n    const hour = e.time.substring(11, 13);\\n    hourlyErrors[hour] = hourlyErrors[hour] || { '429': 0, '5xx': 0 };\\n    hourlyErrors[hour]['429']++;\\n  }\\n});\\n\\nresults.errors.api5xx.forEach(e => {\\n  if (e.time) {\\n    const hour = e.time.substring(11, 13);\\n    hourlyErrors[hour] = hourlyErrors[hour] || { '429': 0, '5xx': 0 };\\n    hourlyErrors[hour]['5xx']++;\\n  }\\n});\\n\\nconsole.log('=== Hourly Error Distribution ===');\\nObject.entries(hourlyErrors)\\n  .sort((a, b) => a[0].localeCompare(b[0]))\\n  .slice(-6)\\n  .forEach(([hour, errors]) => {\\n    console.log(`${hour}:00 - 429: ${errors['429']}, 5xx: ${errors['5xx']}`);\\n  });\\n\\nconsole.log('\\\\n=== Task Frequency (Top 5) ===');\\nconst sortedTasks = Object.entries(results.tasks)\\n  .map(([name, data]) => ({ name, total: data.total, hourly: data.hourly }))\\n  .sort((a, b) => b.total - a.total)\\n  .slice(0, 5);\\n\\nsortedTasks.forEach(task => {\\n  const hourlyRate = (task.total / 6).toFixed(1);\\n  console.log(`${task.name}: ${task.total} total (${hourlyRate}/hour)`);\\n});\\n\\n// 保存结果\\nfs.writeFileSync('/tmp/deep_analysis_results.json', JSON.stringify(results, null, 2));\\nconsole.log('\\\\n\\\\nResults saved to /tmp/deep_analysis_results.json');\\nSCRIPT\\n\\nnode /tmp/deep_analysis_6hour.js\",\"timeout\":60}}],\"api\":\"openai-completions\",\"provider\":\"zai\",\"model\":\"glm-5\",\"usage\":{\"input\":83337,\"output\":1356,\"cacheRead\":3008,\"cacheWrite\":0,\"totalTokens\":87701,\"cost\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"total\":0}},\"stopReason\":\"toolUse\",\"timestamp\":1771886769981}}\n{\"type