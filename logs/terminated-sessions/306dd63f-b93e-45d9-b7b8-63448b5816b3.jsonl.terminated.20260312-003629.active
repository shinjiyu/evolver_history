t/.openclaw/agents/main/sessions';\\nconst sixHoursAgo = Date.now() - (6 * 60 * 60 * 1000);\\n\\n// 分析结果\\nconst analysis = {\\n  totalFiles: 0,\\n  totalLines: 0,\\n  errors: [],\\n  warnings: [],\\n  timeouts: [],\\n  apiFailures: [],\\n  performance: [],\\n  patterns: {}\\n};\\n\\n// 关键词模式\\nconst errorPatterns = [\\n  /error/i, /exception/i, /failed/i, /failure/i,\\n  /ETIMEDOUT/, /ECONNREFUSED/, /ENOTFOUND/,\\n  /401/, /403/, /404/, /429/, /500/, /502/, /503/\\n];\\n\\nconst warningPatterns = [\\n  /warn/i, /warning/i, /deprecated/i, /timeout/i\\n];\\n\\n// 读取最近的文件\\nconst files = fs.readdirSync(sessionsDir)\\n  .filter(f => f.endsWith('.jsonl'))\\n  .map(f => ({\\n    name: f,\\n    path: path.join(sessionsDir, f),\\n    mtime: fs.statSync(path.join(sessionsDir, f)).mtime.getTime()\\n  }))\\n  .filter(f => f.mtime >= sixHoursAgo)\\n  .sort((a, b) => b.mtime - a.mtime);\\n\\nanalysis.totalFiles = files.length;\\n\\nconsole.log(`Found ${files.length} files in last 6 hours\\\\n`);\\n\\n// 分析每个文件\\nfiles.forEach(file => {\\n  try {\\n    const content = fs.readFileSync(file.path, 'utf8');\\n    const lines = content.split('\\\\n').filter(l => l.trim());\\n    analysis.totalLines += lines.length;\\n    \\n    lines.forEach((line, idx) => {\\n      try {\\n        const data = JSON.parse(line);\\n        const content = JSON.stringify(data);\\n        const timestamp = data.timestamp || data.time || file.mtime;\\n        \\n        // 检查错误\\n        errorPatterns.forEach(pattern => {\\n          if (pattern.test(content)) {\\n            analysis.errors.push({\\n              file: file.name,\\n              line: idx + 1,\\n              pattern: pattern.toString(),\\n              snippet: content.substring(0, 300),\\n              timestamp: timestamp\\n            });\\n          }\\n        });\\n        \\n        // 检查警告\\n        warningPatterns.forEach(pattern => {\\n          if (pattern.test(content)) {\\n            analysis.warnings.push({\\n              file: file.name,\\n              line: idx + 1,\\n              pattern: pattern.toString(),\\n              snippet: content.substring(0, 300),\\n              timestamp: timestamp\\n            });\\n          }\\n        });\\n        \\n      } catch (e) {\\n        // 跳过解析错误的行\\n      }\\n    });\\n  } catch (e) {\\n    console.error(`Error reading ${file.name}: ${e.message}`);\\n  }\\n});\\n\\n// 去重并统计模式\\nconst errorCounts = {};\\nanalysis.errors.forEach(e => {\\n  const key = e.pattern;\\n  errorCounts[key] = (errorCounts[key] || 0) + 1;\\n});\\n\\nconst warningCounts = {};\\nanalysis.warnings.forEach(w => {\\n  const key = w.pattern;\\n  warningCounts[key] = (warningCounts[key] || 0) + 1;\\n});\\n\\nconsole.log('=== Analysis Summary ===');\\nconsole.log(`Total Files: ${analysis.totalFiles}`);\\nconsole.log(`Total Lines: ${analysis.totalLines}`);\\nconsole.log(`Errors Found: ${analysis.errors.length}`);\\nconsole.log(`Warnings Found: ${analysis.warnings.length}\\\\n`);\\n\\nconsole.log('=== Error Patterns ===');\\nObject.entries(errorCounts)\\n  .sort((a, b) => b[1] - a[1])\\n  .forEach(([pattern, count]) => {\\n    console.log(`${pattern}: ${count} occurrences`);\\n  });\\n\\nconsole.log('\\\\n=== Warning Patterns ===');\\nObject.entries(warningCounts)\\n  .sort((a, b) => b[1] - a[1])\\n  .forEach(([pattern, count]) => {\\n    console.log(`${pattern}: ${count} occurrences`);\\n  });\\n\\nconsole.log('\\\\n=== Sample Errors (first 5) ===');\\nanalysis.errors.slice(0, 5).forEach((e, i) => {\\n  console.log(`\\\\n[${i + 1}] ${e.file}:${e.line}`);\\n  console.log(`Pattern: ${e.pattern}`);\\n  console.log(`Snippet: ${e.snippet.substring(0, 200)}...`);\\n});\\n\\n// 保存详细分析\\nfs.writeFileSync('/tmp/log_analysis.json', JSON.stringify(analysis, null, 2));\\nconsole.log('\\\\n\\\\nDetailed analysis saved to /tmp/log_analysis.json');\\nSCRIPT\\n\\nnode /tmp/analyze_logs.js\",\"timeout\":60}}],\"api\":\"openai-completions\",\"provider\":\"zai\",\"model\":\"glm-5\",\"usage\":{\"input\":1772,\"output\":1097,\"cacheRead\":12032,\"cacheWrite\":0,\"totalTokens\":14901,\"cost\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"total\":0}},\"stopReason\":\"toolUse\",\"timestamp\":1771876909214}}\n{\"type\":\"message\",\"id\":\"79f0ac83\",\"parentId\":\"87d7419b\",\"timestamp\":\"2026-02-23T20:03:00.882Z\",\"message\":{\"role\":\"assistant\",\"content\":[{\"type\":\"thinking\",\"thinking\":\"非常好！我发现了一些重要的问题：\\n1. 大量的 HTTP 状态码错误：429 (294次), 500 (252次), 404 (209次), 401 (206次), 503 (173次), 403 (161次), 502 (160次)\\n2. 306 个 timeout 相关的警告\\n3. 7 个 ECONNREFUSED 错误\\n\\n这些都是严重的问题。让我深入分析具体的错误内容，特别是：\\n- 429 错误（速率限制）\\n- 500/502/503 错误（服务器错误）\\n- 401/403 错误（认证/授权问题）\\n- Timeout 问题\\n\\n让我提取更详细的错误信息。\",\"thinkingSignature\":\"reasoning_content\"},{\"type\":\"text\",\"text\":\"发现大量问题！让我深入分析具体的错误内容。\"},{\"type\":\"toolCall\",\"id\":\"call_2fdc75fe6d664cc49389f948\",\"name\":\"exec\",\"arguments\":{\"command\":\"cat > /tmp/deep_analyze.js << 'SCRIPT'\\nconst fs = require('fs');\\n\\nconst data = JSON.parse(fs.readFileSync('/tmp/log_analysis.json', 'utf8'));\\n\\n// 分类错误\\nconst categorizedErrors = {\\n  rateLimits: [],  // 429\\n  serverErrors: [], // 500, 502, 503\\n  authErrors: [],  // 401, 403\\n  notFound: [],    // 404\\n  connectionErrors: [], // ETIMEDOUT, ECONNREFUSED, ENOTFOUND\\n  timeouts: []\\n};\\n\\n// 提取详细错误信息\\ndata.errors.forEach(e => {\\n  const snippet = e.snippet.toLowerCase();\\n  \\n  if (snippet.includes('429') || snippet.includes('rate limit')) {\\n    categorizedErrors.rateLimits.push(e);\\n  }\\n  if (snippet.includes('500') || snippet.includes('502') || snippet.includes('503')) {\\n    categorizedErrors.serverErrors.push(e);\\n  }\\n  if (snippet.includes('401') || snippet.includes('403') || snippet.includes('unauthorized') || snippet.includes('forbidden')) {\\n    categorizedErrors.authErrors.push(e);\\n  }\\n  if (snippet.includes('404') || snippet.includes('not found')) {\\n    categorizedErrors.notFound.push(e);\\n  }\\n  if (snippet.includes('etimedout') || snippet.includes('econnrefused') || snippet.includes('enotfound')) {\\n    categorizedErrors.connectionErrors.push(e);\\n  }\\n});\\n\\ndata.warnings.forEach(w => {\\n  if (w.snippet.toLowerCase().includes('timeout')) {\\n    categorizedErrors.timeouts.push(w);\\n  }\\n});\\n\\nconsole.log('=== Categorized Errors ===\\\\n');\\n\\nconsole.log(`[P0] Rate Limits (429): ${categorizedErrors.rateLimits.length}`);\\nconsole.log(`[P0] Server Errors (5xx): ${categorizedErrors.serverErrors.length}`);\\nconsole.log(`[P1] Auth Errors (401/403): ${categorizedErrors.authErrors.length}`);\\nconsole.log(`[P1] Not Found (404): ${categorizedErrors.notFound.length}`);\\nconsole.log(`[P0] Connection Errors: ${categorizedErrors.connectionErrors.length}`);\\nconsole.log(`[P1] Timeouts: ${categorizedErrors.timeouts.length}\\\\n`);\\n\\n// 提取具体的错误信息\\nconsole.log('=== Detailed Rate Limit Errors ===');\\nconst rateLimitDetails = new Set();\\ncategorizedErrors.rateLimits.slice(0, 20).forEach(e => {\\n  try {\\n    const parsed = JSON.parse(e.snippet);\\n    if (parsed.message && parsed.message.content) {\\n      const content = JSON.stringify(parsed.message.content);\\n      if (content.includes('429')) {\\n        rateLimitDetails.add(content.substring(0, 400));\\n      }\\n    }\\n  } catch (err) {}\\n});\\nrateLimitDetails.forEach(d => console.log(d + '\\\\n'));\\n\\nconsole.log('\\\\n=== Detailed Server Errors ===');\\nconst serverErrorDetails = new Set();\\ncategorizedErrors.serverErrors.slice(0, 20).forEach(e => {\\n  try {\\n    const parsed = JSON.parse(e.snippet);\\n    if (parsed.message && parsed.message.content) {\\n      const content = JSON.stringify(parsed.message.content);\\n      if (content.includes('500') || content.includes('502') || content.includes('503')) {\\n        serverErrorDetails.add(content.substring(0, 400));\\n      }\\n    }\\n  } catch (err) {}\\n});\\nserverErrorDetails.forEach(d => console.log(d + '\\\