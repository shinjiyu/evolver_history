果\\nfs.writeFileSync('/tmp/real_errors.json', JSON.stringify(findings, null, 2));\\nconsole.log('\\\\n\\\\nDetailed results saved to /tmp/real_errors.json');\\nSCRIPT\\n\\nnode /tmp/find_real_errors.js\",\"timeout\":60}}],\"api\":\"openai-completions\",\"provider\":\"zai\",\"model\":\"glm-5\",\"usage\":{\"input\":2217,\"output\":937,\"cacheRead\":17024,\"cacheWrite\":0,\"totalTokens\":20178,\"cost\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"total\":0}},\"stopReason\":\"toolUse\",\"timestamp\":1771877040794}}\n{\"type\":\"message\",\"id\":\"f21114d3\",\"parentId\":\"abd69bb2\",\"timestamp\":\"2026-02-23T20:05:57.739Z\",\"message\":{\"role\":\"assistant\",\"content\":[{\"type\":\"thinking\",\"thinking\":\"太好了！现在我有了清晰的数据：\\n\\n**主要问题：**\\n1. **P0 - Rate Limit 问题**：206 个 429 错误\\n   - `evomap-auto-bounty` 任务：107 个错误\\n   - `evolver-log-analysis` 任务：6 个错误\\n   - 平均每小时约 9-12 个错误，持续全天\\n\\n2. **P0 - Server Error 问题**：14 个 5xx 错误\\n   - 主要集中在 2月23日下午到晚上\\n   - 可能是 EvoMap API 服务不稳定\\n\\n现在让我继续深入分析：\\n1. 查看其他类型的错误（timeout、connection 等）\\n2. 检查工具调用失败\\n3. 分析性能问题\\n\\n然后生成完整的报告。\",\"thinkingSignature\":\"reasoning_content\"},{\"type\":\"toolCall\",\"id\":\"call_9cc051b705814105b46cb9e8\",\"name\":\"exec\",\"arguments\":{\"command\":\"cat > /tmp/check_tool_errors.js << 'SCRIPT'\\nconst fs = require('fs');\\nconst path = require('path');\\n\\nconst sessionsDir = '/root/.openclaw/agents/main/sessions';\\nconst sixHoursAgo = Date.now() - (6 * 60 * 60 * 1000);\\n\\nconst toolAnalysis = {\\n  totalToolCalls: 0,\\n  failedToolCalls: [],\\n  timeoutCalls: [],\\n  slowCalls: [],\\n  connectionErrors: []\\n};\\n\\n// 获取最近6小时的文件\\nconst files = fs.readdirSync(sessionsDir)\\n  .filter(f => f.endsWith('.jsonl'))\\n  .map(f => ({\\n    name: f,\\n    path: path.join(sessionsDir, f),\\n    mtime: fs.statSync(path.join(sessionsDir, f)).mtime.getTime()\\n  }))\\n  .filter(f => f.mtime >= sixHoursAgo);\\n\\nconsole.log(`Checking ${files.length} files for tool errors...\\\\n`);\\n\\nfiles.forEach(file => {\\n  const content = fs.readFileSync(file.path, 'utf8');\\n  const lines = content.split('\\\\n').filter(l => l.trim());\\n  \\n  lines.forEach(line => {\\n    try {\\n      const data = JSON.parse(line);\\n      \\n      // 查找 assistant 消息中的工具调用\\n      if (data.type === 'message' && data.message && data.message.role === 'assistant') {\\n        if (data.message.toolCalls) {\\n          toolAnalysis.totalToolCalls += data.message.toolCalls.length;\\n        }\\n      }\\n      \\n      // 查找工具结果中的错误\\n      if (data.type === 'message' && data.message && data.message.role === 'toolResult') {\\n        const result = data.message.content;\\n        \\n        if (typeof result === 'string') {\\n          // 检查连接错误\\n          if (result.includes('ETIMEDOUT') || result.includes('ECONNREFUSED') || result.includes('ENOTFOUND')) {\\n            toolAnalysis.connectionErrors.push({\\n              file: file.name,\\n              timestamp: data.timestamp,\\n              tool: data.message.toolName,\\n              error: result.substring(0, 200)\\n            });\\n          }\\n          \\n          // 检查超时\\n          if (result.toLowerCase().includes('timeout') && !result.includes('ETIMEDOUT')) {\\n            toolAnalysis.timeoutCalls.push({\\n              file: file.name,\\n              timestamp: data.timestamp,\\n              tool: data.message.toolName,\\n              error: result.substring(0, 200)\\n            });\\n          }\\n          \\n          // 检查失败\\n          if (result.includes('failed') || result.includes('error') || result.includes('Error')) {\\n            toolAnalysis.failedToolCalls.push({\\n              file: file.name,\\n              timestamp: data.timestamp,\\n              tool: data.message.toolName,\\n              error: result.substring(0, 200)\\n            });\\n          }\\n        }\\n      }\\n      \\n    } catch (e) {\\n      // 跳过\\n    }\\n  });\\n});\\n\\nconsole.log('=== Tool Call Analysis ===\\\\n');\\nconsole.log(`Total Tool Calls: ${toolAnalysis.totalToolCalls}`);\\nconsole.log(`Failed Calls: ${toolAnalysis.failedToolCalls.length}`);\\nconsole.log(`Timeout Calls: ${toolAnalysis.timeoutCalls.length}`);\\nconsole.log(`Connection Errors: ${toolAnalysis.connectionErrors.length}\\\\n`);\\n\\nif (toolAnalysis.connectionErrors.length > 0) {\\n  console.log('=== Connection Errors ===');\\n  toolAnalysis.connectionErrors.forEach((e, i) => {\\n    console.log(`\\\\n[${i + 1}] ${e.tool} at ${e.timestamp}`);\\n    console.log(`  File: ${e.file}`);\\n    console.log(`  Error: ${e.error}`);\\n  });\\n}\\n\\nif (toolAnalysis.timeoutCalls.length > 0) {\\n  console.log('\\\\n=== Timeout Errors ===');\\n  toolAnalysis.timeoutCalls.slice(0, 5).forEach((e, i) => {\\n    console.log(`\\\\n[${i + 1}] ${e.tool} at ${e.timestamp}`);\\n    console.log(`  File: ${e.file}`);\\n    console.log(`  Error: ${e.error}`);\\n  });\\n}\\n\\nif (toolAnalysis.failedToolCalls.length > 0) {\\n  console.log('\\\\n=== Sample Failed Tool Calls ===');\\n  \\n  // 按工具统计\\n  const toolCounts = {};\\n  toolAnalysis.failedToolCalls.forEach(e => {\\n    toolCounts[e.tool] = (toolCounts[e.tool] || 0) + 1;\\n  });\\n  \\n  console.log('\\\\nBy Tool:');\\n  Object.entries(toolCounts)\\n    .sort((a, b) => b[1] - a[1])\\n    .forEach(([tool, count]) => {\\n      console.log(`  ${tool}: ${count} failures`);\\n    });\\n  \\n  console.log('\\\\nSample Errors:');\\n  toolAnalysis.failedToolCalls.slice(0, 5).forEach((e, i) => {\\n    console.log(`\\\\n[${i + 1}] ${e.tool}`);\\n    console.log(`  Time: ${e.timestamp}`);\\n    console.log(`  Error: ${e.error}`);\\n  });\\n}\\n\\nfs.writeFileSync('/tmp/tool_errors.json', JSON.stringify(toolAnalysis, null, 2));\\nconsole.log('\\\\n\\\\nTool errors saved to /tmp/tool_errors.json');\\nSCRIPT\\n\\nnode /tmp/check_tool_errors.js\",\"timeout\":60}}],\"api\":\"openai-completions\",\"provider\":\"zai\",\"model\":\"glm-5\",\"usage\":{\"input\":1951,\"output\"