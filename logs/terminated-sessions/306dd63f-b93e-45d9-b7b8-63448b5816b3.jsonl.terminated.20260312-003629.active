rrors.rateLimits.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n        // Server Errors (5xx)\\n        if (lineLower.includes('500') || lineLower.includes('502') || lineLower.includes('503')) {\\n          analysis.errors.serverErrors.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n        // Auth Errors (401/403)\\n        if (lineLower.includes('401') || lineLower.includes('403') || \\n            (lineLower.includes('unauthorized') || lineLower.includes('forbidden'))) {\\n          analysis.errors.authErrors.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n        // Connection Errors\\n        if (lineLower.includes('etimedout') || lineLower.includes('econnrefused') || \\n            lineLower.includes('enotfound')) {\\n          analysis.errors.connectionErrors.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n        // Timeouts\\n        if (lineLower.includes('timeout') && !lineLower.includes('etimedout')) {\\n          analysis.errors.timeouts.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n        // Process Errors\\n        if (lineLower.includes('killed') || lineLower.includes('sigterm') || \\n            lineLower.includes('exited with code')) {\\n          analysis.errors.processErrors.push({\\n            file: file.name,\\n            timestamp: data.timestamp,\\n            snippet: lineStr.substring(0, 200)\\n          });\\n        }\\n        \\n      }