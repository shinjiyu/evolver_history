{"type":"message","id":"bc04469a","parentId":"25412587","timestamp":"2026-03-04T09:00:32.292Z","message":{"role":"toolResult","toolCallId":"call_7398907e3ee741db8b48705b","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * EvoMap 文档生成器\n * \n * 功能：\n * - 根据测试结果和监控数据生成系列文档\n * - 支持多种文档模板\n * - 生成索引页面\n */\n\nconst fs = require('fs');\nconst path = require('path');\n\n// 配置\nconst CONFIG = {\n  storage: '/root/.openclaw/workspace/memory/evomap-features',\n  output: '/var/www/kuroneko.chat/evomap-docs',\n  seriesIndex: 'series-index.json'\n};\n\n// 日志\nfunction log(message) {\n  const timestamp = new Date().toISOString();\n  console.log(`[${timestamp}] ${message}`);\n}\n\n// 读取系列索引\nfunction readSeriesIndex() {\n  const filepath = path.join(CONFIG.storage, CONFIG.seriesIndex);\n  if (fs.existsSync(filepath)) {\n    return JSON.parse(fs.readFileSync(filepath, 'utf-8'));\n  }\n  return {\n    totalDocs: 0,\n    lastUpdate: null,\n    documents: []\n  };\n}\n\n// 写入系列索引\nfunction writeSeriesIndex(index) {\n  const filepath = path.join(CONFIG.storage, CONFIG.seriesIndex);\n  fs.writeFileSync(filepath, JSON.stringify(index, null, 2));\n}\n\n// 读取测试结果\nfunction readTestResults() {\n  const filepath = path.join(CONFIG.storage, 'test-results.json');\n  if (fs.existsSync(filepath)) {\n    return JSON.parse(fs.readFileSync(filepath, 'utf-8'));\n  }\n  return null;\n}\n\n// 读取最新文档\nfunction readLatestDocs() {\n  const skillPath = path.join(CONFIG.storage, 'latest-skill.md');\n  const llmsPath = path.join(CONFIG.storage, 'latest-llms-full.txt');\n  \n  const result = {};\n  \n  if (fs.existsSync(skillPath)) {\n    result.skill = fs.readFileSync(skillPath, 'utf-8');\n  }\n  \n  if (fs.existsSync(llmsPath)) {\n    result.llmsFull = fs.readFileSync(llmsPath, 'utf-8');\n  }\n  \n  return result;\n}\n\n// 读取变更日志\nfunction readChangelog() {\n  const filepath = path.join(CONFIG.storage, 'changelog.json');\n  if (fs.existsSync(filepath)) {\n    return JSON.parse(fs.readFileSync(filepath, 'utf-8'));\n  }\n  return { entries: [] };\n}\n\n// 生成文档模板\nfunction generateDocTemplate(params) {\n  const { issueNumber, title, description, endpoints, examples, testResults, bestPractices, problems, changelog } = params;\n  \n  return `# EvoMap 功能系列 - 第 ${issueNumber} 期：${title}\n\n## 功能简介\n\n${description}\n\n## API 端点\n\n${endpoints.map(e => `- \\`${e.method} ${e.path}\\` - ${e.description}`).join('\\n')}\n\n## 使用方法\n\n### 1. 基础调用\n\n\\`\\`\\`javascript\n${examples.basic}\n\\`\\`\\`\n\n### 2. 高级用法\n\n\\`\\`\\`javascript\n${examples.advanced}\n\\`\\`\\`\n\n## 实测结果\n\n- **响应时间**：${testResults.avgResponseTime}ms\n- **成功率**：${((testResults.passed / testResults.total) * 100).toFixed(1)}%\n- **测试次数**：${testResults.total}\n\n### 详细测试结果\n\n| 端点 | 状态码 | 响应时间 | 结果 |\n|------|--------|----------|------|\n${testResults.tests.map(t => `| ${t.endpoint} | ${t.statusCode} | ${t.responseTime}ms | ${t.success ? '✓' : '✗'} |`).join('\\n')}\n\n## 可能遇到的问题\n\n${problems.map((p, i) => `${i + 1}. **${p.title}** - ${p.solution}`).join('\\n')}\n\n## 最佳实践\n\n${bestPractices.map(bp => `- ${bp}`).join('\\n')}\n\n## 更新日志\n\n${changelog.map(c => `- ${c.date}：${c.change}`).join('\\n')}\n\n---\n\n*本系列持续更新中...*\n\n**相关链接**：\n- [EvoMap 官网](https://evomap.ai)\n- [API 文档](https://evomap.ai/skill.md)\n- [完整文档](https://evomap.ai/llms-full.txt)\n- [系列索引](/evomap-docs/)\n\n**系列导航**：\n${issueNumber > 1 ? `- [上一期：第 ${issueNumber - 1} 期](/evomap-docs/issue-${issueNumber - 1}.html)` : ''}\n- [返回索引](/evomap-docs/)\n`;\n}\n\n// 生成索引页面\nfunction generateIndexPage(seriesIndex) {\n  return `# EvoMap 功能系列 - 索引\n\n> 持续追踪 EvoMap 平台功能更新，提供实测使用指南\n\n## 系列概述\n\n- **总文档数**：${seriesIndex.totalDocs}\n- **最后更新**：${seriesIndex.lastUpdate || '暂无'}\n- **更新频率**：每小时自动监控\n\n## 文档列表\n\n${seriesIndex.documents.length > 0 ? seriesIndex.documents.map(doc => \n  `### [第 ${doc.issue} 期：${doc.title}](/evomap-docs/issue-${doc.issue}.html)\n  \n  - **发布时间**：${doc.date}\n  - **关键词**：${doc.keywords.join(', ')}\n  - **摘要**：${doc.summary}\n  \n  `).join('\\n') : '暂无文档'}\n\n## 关于本系列\n\n本系列文档由 OpenClaw Agent 自动生成和维护，旨在：\n\n1. **实时监控** EvoMap 平台功能更新\n2. **实际测试** 每个 API 端点的可用性\n3. **提供示例** 帮助开发者快速上手\n4. **记录问题** 和解决方案\n\n## 快速链接\n\n- [EvoMap 官网](https://evomap.ai)\n- [API 文档](https://evomap.ai/skill.md)\n- [完整文档](https://evomap.ai/llms-full.txt)\n\n---\n\n*由 OpenClaw Agent 自动生成*\n`;\n}\n\n// 生成第一期文档（概览）\nfunction generateFirstDoc(docs, testResults, changelog) {\n  const index = readSeriesIndex();\n  \n  const params = {\n    issueNumber: 1,\n    title: 'EvoMap 平台概览',\n    description: 'EvoMap 是一个 AI Agent 知识资产市场，支持 Gene 和 Capsule 的发布、交易，以及 Agent-to-Agent (A2A) 点对点服务调用。本文将介绍 EvoMap 的核心功能、API 端点和使用方法。',\n    endpoints: [\n      { method: 'GET', path: '/health', description: '健康检查' },\n      { method: 'GET', path: '/api/node/:id', description: '获取节点信息' },\n      { method: 'GET', path: '/api/bounties', description: '获取悬赏任务列表' },\n      { method: 'GET', path: '/api/capsules', description: '获取 Capsule 列表' },\n      { method: 'GET', path: '/api/leaderboard', description: '获取排行榜' },\n      { method: 'GET', path: '/api/a2a/tasks', description: '获取 A2A 任务列表' }\n    ],\n    examples: {\n      basic: `// 健康检查\nconst https = require('https');\n\nhttps.get('https://evomap.ai/health', (res) => {\n  let data = '';\n  res.on('data', chunk => data += chunk);\n  res.on('end', () => {\n    console.log('Health:', data);\n    // 输出: {\"status\":\"ok\"}\n  });\n});`,\n      advanced: `// 使用 API Key 访问受保护端点\nconst https = require('https');\n\nconst options = {\n  hostname: 'evomap.ai',\n  path: '/api/node/your-node-id',\n  method: 'GET',\n  headers: {\n    'Authorization': 'Bearer YOUR_API_KEY',\n    'Content-Type': 'application/json'\n  }\n};\n\nhttps.get(options, (res) => {\n  let data = '';\n  res.on('data', chunk => data += chunk);\n  res.on('end', () => {\n    const node = JSON.parse(data);\n    console.log('Node:', node);\n  });\n});`\n    },\n    testResults: testResults || {\n      avgResponseTime: 0,\n      passed: 0,\n      total: 0,\n      tests: []\n    },\n    bestPractices: [\n      '使用 API Key 进行认证，避免匿名访问限制',\n      '实现重试机制，处理网络波动',\n      '缓存常用数据，减少 API 调用',\n      '监控响应时间，及时发现性能问题',\n      '定期检查文档更新，了解新功能'\n    ],\n    problems: [\n      {\n        title: 'API 调用返回 401 Unauthorized',\n        solution: '检查 API Key 是否正确，确保在请求头中包含 Authorization: Bearer YOUR_API_KEY'\n      },\n      {\n        title: '请求超时',\n        solution: 'EvoMap API 默认超时 30 秒，建议设置合理的超时时间并实现重试机制'\n      },\n      {\n        title: '节点数据为空',\n        solution: '新注册节点需要发送心跳激活，确保节点处于 active 状态'\n      }\n    ],\n    changelog: [\n      { date: '2026-03-04', change: '首次发布' }\n    ]\n  };\n  \n  return generateDocTemplate(params);\n}\n\n// 主生成函数\nasync function generateDocs() {\n  log('开始生成文档...');\n  \n  // 读取数据\n  const docs = readLatestDocs();\n  const testResults = readTestResults();\n  const changelog = readChangelog();\n  const seriesIndex = readSeriesIndex();\n  \n  // 检查是否需要生成新文档\n  const needsNewDoc = seriesIndex.totalDocs === 0 || \n    (changelog.entries.length > 0 && \n     changelog.entries[changelog.entries.length - 1].timestamp !== seriesIndex.lastUpdate);\n  \n  if (needsNewDoc) {\n    log('检测到变化，生成新文档...');\n    \n    // 确定文档编号\n    const issueNumber = seriesIndex.totalDocs + 1;\n    \n    // 生成文档\n    const docContent = generateFirstDoc(docs, testResults, changelog);\n    \n    // 保存文档\n    const docFilename = `issue-${issueNumber}.md`;\n    const docPath = path.join(CONFIG.output, docFilename);\n    fs.writeFileSync(docPath, docContent);\n    log(`✓ 文档已保存: ${docPath}`);\n    \n    // 更新索引\n    seriesIndex.totalDocs = issueNumber;\n    seriesIndex.lastUpdate = new Date().toISOString();\n    seriesIndex.documents.push({\n      issue: issueNumber,\n      title: issueNumber === 1 ? 'EvoMap 平台概览' : '功能更新',\n      date: new Date().toISOString().split('T')[0],\n      keywords: ['EvoMap', 'API', 'Agent'],\n      summary: issueNumber === 1 ? 'EvoMap 平台核心功能介绍' : '最新功能更新'\n    });\n    \n    writeSeriesIndex(seriesIndex);\n    log('✓ 系列索引已更新');\n  } else {\n    log('无需生成新文档');\n  }\n  \n  // 生成/更新索引页面\n  const indexContent = generateIndexPage(seriesIndex);\n  const indexPath = path.join(CONFIG.output, 'index.md');\n  fs.writeFileSync(indexPath, indexContent);\n  log(`✓ 索引页面已生成: ${indexPath}`);\n  \n  log('文档生成完成');\n  \n  return {\n    generated: needsNewDoc,\n    totalDocs: seriesIndex.totalDocs\n  };\n}\n\n// 如果直接运行\nif (require.main === module) {\n  generateDocs().catch(error => {\n    console.error('文档生成失败:', error);\n    process.exit(1);\n  });\n}\n\nmodule.exports = { generateDocs, generateDocTemplate, generateIndexPage };\n"}],"isError":false,"timestamp":1772614832292}}
