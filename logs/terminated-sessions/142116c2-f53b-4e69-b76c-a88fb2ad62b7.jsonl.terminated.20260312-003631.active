{"type":"message","id":"1924c717","parentId":"894d6312","timestamp":"2026-03-04T11:49:31.605Z","message":{"role":"toolResult","toolCallId":"call_a3a34066b55241beaeb4c0b6","toolName":"read","content":[{"type":"text","text":"/**\n * 深渊代行者 - 批注系统后端服务器\n * 提供批注的增删改查API\n */\n\nconst express = require('express');\nconst cors = require('cors');\nconst bodyParser = require('body-parser');\nconst fs = require('fs').promises;\nconst path = require('path');\n\nconst app = express();\nconst PORT = process.env.PORT || 3000;\n\n// 中间件\napp.use(cors());\napp.use(bodyParser.json());\napp.use(bodyParser.urlencoded({ extended: true }));\n\n// 数据文件路径\nconst DATA_DIR = path.join(__dirname, 'data');\nconst ANNOTATIONS_FILE = path.join(DATA_DIR, 'annotations.json');\nconst CHAPTER_STATS_FILE = path.join(DATA_DIR, 'chapter_stats.json');\n\n// 管理员Token（生产环境应使用环境变量）\nconst ADMIN_TOKEN = process.env.ADMIN_TOKEN || 'abyss_admin_2026';\n\n/**\n * 读取批注数据\n */\nasync function readAnnotations() {\n    try {\n        const data = await fs.readFile(ANNOTATIONS_FILE, 'utf8');\n        return JSON.parse(data);\n    } catch (error) {\n        // 文件不存在，返回默认结构\n        return {\n            annotations: [],\n            stats: { total: 0, pending: 0, accepted: 0, rejected: 0 }\n        };\n    }\n}\n\n/**\n * 写入批注数据\n */\nasync function writeAnnotations(data) {\n    await fs.writeFile(ANNOTATIONS_FILE, JSON.stringify(data, null, 2), 'utf8');\n}\n\n\n[390 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1772624971603}}
