type f -newermt \\\"$(date -d \\\"@$SIX_HOURS_AGO\\\" '+%Y-%m-%d %H:%M:%S')\\\" 2>/dev/null | sort)\\nFILE_COUNT=$(echo \\\"$RECENT_FILES\\\" | grep -c \\\".jsonl\\\" || echo \\\"0\\\")\\necho \\\"找到 $FILE_COUNT 个 session 文件\\\"\\necho \\\"\\\"\\n\\n# 统计各类错误\\necho \\\"=== 2. 错误统计 ===\\\"\\necho \\\"\\\"\\n\\n# 2.1 HTTP 错误\\necho \\\"【HTTP 错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    cat \\\"$file\\\" | grep -oE '\\\"(status|statusCode)\\\":\\\\s*[0-9]+' | grep -oE '[0-9]+' | sort | uniq -c | sort -rn\\ndone | awk '{count[$2]+=$1} END {for (code in count) print count[code], code}' | sort -rn | head -10\\necho \\\"\\\"\\n\\n# 2.2 429 Rate Limit\\necho \\\"【429 Rate Limit 错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -c '\\\"status\\\":\\\\s*429' \\\"$file\\\" 2>/dev/null || echo \\\"0\\\"\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 2.3 isError 标记\\necho \\\"【isError=true 错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -c '\\\"isError\\\":\\\\s*true' \\\"$file\\\" 2>/dev/null || echo \\\"0\\\"\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 2.4 timeout 错误\\necho \\\"【Timeout 错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -iE 'timeout|timed?[-_]?out' \\\"$file\\\" 2>/dev/null | wc -l\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 2.5 network_error\\necho \\\"【Network 错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -c 'network_error' \\\"$file\\\" 2>/dev/null || echo \\\"0\\\"\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 2.6 aborted 错误\\necho \\\"【Aborted 错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -ci 'aborted' \\\"$file\\\" 2>/dev/null || echo \\\"0\\\"\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 2.7 ENOENT 文件错误\\necho \\\"【ENOENT 文件错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -c 'ENOENT' \\\"$file\\\" 2>/dev/null || echo \\\"0\\\"\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 2.8 401/403 认证错误\\necho \\\"【401/403 认证错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -oE '\\\"status\\\":\\\\s*(401|403)' \\\"$file\\\" 2>/dev/null | wc -l\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 2.9 5xx 服务器错误\\necho \\\"【5xx 服务器错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -oE '\\\"status\\\":\\\\s*5[0-9][0-9]' \\\"$file\\\" 2>/dev/null | wc -l\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 2.10 错误消息模式\\necho \\\"【错误消息 Top 10】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    cat \\\"$file\\\" | grep -oP '(?<=\\\"error\\\":\\\\s*\\\")[^\\\"]*' | head -100\\n    cat \\\"$file\\\" | grep -oP '(?<=\\\"message\\\":\\\\s*\\\")[^\\\"]*' | grep -iE 'error|fail|timeout|abort' | head -100\\ndone | sort | uniq -c | sort -rn | head -10\\necho \\\"\\\"\\n\\n# 3. 工具调用分析\\necho \\\"=== 3. 工具调用统计 ===\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    cat \\\"$file\\\" | grep -oP '(?<=\\\"tool\\\":\\\\s*\\\")[^\\\"]*'\\ndone | sort | uniq -c | sort -rn | head -15\\necho \\\"\\\"\\n\\n# 4. 慢响应分析\\necho \\\"=== 4. 慢响应分析（>5s）===\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    cat \\\"$file\\\" | grep -oP '(?<=\\\"duration\\\":\\\\s*)[0-9]+' | awk '{if ($1 > 5000) count++} END {print \\\"慢响应(>5s):\\\", count+0, \\\"次\\\"}'\\ndone | awk '{sum+=$2} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 5. API 调用分析\\necho \\\"=== 5. API 调用统计 ===\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -oP 'api\\\\.[^\\\"]+' \\\"$file\\\" | head -100\\n    grep -oP 'https?://[^\\\"]+api[^\\\"]*' \\\"$file\\\" | head -100\\ndone | sort | uniq -c | sort -rn | head -10\\necho \\\"\\\"\\n\\n# 6. 模型调用分析\\necho \\\"=== 6. 模型调用统计 ===\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    cat \\\"$file\\\" | grep -oP '(?<=\\\"model\\\":\\\\s*\\\")[^\\\"]*' | head -100\\ndone | sort | uniq -c | sort -rn\\necho \\\"\\\"\\n\\n# 7. 特定错误模式\\necho \\\"=== 7. 特定错误模式 ===\\\"\\n\\n# 7.1 Gateway 错误\\necho \\\"【Gateway 错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -ci 'gateway' \\\"$file\\\" 2>/dev/null || echo \\\"0\\\"\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 7.2 Subagent 错误\\necho \\\"【Subagent 错误】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -c 'Unknown subagent target' \\\"$file\\\" 2>/dev/null || echo \\\"0\\\"\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\n# 7.3 内存相关\\necho \\\"【内存相关警告】\\\"\\nfor file in $RECENT_FILES; do\\n    [ -f \\\"$file\\\" ] || continue\\n    grep -ciE 'memory|内存' \\\"$file\\\" 2>/dev/null || echo \\\"0\\\"\\ndone | awk '{sum+=$1} END {print \\\"总计:\\\", sum, \\\"次\\\"}'\\necho \\\"\\\"\\n\\necho \\\"=== 分析完成 ===\\\"\\n\"}}],\"api\":\"openai-completions\",\"provider\":\"zai\",\"model\":\"glm-5\",\"usage\":{\"input\":8120,\"output\":2525,\"cacheRead\":10368,\"cacheWrite\":0,\"totalTokens\":21013,\"cost\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"total\":0}},\"stopReason\":\"toolUse\",\"timestamp\":1772928033036}}\n\n---\n=== 6c883048-65b7-4bd9-a492-6984cffddbc4.jsonl ===\n【Timeout 示例】\n{\"type\":\"message\",\"id\":\"ac64bcff\",\"parentId\":\"c17606f5\",\"timestamp\":\"2026-03-03T04:08:22.261Z\",\"message\":{\"role\":\"assistant\",\"content\":[{\"type\":\"thinking\",\"t